@{
    Layout = "_Layout";
    ViewData["Title"] = "Quên mật khẩu";
}

<div class="bg-surface min-h-screen flex flex-col items-center justify-center p-margin-mobile">
    <main class="w-full max-w-[480px] flex flex-col items-center py-unit-xl">
        <!-- Header -->
        <header class="text-center mb-unit-lg">
            <div class="inline-flex items-center justify-center bg-primary rounded-full w-14 h-14 mb-unit-md text-white">
                <span class="material-symbols-outlined text-headline-lg">lock_reset</span>
            </div>
            <h1 class="font-headline-md text-primary font-bold tracking-tight">Khôi phục mật khẩu</h1>
            <p class="font-body-md text-on-surface-variant mt-unit-sm">
                Nhập địa chỉ Email hoặc Số điện thoại liên kết với tài khoản để khôi phục quyền truy cập.
            </p>
        </header>

        <!-- Card -->
        <div class="glass-card w-full rounded-xl p-unit-lg shadow-sm">
            <form action="/Auth/ForgotPassword" method="POST" class="space-y-unit-md">
                <div class="space-y-unit-xs">
                    <label class="block text-caption font-semibold text-on-surface-variant" for="identifier">Email / Số điện thoại đăng ký</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-outline">
                            <span class="material-symbols-outlined">alternate_email</span>
                        </span>
                        <input class="w-full pl-10 pr-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                               id="identifier" name="identifier" placeholder="example@mail.com hoặc 090..." required type="text" />
                    </div>
                </div>

                <!-- Submit Button -->
                <button class="w-full bg-primary text-on-primary font-body-lg font-semibold py-3 rounded-lg hover:bg-primary-container transition-all active:scale-[0.98] flex items-center justify-center gap-unit-sm shadow-md" type="submit">
                    <span>Gửi yêu cầu khôi phục</span>
                    <span class="material-symbols-outlined">send_and_archive</span>
                </button>
            </form>

            <div class="mt-unit-lg pt-unit-md border-t border-outline-variant text-center">
                <p class="text-body-md text-on-surface-variant">
                    Nhớ ra mật khẩu? 
                    <a class="text-primary font-bold hover:underline" href="/Auth/Login">Quay lại Đăng nhập</a>
                </p>
            </div>
        </div>
    </main>
</div>
