@{
    Layout = "_Layout";
    ViewData["Title"] = "Không có quyền truy cập";
}

<body class="bg-surface min-h-screen flex flex-col items-center justify-center p-margin-mobile">
    <main class="w-full max-w-lg flex flex-col items-center text-center py-unit-xl">
        <!-- Icon -->
        <div class="inline-flex items-center justify-center bg-error-container text-error rounded-full w-20 h-20 mb-unit-lg shadow-inner">
            <span class="material-symbols-outlined text-[48px]" style="font-variation-settings: 'FILL' 1;">gpp_maybe</span>
        </div>
        
        <!-- Text -->
        <h1 class="font-headline-lg text-on-surface font-extrabold tracking-tight">Từ chối truy cập!</h1>
        <p class="font-body-md text-on-surface-variant mt-unit-sm max-w-sm mx-auto leading-relaxed">
            Tài khoản của bạn không được cấp quyền hạn để truy cập vào phân hệ này. Vui lòng quay lại hoặc đăng nhập bằng tài khoản khác.
        </p>

        <!-- Actions -->
        <div class="mt-unit-xl w-full flex flex-col gap-unit-sm">
            <a href="/Auth/Login" class="w-full bg-primary text-on-primary font-body-lg font-semibold py-3 rounded-lg hover:bg-primary-container transition-all active:scale-[0.98] flex items-center justify-center gap-unit-sm shadow-md">
                <span class="material-symbols-outlined">home</span>
                <span>Quay về trang chủ</span>
            </a>
            
            <a href="/Auth/Logout" class="w-full bg-white border border-outline text-on-surface font-body-lg font-semibold py-3 rounded-lg hover:bg-surface-container transition-all active:scale-[0.98] flex items-center justify-center gap-unit-sm">
                <span class="material-symbols-outlined">logout</span>
                <span>Đăng xuất tài khoản</span>
            </a>
        </div>
    </main>
</body>
