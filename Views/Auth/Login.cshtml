@{
    Layout = "_Layout";
    ViewData["Title"] = "Đăng nhập an toàn";
}

@section Styles {
<style>
    .auth-shell{min-height:100svh;background:#f5f8fb;color:#102a43;display:grid;grid-template-columns:minmax(0,1.05fr) minmax(480px,.95fr)}
    .auth-brand{position:relative;overflow:hidden;padding:clamp(2.5rem,5vw,5.5rem);display:flex;flex-direction:column;justify-content:space-between;background:linear-gradient(145deg,#063b67 0%,#075985 48%,#087f8c 100%);color:#fff}
    .auth-brand:before{content:"";position:absolute;width:34rem;height:34rem;border:1px solid rgba(255,255,255,.12);border-radius:50%;right:-14rem;top:-15rem;box-shadow:0 0 0 4rem rgba(255,255,255,.025),0 0 0 9rem rgba(255,255,255,.018)}
    .auth-brand:after{content:"";position:absolute;inset:auto -10% -25% 20%;height:55%;background:radial-gradient(ellipse,rgba(66,211,182,.22),transparent 68%);pointer-events:none}
    .brand-lockup,.brand-copy,.trust-list{position:relative;z-index:1}.brand-lockup{display:flex;align-items:center;gap:.9rem;font-weight:700;letter-spacing:-.02em}.brand-mark{display:grid;place-items:center;width:3rem;height:3rem;border-radius:.9rem;background:#fff;color:#08738a;box-shadow:0 12px 30px rgba(0,0,0,.16)}
    .brand-copy{max-width:42rem}.brand-kicker{display:inline-flex;align-items:center;gap:.5rem;padding:.4rem .7rem;border:1px solid rgba(255,255,255,.2);border-radius:999px;background:rgba(255,255,255,.08);font-size:.75rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase}.brand-copy h1{font-size:clamp(2.25rem,4.2vw,4.75rem);line-height:1.03;letter-spacing:-.045em;margin:1.5rem 0 1.25rem;font-weight:700}.brand-copy p{max-width:36rem;font-size:clamp(1rem,1.4vw,1.2rem);line-height:1.75;color:rgba(255,255,255,.78)}
    .trust-list{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:1rem;padding-top:2rem;border-top:1px solid rgba(255,255,255,.14)}.trust-item{display:flex;gap:.65rem;align-items:flex-start;font-size:.82rem;line-height:1.45;color:rgba(255,255,255,.78)}.trust-item .material-symbols-outlined{color:#76e4cf;font-size:1.25rem}
    .auth-panel{padding:clamp(1.5rem,4vw,4.5rem);display:flex;align-items:center;justify-content:center;background:radial-gradient(circle at 90% 10%,rgba(8,127,140,.08),transparent 30%),#f7fafc}.auth-inner{width:100%;max-width:31rem}.mobile-brand{display:none}.auth-eyebrow{font-size:.78rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:#087f8c}.auth-heading{margin:.55rem 0 .55rem;font-size:clamp(1.8rem,3vw,2.35rem);line-height:1.2;letter-spacing:-.035em;font-weight:700;color:#102a43}.auth-subtitle{color:#627d98;line-height:1.65;margin-bottom:1.8rem}
    .role-fieldset{border:0;padding:0;margin:0 0 1.4rem}.auth-label,.role-fieldset legend{display:block;margin-bottom:.55rem;font-size:.82rem;font-weight:700;color:#334e68}.role-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.65rem}.role-option{min-height:4.65rem;border:1px solid #d5e1eb;border-radius:.8rem;background:#fff;color:#526d82;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:.3rem;transition:transform .18s ease,border-color .18s ease,box-shadow .18s ease,background .18s ease}.role-option:hover{border-color:#70a9bd;background:#f6fbfc}.role-option[aria-pressed="true"]{border-color:#087f8c;background:#edfafa;color:#086477;box-shadow:0 0 0 3px rgba(8,127,140,.1)}.role-option:focus-visible,.auth-input:focus-visible,.password-toggle:focus-visible,.auth-primary:focus-visible,.auth-link:focus-visible,.demo-button:focus-visible{outline:3px solid rgba(8,127,140,.3);outline-offset:2px}
    .field{margin-bottom:1.15rem}.input-wrap{position:relative}.input-icon{position:absolute;left:.95rem;top:50%;transform:translateY(-50%);font-size:1.25rem;color:#829ab1;pointer-events:none}.auth-input{width:100%;height:3.25rem;padding:0 3rem 0 3rem;border:1px solid #cbd8e3;border-radius:.75rem;background:#fff;color:#102a43;transition:border-color .18s,box-shadow .18s}.auth-input::placeholder{color:#9aabba}.auth-input:focus{border-color:#087f8c;box-shadow:0 0 0 4px rgba(8,127,140,.1);outline:0}.password-toggle{position:absolute;right:.45rem;top:50%;transform:translateY(-50%);width:2.5rem;height:2.5rem;border-radius:.55rem;color:#627d98;display:grid;place-items:center}.password-toggle:hover{background:#edf2f7;color:#086477}
    .auth-meta{display:flex;justify-content:space-between;gap:1rem;align-items:center;margin:.2rem 0 1.4rem;font-size:.84rem}.remember{display:flex;gap:.55rem;align-items:center;color:#526d82}.remember input{width:1rem;height:1rem;border-radius:.25rem;color:#087f8c}.auth-link{color:#087083;font-weight:700;text-decoration:none}.auth-link:hover{text-decoration:underline}.auth-primary{width:100%;height:3.35rem;border-radius:.75rem;background:#086b7d;color:#fff;font-weight:700;display:flex;align-items:center;justify-content:center;gap:.55rem;box-shadow:0 10px 22px rgba(8,107,125,.2);transition:transform .18s,background .18s,box-shadow .18s}.auth-primary:hover{background:#075b6b;transform:translateY(-1px);box-shadow:0 14px 28px rgba(8,107,125,.24)}.auth-primary:active{transform:translateY(0)}
    .auth-register{text-align:center;margin:1.4rem 0;color:#627d98;font-size:.9rem}.demo-disclosure{border-top:1px solid #d9e2ec;padding-top:1rem}.demo-disclosure summary{cursor:pointer;color:#526d82;font-size:.84rem;font-weight:600;text-align:center;list-style:none}.demo-disclosure summary::-webkit-details-marker{display:none}.demo-disclosure summary:after{content:"keyboard_arrow_down";font-family:'Material Symbols Outlined';vertical-align:middle;margin-left:.35rem}.demo-disclosure[open] summary:after{content:"keyboard_arrow_up"}.demo-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.55rem;margin-top:.9rem}.demo-button{padding:.65rem .35rem;border:1px solid #d5e1eb;border-radius:.65rem;background:#fff;color:#526d82;font-size:.76rem;font-weight:700}.demo-button:hover{border-color:#70a9bd;color:#086477;background:#f6fbfc}.security-note{display:flex;align-items:center;justify-content:center;gap:.4rem;margin-top:1.5rem;color:#829ab1;font-size:.76rem}.security-note .material-symbols-outlined{font-size:1rem}
    @@media(max-width:960px){.auth-shell{grid-template-columns:1fr}.auth-brand{display:none}.mobile-brand{display:flex;align-items:center;gap:.7rem;margin-bottom:2.25rem;color:#086477;font-weight:750}.mobile-brand .brand-mark{width:2.6rem;height:2.6rem;background:#086b7d;color:#fff;box-shadow:none}.auth-panel{align-items:flex-start;padding-top:clamp(2rem,8vh,5rem)}}
    @@media(max-width:520px){.auth-panel{padding:1.25rem}.auth-inner{max-width:none}.role-grid{gap:.45rem}.role-option{font-size:.76rem}.auth-meta{align-items:flex-start}.demo-grid{grid-template-columns:1fr}.auth-heading{font-size:1.75rem}}
    @@media(prefers-reduced-motion:reduce){.role-option,.auth-primary{transition:none}.auth-primary:hover{transform:none}}
    /* Blue hospital palette shared with all authenticated portals. */
    .auth-brand{background:linear-gradient(145deg,#063b67 0%,#0b5cab 52%,#2a76c5 100%)}
    .brand-mark{color:#0b5cab}.trust-item .material-symbols-outlined{color:#a9d4ff}
    .auth-panel{background:radial-gradient(circle at 90% 10%,rgba(169,212,255,.18),transparent 30%),#f7faff}
    .auth-eyebrow,.auth-link{color:#0b5cab}.role-option[aria-pressed="true"]{border-color:#0b5cab;background:#eaf3ff;color:#08457f;box-shadow:0 0 0 3px rgba(11,92,171,.1)}
    .role-option:focus-visible,.auth-input:focus-visible,.password-toggle:focus-visible,.auth-primary:focus-visible,.auth-link:focus-visible,.demo-button:focus-visible{outline-color:rgba(11,92,171,.3)}
    .auth-input:focus{border-color:#70a9e8;box-shadow:0 0 0 4px rgba(11,92,171,.1)}.auth-primary{background:#0b5cab;box-shadow:0 10px 22px rgba(11,92,171,.2)}.auth-primary:hover{background:#08457f;box-shadow:0 14px 28px rgba(11,92,171,.24)}.password-toggle:hover,.demo-button:hover{color:#0b5cab}.mobile-brand{color:#0b5cab}.mobile-brand .brand-mark{background:#0b5cab}
</style>
}

<div class="auth-shell">
    <aside class="auth-brand" aria-label="Giới thiệu hệ thống">
        <a href="/" class="brand-lockup" aria-label="MediFlow HMS - Trang chủ">
            <span class="brand-mark"><span class="material-symbols-outlined" style="font-size:1.85rem;font-variation-settings:'FILL' 1">medical_services</span></span>
            <span>MediFlow <span style="font-weight:400;opacity:.72">HMS</span></span>
        </a>
        <div class="brand-copy">
            <span class="brand-kicker"><span class="material-symbols-outlined" style="font-size:1rem">verified_user</span> Hospital Information System</span>
            <h1>Vận hành bệnh viện.<br/>An toàn và liền mạch.</h1>
            <p>Một không gian làm việc thống nhất cho đội ngũ y tế, quản trị viên và người bệnh — được thiết kế để mỗi quyết định chăm sóc đều rõ ràng, nhanh chóng và đáng tin cậy.</p>
        </div>
        <div class="trust-list" aria-label="Cam kết hệ thống">
            <div class="trust-item"><span class="material-symbols-outlined">shield_lock</span><span>Bảo vệ dữ liệu<br/>y tế nhạy cảm</span></div>
            <div class="trust-item"><span class="material-symbols-outlined">clinical_notes</span><span>Hồ sơ xuyên suốt<br/>hành trình điều trị</span></div>
            <div class="trust-item"><span class="material-symbols-outlined">support_agent</span><span>Hỗ trợ vận hành<br/>24 giờ mỗi ngày</span></div>
        </div>
    </aside>

    <main class="auth-panel">
        <div class="auth-inner">
            <a href="/" class="mobile-brand"><span class="brand-mark"><span class="material-symbols-outlined">medical_services</span></span><span>MediFlow HMS</span></a>
            <p class="auth-eyebrow">Cổng truy cập bảo mật</p>
            <h2 class="auth-heading">Chào mừng bạn trở lại</h2>
            <p class="auth-subtitle">Đăng nhập bằng tài khoản đã được bệnh viện cấp để tiếp tục công việc.</p>

            <form action="/Auth/Login" method="post">
                @Html.AntiForgeryToken()
                <fieldset class="role-fieldset">
                    <legend>Đăng nhập với vai trò</legend>
                    <div class="role-grid">
                        <button type="button" class="role-option" id="role-patient" aria-pressed="true" onclick="selectLoginRole('Patient')"><span class="material-symbols-outlined">personal_injury</span><span>Bệnh nhân</span></button>
                        <button type="button" class="role-option" id="role-doctor" aria-pressed="false" onclick="selectLoginRole('Doctor')"><span class="material-symbols-outlined">stethoscope</span><span>Bác sĩ</span></button>
                        <button type="button" class="role-option" id="role-admin" aria-pressed="false" onclick="selectLoginRole('Admin')"><span class="material-symbols-outlined">admin_panel_settings</span><span>Quản trị</span></button>
                    </div>
                    <input type="hidden" name="role" id="selected-role-input" value="Patient" />
                </fieldset>
                <div class="field">
                    <label class="auth-label" for="identifier">Email hoặc số điện thoại</label>
                    <div class="input-wrap"><span class="material-symbols-outlined input-icon">account_circle</span><input class="auth-input" id="identifier" name="identifier" placeholder="vidu@benhvien.vn" autocomplete="username" inputmode="email" required /></div>
                </div>
                <div class="field">
                    <label class="auth-label" for="password">Mật khẩu</label>
                    <div class="input-wrap"><span class="material-symbols-outlined input-icon">lock</span><input class="auth-input" id="password" name="password" placeholder="Nhập mật khẩu" type="password" autocomplete="current-password" required /><button class="password-toggle" type="button" onclick="togglePasswordVisibility()" aria-label="Hiện mật khẩu" aria-controls="password"><span class="material-symbols-outlined" id="pw-toggle-icon">visibility</span></button></div>
                </div>
                <div class="auth-meta"><label class="remember"><input name="rememberMe" value="true" type="checkbox"/> Duy trì đăng nhập</label><a class="auth-link" href="/Auth/ForgotPassword">Quên mật khẩu?</a></div>
                <button class="auth-primary" type="submit"><span>Đăng nhập an toàn</span><span class="material-symbols-outlined">arrow_forward</span></button>
            </form>
            <p class="auth-register">Chưa có hồ sơ bệnh nhân? <a class="auth-link" href="/Auth/Register">Tạo tài khoản</a></p>
            <details class="demo-disclosure"><summary>Tài khoản dành cho môi trường trải nghiệm</summary><div class="demo-grid"><button class="demo-button" type="button" onclick="setDemoRole('admin')">Quản trị viên</button><button class="demo-button" type="button" onclick="setDemoRole('doctor')">Bác sĩ</button><button class="demo-button" type="button" onclick="setDemoRole('patient')">Bệnh nhân</button></div></details>
            <p class="security-note"><span class="material-symbols-outlined">lock</span>Kết nối bảo mật · Tự động bảo vệ khi không hoạt động</p>
        </div>
    </main>
</div>

@section Scripts {
<script>
    const demoAccounts={admin:{identifier:'admin@hms.com',password:'Admin@123',role:'Admin'},doctor:{identifier:'doctor@hms.com',password:'Doctor@123',role:'Doctor'},patient:{identifier:'patient@hms.com',password:'Patient@123',role:'Patient'}};
    function selectLoginRole(role){document.getElementById('selected-role-input').value=role;['Patient','Doctor','Admin'].forEach(item=>document.getElementById('role-'+item.toLowerCase()).setAttribute('aria-pressed',String(item===role)));}
    function setDemoRole(key){const account=demoAccounts[key];document.getElementById('identifier').value=account.identifier;document.getElementById('password').value=account.password;selectLoginRole(account.role);document.getElementById('identifier').focus();}
    function togglePasswordVisibility(){const input=document.getElementById('password');const button=document.querySelector('.password-toggle');const icon=document.getElementById('pw-toggle-icon');const show=input.type==='password';input.type=show?'text':'password';icon.textContent=show?'visibility_off':'visibility';button.setAttribute('aria-label',show?'Ẩn mật khẩu':'Hiện mật khẩu');}
</script>
}
