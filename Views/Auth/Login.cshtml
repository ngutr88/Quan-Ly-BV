@{
    Layout = "_Layout";
    ViewData["Title"] = "Đăng nhập";
}

@section Styles {
    <style>
        .login-page-bg {
            background: radial-gradient(circle at 10% 20%, rgba(0, 86, 179, 0.06) 0%, transparent 45%),
                        radial-gradient(circle at 90% 80%, rgba(16, 185, 129, 0.05) 0%, transparent 45%),
                        #f8fafc;
        }
        .login-card {
            background: rgba(255, 255, 255, 0.9);
            backdrop-filter: blur(16px);
            border: 1px solid rgba(226, 232, 240, 0.8);
            box-shadow: 0 20px 25px -5px rgba(0, 86, 179, 0.08), 0 10px 10px -5px rgba(0, 86, 179, 0.03);
            transition: all 0.3s ease;
        }
        .login-card:hover {
            box-shadow: 0 25px 30px -5px rgba(0, 86, 179, 0.12), 0 15px 15px -5px rgba(0, 86, 179, 0.05);
        }
        .demo-pill {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .demo-pill:hover {
            transform: translateY(-1.5px);
            box-shadow: 0 4px 10px rgba(0, 86, 179, 0.08);
        }
        .btn-hover-effect {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-hover-effect:hover {
            background-color: #004494;
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(0, 86, 179, 0.15);
        }
        .quick-btn-hover-effect:hover {
            background-color: #059669;
            transform: translateY(-1px);
            box-shadow: 0 4px 10px rgba(16, 185, 129, 0.15);
        }
    </style>
}

<div class="min-h-screen flex flex-col items-center justify-center p-6 login-page-bg">
    <main class="w-full max-w-lg flex flex-col items-center py-8">
        <!-- Header -->
        <header class="text-center mb-8">
            <div class="inline-flex items-center justify-center bg-primary rounded-2xl w-16 h-16 mb-4 text-white shadow-md shadow-primary/20">
                <svg class="w-10 h-10 text-white" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Logo MediFlow HMS">
                    <path d="M18 7.5h12v10.25h10.5v12.5H30V40.5H18V30.25H7.5v-12.5H18V7.5Z" fill="currentColor" />
                    <path d="M24 13v22M13 24h22" stroke="white" stroke-width="2.5" stroke-linecap="round" opacity=".35" />
                </svg>
            </div>
            <h1 class="font-headline-md text-primary font-bold tracking-tight text-[32px] leading-tight">MediFlow HMS</h1>
            <p class="font-body-md text-on-surface-variant mt-2 max-w-sm mx-auto">
                Hệ thống Quản lý Bệnh viện - Đăng nhập để tiếp tục điều hành, khám bệnh hoặc đặt lịch hẹn.
            </p>
        </header>

        <!-- Login Card -->
        <div class="login-card w-full rounded-2xl p-8 shadow-sm">
            <div class="flex items-center gap-3 mb-6">
                <div class="w-8 h-8 rounded-lg bg-primary/10 flex items-center justify-center">
                    <span class="material-symbols-outlined text-primary text-[20px]" style="font-variation-settings: 'FILL' 1;">lock</span>
                </div>
                <h2 class="font-title-lg text-[20px] font-bold text-on-surface">Đăng nhập hệ thống</h2>
            </div>

            <form class="space-y-5" action="/Auth/Login" method="POST">
                <!-- Role Selection Cards Grid -->
                <div class="space-y-2">
                    <label class="block text-caption font-semibold text-on-surface-variant">Lựa chọn vai trò đăng nhập *</label>
                    <div class="grid grid-cols-3 gap-3">
                        <!-- Patient Card -->
                        <button type="button" id="role-patient" onclick="selectLoginRole('Patient')"
                            class="flex flex-col items-center justify-center p-3 rounded-xl border-2 transition-all cursor-pointer bg-primary/5 border-primary text-primary shadow-sm scale-[1.02] gap-1">
                            <span class="material-symbols-outlined text-[24px]" style="font-variation-settings: 'FILL' 1;">person</span>
                            <span class="font-bold text-caption">Bệnh nhân</span>
                        </button>
                        <!-- Doctor Card -->
                        <button type="button" id="role-doctor" onclick="selectLoginRole('Doctor')"
                            class="flex flex-col items-center justify-center p-3 rounded-xl border-2 transition-all cursor-pointer border-outline-variant hover:border-primary/50 hover:bg-surface-container-low text-on-surface-variant hover:text-on-surface gap-1">
                            <span class="material-symbols-outlined text-[24px]">stethoscope</span>
                            <span class="font-bold text-caption">Bác sĩ</span>
                        </button>
                        <!-- Admin Card -->
                        <button type="button" id="role-admin" onclick="selectLoginRole('Admin')"
                            class="flex flex-col items-center justify-center p-3 rounded-xl border-2 transition-all cursor-pointer border-outline-variant hover:border-primary/50 hover:bg-surface-container-low text-on-surface-variant hover:text-on-surface gap-1">
                            <span class="material-symbols-outlined text-[24px]">admin_panel_settings</span>
                            <span class="font-bold text-caption">Quản trị viên</span>
                        </button>
                    </div>
                    <input type="hidden" name="role" id="selected-role-input" value="Patient" />
                </div>

                <!-- Username Input -->
                <div class="space-y-1.5">
                    <label class="block text-caption font-semibold text-on-surface-variant" for="identifier">Email / Số điện thoại</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-outline-variant">
                            <span class="material-symbols-outlined text-[20px]">person</span>
                        </span>
                        <input
                            class="w-full pl-10 pr-4 py-2.5 bg-white border border-outline-variant rounded-lg font-body-md input-focus transition-all"
                            id="identifier" name="identifier" placeholder="Nhập email hoặc số điện thoại" required
                            type="text" />
                    </div>
                </div>

                <!-- Password Input -->
                <div class="space-y-1.5">
                    <label class="block text-caption font-semibold text-on-surface-variant" for="password">Mật khẩu</label>
                    <div class="relative">
                        <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-outline-variant">
                            <span class="material-symbols-outlined text-[20px]">lock_open</span>
                        </span>
                        <input
                            class="w-full pl-10 pr-12 py-2.5 bg-white border border-outline-variant rounded-lg font-body-md input-focus transition-all"
                            id="password" name="password" placeholder="Nhập mật khẩu" required type="password" />
                        <button
                            class="absolute inset-y-0 right-0 pr-3 flex items-center text-outline hover:text-primary transition-colors"
                            onclick="togglePasswordVisibility()" type="button">
                            <span class="material-symbols-outlined text-[20px]" id="pw-toggle-icon">visibility</span>
                        </button>
                    </div>
                </div>

                <!-- Remember & Forgot -->
                <div class="flex items-center justify-between pt-1">
                    <label class="flex items-center gap-2 cursor-pointer group">
                        <input class="w-4 h-4 text-primary border-outline-variant rounded focus:ring-primary cursor-pointer"
                            name="rememberMe" value="true" type="checkbox" />
                        <span class="text-caption text-on-surface-variant group-hover:text-on-surface transition-colors">Ghi nhớ đăng nhập</span>
                    </label>
                    <a class="text-caption font-semibold text-primary hover:underline transition-colors"
                        href="/Auth/ForgotPassword">Quên mật khẩu?</a>
                </div>

                <!-- Action Button -->
                <button
                    class="w-full bg-primary text-on-primary font-body-lg font-semibold py-3 rounded-lg btn-hover-effect active:scale-[0.98] flex items-center justify-center gap-2 shadow-md shadow-primary/15 mt-2"
                    type="submit">
                    <span>Đăng nhập</span>
                    <span class="material-symbols-outlined text-[20px]">login</span>
                </button>
            </form>

            <div class="mt-6 pt-5 border-t border-outline-variant text-center">
                <p class="text-body-md text-on-surface-variant">
                    Bệnh nhân mới?
                    <a class="text-primary font-bold hover:underline" href="/Auth/Register">Đăng ký tài khoản</a>
                </p>
            </div>
        </div>

        <!-- Demo Accounts Section -->
        <section class="mt-6 w-full">
            <div class="bg-surface-container-lowest border border-outline-variant rounded-2xl p-6 shadow-sm">
                <div class="flex items-center gap-2 mb-4">
                    <div class="w-8 h-8 rounded-lg bg-secondary/10 flex items-center justify-center">
                        <span class="material-symbols-outlined text-secondary text-[20px]" style="font-variation-settings: 'FILL' 1;">auto_awesome</span>
                    </div>
                    <h3 class="font-label-md text-on-surface uppercase font-bold tracking-wider text-[13px]">Tài khoản trải nghiệm nhanh</h3>
                </div>
                <div class="flex flex-wrap gap-2 mb-4">
                    <button
                        class="demo-pill px-4 py-1.5 rounded-full border border-outline text-on-surface-variant font-semibold text-caption hover:border-primary hover:text-primary transition-all bg-white"
                        id="pill-admin" onclick="setDemoRole('admin')">Quản trị viên</button>
                    <button
                        class="demo-pill px-4 py-1.5 rounded-full border border-outline text-on-surface-variant font-semibold text-caption hover:border-primary hover:text-primary transition-all bg-white"
                        id="pill-doctor" onclick="setDemoRole('doctor')">BS. Nguyễn Văn Trung</button>
                    <button
                        class="demo-pill px-4 py-1.5 rounded-full border border-outline text-on-surface-variant font-semibold text-caption hover:border-primary hover:text-primary transition-all bg-white"
                        id="pill-patient" onclick="setDemoRole('patient')">BN. Trần Văn A</button>
                </div>
                <div class="bg-surface-container/30 p-4 rounded-lg border border-outline-variant/30 mb-4">
                    <p class="text-caption text-on-surface-variant leading-relaxed min-h-[48px]" id="demo-description">
                        Chọn một vai trò trải nghiệm nhanh ở trên để điền thông tin tự động và kiểm tra chức năng hệ thống.
                    </p>
                </div>
                <button
                    class="w-full bg-secondary text-white py-2.5 rounded-lg font-semibold text-body-md quick-btn-hover-effect transition-all active:scale-[0.98] hidden"
                    id="btn-quick-login" onclick="submitQuickLogin()">
                    Đăng nhập nhanh vai trò đã chọn
                </button>
            </div>
        </section>
    </main>

    <!-- Professional Footer -->
    <footer class="text-center pb-6 mt-auto">
        <p class="text-caption text-outline">© 2026 Hệ thống Quản lý Bệnh viện HMS MediFlow. Bảo mật &amp; Chuyên nghiệp.</p>
    </footer>

    <script>
        function togglePasswordVisibility() {
            const pwInput = document.getElementById('password');
            const icon = document.getElementById('pw-toggle-icon');
            if (pwInput.type === 'password') {
                pwInput.type = 'text';
                icon.textContent = 'visibility_off';
            } else {
                pwInput.type = 'password';
                icon.textContent = 'visibility';
            }
        }

        function selectLoginRole(role) {
            document.getElementById('selected-role-input').value = role;

            const rolesList = ['Patient', 'Doctor', 'Admin'];
            rolesList.forEach(r => {
                const btn = document.getElementById('role-' + r.toLowerCase());
                if (r === role) {
                    btn.className = "flex flex-col items-center justify-center p-3 rounded-xl border-2 transition-all cursor-pointer bg-primary/5 border-primary text-primary shadow-sm scale-[1.02] gap-1";
                    btn.querySelector('.material-symbols-outlined').style.fontVariationSettings = "'FILL' 1";
                } else {
                    btn.className = "flex flex-col items-center justify-center p-3 rounded-xl border-2 transition-all cursor-pointer border-outline-variant hover:border-primary/50 hover:bg-surface-container-low text-on-surface-variant hover:text-on-surface gap-1";
                    btn.querySelector('.material-symbols-outlined').style.fontVariationSettings = "'FILL' 0";
                }
            });
        }

        const roles = {
            admin: {
                username: "admin@hms.com",
                password: "Admin@123",
                desc: "Quản trị viên: Có toàn quyền quản lý nhân sự bác sĩ, cấu hình dịch vụ, danh mục thuốc, duyệt lịch khám toàn viện và báo cáo thống kê doanh thu.",
                pill: "pill-admin"
            },
            doctor: {
                username: "doctor@hms.com",
                password: "Doctor@123",
                desc: "Bác sĩ Nguyễn Văn Trung: Xem hàng đợi bệnh nhân hôm nay, khám bệnh, ghi chỉ số sinh tồn, chẩn đoán, xem bệnh sử và kê đơn thuốc (FEFO trừ kho).",
                pill: "pill-doctor"
            },
            patient: {
                username: "patient@hms.com",
                password: "Patient@123",
                desc: "Bệnh nhân Trần Văn A: Đặt lịch khám trực tuyến, theo dõi đơn thuốc, nhận thông báo nhắc lịch và xem/thanh toán hóa đơn trực tuyến.",
                pill: "pill-patient"
            }
        };

        let selectedRole = null;

        function setDemoRole(roleKey) {
            selectedRole = roles[roleKey];
            document.getElementById('demo-description').innerText = selectedRole.desc;

            // Fill inputs
            document.getElementById('identifier').value = selectedRole.username;
            document.getElementById('password').value = selectedRole.password;

            // Select role in segmented control
            if (roleKey === 'admin') selectLoginRole('Admin');
            if (roleKey === 'doctor') selectLoginRole('Doctor');
            if (roleKey === 'patient') selectLoginRole('Patient');

            // Update pills UI
            document.querySelectorAll('.demo-pill').forEach(p => {
                p.classList.remove('bg-primary', 'text-white', 'border-primary');
                p.classList.add('bg-white', 'text-on-surface-variant', 'border-outline');
            });

            const activePill = document.getElementById(selectedRole.pill);
            activePill.classList.remove('bg-white', 'text-on-surface-variant', 'border-outline');
            activePill.classList.add('bg-primary', 'text-white', 'border-primary');

            // Show quick login button
            const qBtn = document.getElementById('btn-quick-login');
            qBtn.classList.remove('hidden');
        }

        function submitQuickLogin() {
            if (selectedRole) {
                document.getElementById('identifier').value = selectedRole.username;
                document.getElementById('password').value = selectedRole.password;
                document.querySelector('form').submit();
            }
        }
    </script>
</div>
