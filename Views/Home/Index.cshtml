@{
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
    ViewData["Title"] = "MediFlow HMS - Chăm sóc sức khỏe toàn diện";
}

@section Styles {
    <style>
        .home-hero {
            background:
                radial-gradient(circle at 82% 18%, rgba(215, 226, 255, .7), transparent 34%),
                linear-gradient(135deg, #f8f9ff 0%, #ffffff 56%, #eef4ff 100%);
        }

        .hero-visual {
            box-shadow: 0 32px 80px -34px rgba(15, 45, 85, .48),
                        0 14px 32px -18px rgba(0, 86, 179, .35);
        }

        .hero-float-card {
            box-shadow: 0 18px 45px -24px rgba(15, 45, 85, .55);
        }

        .home-stat {
            border: 1px solid rgba(199, 205, 216, .65);
            box-shadow: 0 12px 30px -24px rgba(15, 45, 85, .55);
            transition: transform .25s ease, box-shadow .25s ease;
        }

        .home-stat:hover {
            transform: translateY(-4px);
            box-shadow: 0 22px 42px -25px rgba(0, 86, 179, .42);
        }

        .home-cta {
            box-shadow: 0 28px 70px -35px rgba(0, 50, 112, .75);
        }
    </style>
}

<section class="home-hero overflow-hidden border-b border-outline-variant/40">
    <div class="max-w-[1440px] mx-auto px-4 md:px-unit-lg py-14 lg:py-24 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-7">
            <div class="inline-flex items-center gap-2 px-3.5 py-1.5 rounded-full bg-primary/10 text-primary font-bold text-xs uppercase tracking-wider">
                <span class="text-primary">•</span>
                Công ty y tế số hiện đại
            </div>
            <h2 class="text-[40px] lg:text-[58px] font-black text-on-surface leading-[1.08] tracking-tight">
                Chăm sóc sức khỏe
                <span class="block"><span class="text-primary">thông minh</span> &amp; toàn diện</span>
            </h2>
            <p class="text-body-lg text-on-surface-variant leading-relaxed max-w-2xl">
                Đặt lịch khám nhanh chóng, theo dõi hồ sơ sức khỏe an toàn và kết nối với đội ngũ bác sĩ chuyên khoa tại MediFlow.
            </p>
            <div class="flex flex-col sm:flex-row gap-4">
                <a href="/Auth/Register" class="px-7 py-3.5 rounded-xl bg-primary text-white font-bold hover:bg-primary-container transition-all flex items-center justify-center gap-2 shadow-lg shadow-primary/15">
                    <span class="material-symbols-outlined text-[22px]" style="font-variation-settings: 'FILL' 1;">event_available</span>
                    Đăng ký khám trực tuyến
                </a>
                <a href="/Home/About" class="px-7 py-3.5 rounded-xl border border-outline-variant bg-white text-primary font-bold hover:bg-primary/5 transition-all flex items-center justify-center gap-2">
                    Khám phá MediFlow
                    <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                </a>
            </div>
        </div>

        <div class="relative mx-auto w-full max-w-[620px] pb-10 lg:pb-0">
            <!-- Glow effect behind image -->
            <div class="absolute -inset-6 bg-primary/15 rounded-[2.25rem] blur-3xl"></div>

            <!-- Doctor Consultation Image -->
            <div class="relative rounded-3xl overflow-hidden shadow-2xl border border-white/80 bg-white/60 p-2 backdrop-blur-sm hero-visual">
                <img src="~/images/hospital_hero_consultation.png" alt="Bác sĩ MediFlow tư vấn sức khỏe cho bệnh nhân"
                     class="w-full aspect-[16/10] object-cover object-center rounded-2xl" />
            </div>

            <!-- Floating Combined Stats & Features Card -->
            <div class="relative mt-8 lg:mt-0 lg:absolute lg:-bottom-10 lg:right-0 lg:left-0 lg:-left-12 bg-white/95 backdrop-blur-md p-5 rounded-[20px] border border-outline-variant/50 shadow-[0_20px_50px_-12px_rgba(0,0,0,0.12)] flex flex-col sm:flex-row items-stretch justify-between gap-5 z-10">
                <!-- Protection Feature -->
                <div class="flex items-center gap-3.5 flex-1">
                    <span class="material-symbols-outlined text-primary text-[32px] shrink-0">verified_user</span>
                    <div>
                        <strong class="block text-on-surface font-bold text-[15px] leading-tight">Bảo mật hồ sơ y tế</strong>
                        <span class="block text-on-surface-variant text-[13px] font-medium mt-0.5">An toàn tuyệt đối</span>
                    </div>
                </div>

                <!-- Divider -->
                <div class="hidden sm:block w-px bg-outline-variant/50 self-stretch my-1"></div>

                <!-- Booking Feature -->
                <div class="flex items-center gap-3.5 flex-1">
                    <span class="material-symbols-outlined text-primary text-[32px] shrink-0">schedule</span>
                    <div>
                        <strong class="block text-on-surface font-bold text-[15px] leading-tight">Đặt lịch 24/7</strong>
                        <span class="block text-on-surface-variant text-[13px] font-medium mt-0.5">Linh hoạt, tiện lợi</span>
                    </div>
                </div>

                <!-- Divider -->
                <div class="hidden sm:block w-px bg-outline-variant/50 self-stretch my-1"></div>

                <!-- Doctors Count Feature -->
                <div class="flex items-center gap-3.5 flex-1">
                    <span class="material-symbols-outlined text-primary text-[32px] shrink-0">groups</span>
                    <div>
                        <strong class="block text-on-surface font-bold text-[15px] leading-tight">150+ Bác sĩ</strong>
                        <span class="block text-on-surface-variant text-[13px] font-medium mt-0.5">Nhiều chuyên khoa</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="bg-white border-b border-outline-variant/40">
    <div class="max-w-[1200px] mx-auto px-4 md:px-unit-lg py-10 grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-6">
        <div class="home-stat rounded-2xl bg-white px-4 py-6 text-center"><strong class="block text-3xl text-primary font-black">20+</strong><span class="text-caption text-on-surface-variant font-semibold">Khoa chuyên môn</span></div>
        <div class="home-stat rounded-2xl bg-white px-4 py-6 text-center"><strong class="block text-3xl text-primary font-black">150+</strong><span class="text-caption text-on-surface-variant font-semibold">Bác sĩ &amp; chuyên gia</span></div>
        <div class="home-stat rounded-2xl bg-white px-4 py-6 text-center"><strong class="block text-3xl text-primary font-black">25.000+</strong><span class="text-caption text-on-surface-variant font-semibold">Lượt khám thành công</span></div>
        <div class="home-stat rounded-2xl bg-white px-4 py-6 text-center"><strong class="block text-3xl text-primary font-black">99,5%</strong><span class="text-caption text-on-surface-variant font-semibold">Khách hàng hài lòng</span></div>
    </div>
</section>

<section class="bg-surface py-14">
    <div class="home-cta max-w-[1100px] mx-auto px-4 md:px-unit-lg rounded-3xl bg-primary text-white p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-7">
        <div>
            <p class="text-primary-fixed font-bold uppercase tracking-wider text-caption mb-2">Bắt đầu hành trình chăm sóc sức khỏe</p>
            <h3 class="text-2xl md:text-3xl font-black">Đặt lịch với bác sĩ phù hợp ngay hôm nay</h3>
        </div>
        <a href="/Auth/Register" class="shrink-0 px-7 py-3.5 rounded-xl bg-white text-primary font-bold hover:bg-primary-fixed transition-colors">Tạo tài khoản bệnh nhân</a>
    </div>
</section>
