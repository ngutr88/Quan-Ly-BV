@{
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
    ViewData["Title"] = "MediFlow HMS - Chăm sóc sức khỏe toàn diện";
}

@section Styles {
    <style>
        .home-hero {
            background:
                radial-gradient(circle at 82% 18%, rgba(215, 226, 255, .7), transparent 34%),
                linear-gradient(135deg, #f8f9ff 0%, #ffffff 56%, #eef4ff 100%);
        }
    </style>
}

<section class="home-hero overflow-hidden border-b border-outline-variant/40">
    <div class="max-w-[1440px] mx-auto px-4 md:px-unit-lg py-14 lg:py-24 grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="space-y-7">
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 text-primary font-bold text-caption uppercase tracking-wider">
                <span class="w-2 h-2 rounded-full bg-primary animate-pulse"></span>
                Cổng y tế số hiện đại
            </div>
            <h2 class="text-[40px] lg:text-[58px] font-black text-on-surface leading-[1.08] tracking-tight">
                Chăm sóc sức khỏe
                <span class="block text-primary">thông minh &amp; toàn diện</span>
            </h2>
            <p class="text-body-lg text-on-surface-variant leading-relaxed max-w-2xl">
                Đặt lịch khám nhanh chóng, theo dõi hồ sơ sức khỏe an toàn và kết nối với đội ngũ bác sĩ chuyên khoa tại MediFlow.
            </p>
            <div class="flex flex-col sm:flex-row gap-3">
                <a href="/Auth/Register" class="px-7 py-3.5 rounded-xl bg-primary text-white font-bold shadow-lg shadow-primary/15 hover:-translate-y-0.5 transition-all flex items-center justify-center gap-2">
                    Đăng ký khám trực tuyến
                    <span class="material-symbols-outlined text-[20px]">arrow_forward</span>
                </a>
                <a href="/Home/About" class="px-7 py-3.5 rounded-xl border border-outline bg-white/70 text-on-surface font-bold hover:bg-white transition-colors flex items-center justify-center">
                    Khám phá MediFlow
                </a>
            </div>
            <div class="flex flex-wrap gap-x-6 gap-y-2 text-caption font-semibold text-on-surface-variant">
                <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-[18px]">verified_user</span>Bảo mật hồ sơ y tế</span>
                <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-[18px]">schedule</span>Đặt lịch 24/7</span>
                <span class="flex items-center gap-1.5"><span class="material-symbols-outlined text-primary text-[18px]">support_agent</span>Hỗ trợ tận tâm</span>
            </div>
        </div>

        <div class="relative mx-auto w-full max-w-[590px]">
            <div class="absolute -inset-5 bg-primary/10 rounded-[2rem] blur-2xl"></div>
            <img src="~/images/hospital_hero_banner.png" alt="Bác sĩ MediFlow và bệnh viện hiện đại"
                 class="relative w-full aspect-[4/3] object-cover rounded-[1.75rem] shadow-2xl border-4 border-white" />
            <div class="absolute top-5 -left-3 md:-left-8 bg-white/90 backdrop-blur-md px-4 py-3 rounded-2xl shadow-xl border border-white flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">verified</span>
                <div><strong class="block text-sm">Tiêu chuẩn JCI</strong><span class="text-[11px] text-on-surface-variant">Chất lượng quốc tế</span></div>
            </div>
            <div class="absolute bottom-5 -right-2 md:-right-7 bg-white/90 backdrop-blur-md px-4 py-3 rounded-2xl shadow-xl border border-white flex items-center gap-3">
                <span class="material-symbols-outlined text-primary">medical_services</span>
                <div><strong class="block text-sm">150+ Bác sĩ</strong><span class="text-[11px] text-on-surface-variant">Nhiều chuyên khoa</span></div>
            </div>
        </div>
    </div>
</section>

<section class="bg-white border-b border-outline-variant/40">
    <div class="max-w-[1200px] mx-auto px-4 md:px-unit-lg py-10 grid grid-cols-2 lg:grid-cols-4 gap-6">
        <div class="text-center"><strong class="block text-3xl text-primary font-black">20+</strong><span class="text-caption text-on-surface-variant font-semibold">Khoa chuyên môn</span></div>
        <div class="text-center"><strong class="block text-3xl text-primary font-black">150+</strong><span class="text-caption text-on-surface-variant font-semibold">Bác sĩ &amp; chuyên gia</span></div>
        <div class="text-center"><strong class="block text-3xl text-primary font-black">25.000+</strong><span class="text-caption text-on-surface-variant font-semibold">Lượt khám thành công</span></div>
        <div class="text-center"><strong class="block text-3xl text-primary font-black">99,5%</strong><span class="text-caption text-on-surface-variant font-semibold">Khách hàng hài lòng</span></div>
    </div>
</section>

<section class="bg-surface py-14">
    <div class="max-w-[1100px] mx-auto px-4 md:px-unit-lg rounded-3xl bg-primary text-white p-8 md:p-12 flex flex-col md:flex-row items-center justify-between gap-7 shadow-xl">
        <div>
            <p class="text-primary-fixed font-bold uppercase tracking-wider text-caption mb-2">Bắt đầu hành trình chăm sóc sức khỏe</p>
            <h3 class="text-2xl md:text-3xl font-black">Đặt lịch với bác sĩ phù hợp ngay hôm nay</h3>
        </div>
        <a href="/Auth/Register" class="shrink-0 px-7 py-3.5 rounded-xl bg-white text-primary font-bold hover:bg-primary-fixed transition-colors">Tạo tài khoản bệnh nhân</a>
    </div>
</section>
