@{
    Layout = "~/Views/Shared/_HomeLayout.cshtml";
    ViewData["Title"] = "Giới thiệu | MediFlow HMS";
}

<!-- Page Banner -->
<section class="bg-gradient-to-r from-primary-fixed to-primary-fixed-dim text-on-primary-fixed py-16 text-center">
    <div class="max-w-[1440px] mx-auto px-unit-lg">
        <h2 class="text-[36px] lg:text-[48px] font-bold tracking-tight">Giới thiệu bệnh viện</h2>
        <p class="text-body-lg opacity-90 max-w-xl mx-auto mt-2">
            Tìm hiểu về lịch sử hình thành, tầm nhìn sứ mệnh và đội ngũ chuyên gia tận tâm tại MediFlow.
        </p>
    </div>
</section>

<!-- Vision & Core Values -->
<section class="py-20 bg-surface">
    <div class="max-w-[1440px] mx-auto px-unit-lg">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-unit-lg mb-16">
            <div class="bg-white border border-outline-variant/60 rounded-2xl p-unit-lg shadow-sm space-y-4">
                <span class="material-symbols-outlined text-primary text-[36px] p-2 bg-primary/10 rounded-xl">visibility</span>
                <h3 class="text-title-lg font-bold text-on-surface">Tầm nhìn</h3>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    Trở thành hệ thống bệnh viện đa khoa thông minh hàng đầu khu vực, tiên phong ứng dụng công nghệ số vào chẩn đoán và điều trị, nâng tầm trải nghiệm chăm sóc sức khỏe cho người dân Việt Nam.
                </p>
            </div>
            
            <div class="bg-white border border-outline-variant/60 rounded-2xl p-unit-lg shadow-sm space-y-4">
                <span class="material-symbols-outlined text-primary text-[36px] p-2 bg-primary/10 rounded-xl">explore</span>
                <h3 class="text-title-lg font-bold text-on-surface">Sứ mệnh</h3>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    Đưa y khoa chất lượng cao tới mọi người dân bằng sự ân cần, thấu hiểu và quy trình số hóa thông minh, giúp tiết kiệm thời gian, tối ưu chi phí và gia tăng tối đa chất lượng phục vụ lâm sàng.
                </p>
            </div>

            <div class="bg-white border border-outline-variant/60 rounded-2xl p-unit-lg shadow-sm space-y-4">
                <span class="material-symbols-outlined text-primary text-[36px] p-2 bg-primary/10 rounded-xl">volunteer_activism</span>
                <h3 class="text-title-lg font-bold text-on-surface">Giá trị cốt lõi</h3>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    <b>Tận tâm:</b> Luôn coi bệnh nhân là trung tâm. <br/>
                    <b>Chính xác:</b> Đảm bảo chẩn đoán chuẩn mực khoa học. <br/>
                    <b>Đổi mới:</b> Tiên phong công nghệ và số hóa toàn bộ dịch vụ y tế.
                </p>
            </div>
        </div>

        <!-- History Timeline -->
        <div class="max-w-4xl mx-auto space-y-8">
            <div class="text-center space-y-2 mb-12">
                <h3 class="text-[28px] lg:text-[36px] font-bold text-on-surface">Dòng lịch sử phát triển</h3>
                <p class="text-body-md text-on-surface-variant">Hành trình khẳng định vị thế và kiến tạo y khoa số của MediFlow</p>
            </div>

            <div class="relative pl-8 border-l-2 border-outline-variant/80 space-y-12">
                <!-- 2026 -->
                <div class="relative">
                    <div class="absolute -left-[41px] top-1.5 w-6 h-6 rounded-full bg-primary border-4 border-white flex items-center justify-center shadow-sm"></div>
                    <div class="bg-white border border-outline-variant/60 p-unit-md rounded-xl shadow-sm space-y-2">
                        <span class="text-label-md font-extrabold text-primary uppercase">Năm 2026</span>
                        <h4 class="text-title-lg font-bold text-on-surface">Chuyển mình sang Y tế số Toàn diện</h4>
                        <p class="text-body-md text-on-surface-variant">
                            Ra mắt cổng thông tin bệnh nhân trực tuyến (MediFlow HMS), tích hợp đặt lịch tự động, bệnh án điện tử tập trung và hệ thống nhắn tin tư vấn trực tiếp từ bác sĩ điều trị.
                        </p>
                    </div>
                </div>

                <!-- 2024 -->
                <div class="relative">
                    <div class="absolute -left-[41px] top-1.5 w-6 h-6 rounded-full bg-primary border-4 border-white flex items-center justify-center shadow-sm"></div>
                    <div class="bg-white border border-outline-variant/60 p-unit-md rounded-xl shadow-sm space-y-2">
                        <span class="text-label-md font-extrabold text-primary uppercase">Năm 2024</span>
                        <h4 class="text-title-lg font-bold text-on-surface">Khánh thành Phân viện kỹ thuật cao</h4>
                        <p class="text-body-md text-on-surface-variant">
                            Mở rộng quy mô thêm 500 giường bệnh nội trú, xây dựng trung tâm chẩn đoán hình ảnh tiên tiến bậc nhất khu vực và lắp đặt hệ thống phòng mổ áp lực âm vô trùng tuyệt đối.
                        </p>
                    </div>
                </div>

                <!-- 2020 -->
                <div class="relative">
                    <div class="absolute -left-[41px] top-1.5 w-6 h-6 rounded-full bg-primary border-4 border-white flex items-center justify-center shadow-sm"></div>
                    <div class="bg-white border border-outline-variant/60 p-unit-md rounded-xl shadow-sm space-y-2">
                        <span class="text-label-md font-extrabold text-primary uppercase">Năm 2020</span>
                        <h4 class="text-title-lg font-bold text-on-surface">Thành lập Bệnh viện Đa khoa</h4>
                        <p class="text-body-md text-on-surface-variant">
                            Chính thức thành lập Bệnh viện Đa khoa MediFlow với 15 khoa chuyên môn lâm sàng ban đầu, quy tụ hơn 80 y bác sĩ đầu ngành công tác.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Leadership Team -->
<section class="py-20 bg-white border-t border-outline-variant/20">
    <div class="max-w-[1440px] mx-auto px-unit-lg">
        <div class="text-center space-y-3 mb-16">
            <h3 class="text-[28px] lg:text-[36px] font-bold text-on-surface">Đội ngũ lãnh đạo chuyên môn</h3>
            <div class="w-12 h-1 bg-primary rounded-full mx-auto"></div>
            <p class="text-body-md text-on-surface-variant">Những giáo sư, bác sĩ chủ chốt chịu trách nhiệm chuyên môn tối cao tại viện</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div class="bg-surface border border-outline-variant/60 rounded-xl p-unit-lg text-center space-y-4">
                <div class="w-24 h-24 rounded-full bg-primary-fixed text-primary flex items-center justify-center text-3xl font-extrabold mx-auto shadow-sm">
                    HP
                </div>
                <div>
                    <h4 class="text-title-lg font-bold text-on-surface">GS. TS. Nguyễn Hoàng Phong</h4>
                    <p class="text-caption text-primary font-bold uppercase tracking-wider mt-1">Giám đốc bệnh viện</p>
                </div>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    Hơn 30 năm kinh nghiệm điều trị tim mạch, nguyên Trưởng khoa Tim mạch Bệnh viện Chợ Rẫy, chịu trách nhiệm vận hành chuyên môn và định hướng số hóa lâm sàng.
                </p>
            </div>

            <div class="bg-surface border border-outline-variant/60 rounded-xl p-unit-lg text-center space-y-4">
                <div class="w-24 h-24 rounded-full bg-primary-fixed text-primary flex items-center justify-center text-3xl font-extrabold mx-auto shadow-sm">
                    AL
                </div>
                <div>
                    <h4 class="text-title-lg font-bold text-on-surface">PGS. TS. Trần Anh Lan</h4>
                    <p class="text-caption text-primary font-bold uppercase tracking-wider mt-1">Phó giám đốc y vụ</p>
                </div>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    Chuyên gia Nội tiết học hàng đầu, tốt nghiệp Y khoa tại Pháp, kiểm soát tối ưu quy trình phác đồ điều trị nội khoa và kiểm tra chất lượng bệnh án điện tử.
                </p>
            </div>

            <div class="bg-surface border border-outline-variant/60 rounded-xl p-unit-lg text-center space-y-4">
                <div class="w-24 h-24 rounded-full bg-primary-fixed text-primary flex items-center justify-center text-3xl font-extrabold mx-auto shadow-sm">
                    KM
                </div>
                <div>
                    <h4 class="text-title-lg font-bold text-on-surface">TS. BS. Vũ Khánh Minh</h4>
                    <p class="text-caption text-primary font-bold uppercase tracking-wider mt-1">Trưởng hội đồng chuyên môn</p>
                </div>
                <p class="text-body-md text-on-surface-variant leading-relaxed">
                    Bác sĩ Ngoại khoa chấn thương chỉnh hình nổi tiếng, người tiên phong ứng dụng kỹ thuật mổ nội soi ít xâm lấn và thay khớp nhân tạo chất lượng cao tại Việt Nam.
                </p>
            </div>
        </div>
    </div>
</section>
