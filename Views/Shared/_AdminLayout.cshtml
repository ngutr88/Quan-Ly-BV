@{
    Layout = "_Layout";
}

<div class="text-on-surface overflow-hidden flex h-screen w-screen">
    <button id="admin-sidebar-backdrop" type="button" aria-label="Đóng menu"
            class="hidden md:hidden fixed inset-0 bg-on-background/40 z-40"
            onclick="closeAdminSidebar()"></button>

    <!-- Side Navigation Bar -->
    <aside id="admin-sidebar" class="fixed md:relative inset-y-0 left-0 -translate-x-full md:translate-x-0 transition-transform duration-200 ease-out w-[280px] max-w-[85vw] h-screen bg-surface-container-lowest border-r border-outline-variant flex flex-col py-unit-lg shrink-0 z-50">
        <button type="button" aria-label="Đóng menu" onclick="closeAdminSidebar()"
                class="md:hidden absolute top-4 right-3 w-9 h-9 flex items-center justify-center rounded-full text-on-surface-variant hover:bg-surface-container-high">
            <span class="material-symbols-outlined">close</span>
        </button>
        <!-- Logo -->
        <div class="px-unit-lg mb-unit-xl">
            <a href="/Admin/Dashboard" class="flex items-center gap-unit-md group">
                <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center shadow-sm group-hover:scale-105 transition-transform">
                    <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">medical_services</span>
                </div>
                <div>
                    <h1 class="font-headline-md text-headline-md font-bold text-primary leading-tight">MediFlow HMS</h1>
                    <p class="text-caption text-on-surface-variant">Quản trị hệ thống</p>
                </div>
            </a>
        </div>

        <nav class="flex-1 px-unit-sm space-y-1 overflow-y-auto custom-scrollbar">
            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-all cursor-pointer active:scale-95 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Admin/Dashboard">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">dashboard</span>
                <span class="font-body-md text-body-md">Dashboard</span>
            </a>

            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-all cursor-pointer active:scale-95 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Appointments" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Admin/Appointments">
                <span class="material-symbols-outlined">calendar_today</span>
                <span class="font-body-md text-body-md">Lịch khám</span>
            </a>

            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-all cursor-pointer active:scale-95 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Doctors" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Admin/Doctors">
                <span class="material-symbols-outlined">stethoscope</span>
                <span class="font-body-md text-body-md">Bác sĩ</span>
            </a>

            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-all cursor-pointer active:scale-95 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Patients" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Admin/Patients">
                <span class="material-symbols-outlined">group</span>
                <span class="font-body-md text-body-md">Bệnh nhân</span>
            </a>

            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-all cursor-pointer active:scale-95 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Departments" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Admin/Departments">
                <span class="material-symbols-outlined">account_tree</span>
                <span class="font-body-md text-body-md">Khoa &amp; Dịch vụ</span>
            </a>

            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-all cursor-pointer active:scale-95 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Medicines" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Admin/Medicines">
                <span class="material-symbols-outlined">inventory_2</span>
                <span class="font-body-md text-body-md">Thuốc &amp; Kho</span>
            </a>

            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-all cursor-pointer active:scale-95 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Invoices" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Admin/Invoices">
                <span class="material-symbols-outlined">receipt_long</span>
                <span class="font-body-md text-body-md">Hóa đơn</span>
            </a>

            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-all cursor-pointer active:scale-95 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Staff" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Admin/Staff">
                <span class="material-symbols-outlined">admin_panel_settings</span>
                <span class="font-body-md text-body-md">Nhân sự &amp; Phân quyền</span>
            </a>
        </nav>

        <!-- Bottom actions -->
        <div class="px-unit-sm mt-auto space-y-1 border-t border-outline-variant pt-unit-sm">
            <a class="flex items-center gap-unit-md px-unit-md py-3 text-on-surface-variant hover:bg-surface-container-low rounded-lg transition-colors @(ViewContext.RouteData.Values["controller"]?.ToString() == "Settings" ? "text-primary font-bold bg-primary-container/10" : "")"
               href="/Admin/Settings">
                <span class="material-symbols-outlined">settings</span>
                <span class="font-body-md text-body-md">Cấu hình hệ thống</span>
            </a>
            <a class="flex items-center gap-unit-md px-unit-md py-3 text-on-surface-variant hover:bg-surface-container-low rounded-lg transition-colors @(ViewContext.RouteData.Values["controller"]?.ToString() == "Logs" ? "text-primary font-bold bg-primary-container/10" : "")"
               href="/Admin/Logs">
                <span class="material-symbols-outlined">history</span>
                <span class="font-body-md text-body-md">Nhật ký hệ thống</span>
            </a>
            <a class="flex items-center gap-unit-md px-unit-md py-3 text-error hover:bg-error-container/20 rounded-lg transition-colors font-medium"
               href="/Auth/Logout">
                <span class="material-symbols-outlined text-error">logout</span>
                <span class="font-body-md text-body-md">Đăng xuất</span>
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 min-w-0 w-full h-screen overflow-y-auto flex flex-col">
        <!-- Top App Bar -->
        <header class="h-16 w-full sticky top-0 bg-surface/80 backdrop-blur-md border-b border-outline-variant flex items-center justify-between px-margin-mobile md:px-unit-lg gap-unit-sm md:gap-unit-md shrink-0 z-30">
            <div class="flex items-center gap-unit-lg flex-1">
                <button type="button" aria-label="Mở menu quản trị" onclick="openAdminSidebar()"
                        class="md:hidden w-10 h-10 flex items-center justify-center rounded-lg text-primary hover:bg-surface-container-high shrink-0">
                    <span class="material-symbols-outlined">menu</span>
                </button>
                @if (ViewData["ShowTopSearch"] as bool? == true)
                {
                    <div class="relative w-96 hidden md:block">
                        <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-outline">search</span>
                        <input class="w-full pl-10 pr-4 py-2 bg-surface-container rounded-lg border-none focus:ring-2 focus:ring-primary text-body-md"
                               placeholder="Tìm kiếm bệnh nhân, hồ sơ, mã hóa đơn..." type="text" />
                    </div>
                }
            </div>

            <div class="flex items-center gap-unit-md">
                <!-- Notification Bell -->
                <button class="w-10 h-10 flex items-center justify-center text-on-surface-variant hover:bg-surface-container-high rounded-full transition-all relative">
                    <span class="material-symbols-outlined">notifications</span>
                </button>
                <div class="h-8 w-px bg-outline-variant"></div>
                <!-- User Profile -->
                <div class="flex items-center gap-unit-sm hover:bg-surface-container-high p-1 pr-3 rounded-lg transition-all cursor-pointer">
                    <div class="w-8 h-8 rounded-full bg-primary-fixed flex items-center justify-center text-primary font-bold text-body-md">
                        @(User.Identity?.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "A")
                    </div>
                    <div class="hidden lg:block text-left">
                        <p class="font-label-md text-label-md text-on-surface leading-none">@User.Identity?.Name</p>
                        <p class="text-[10px] text-on-surface-variant uppercase font-bold tracking-wider">Super Admin</p>
                    </div>
                </div>
            </div>
        </header>

        <!-- Page Canvas -->
        <div class="p-margin-mobile md:p-unit-lg max-w-[1800px] mx-auto w-full flex-1 overflow-x-hidden">
            @RenderBody()
        </div>

        <!-- Footer -->
        <footer class="p-unit-lg text-center text-caption text-on-surface-variant border-t border-outline-variant shrink-0 mt-auto">
            © 2026 HMS MediFlow • Trạng thái hệ thống: <span class="text-secondary font-bold">Ổn định</span>
        </footer>
    </main>
</div>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        function openAdminSidebar() {
            document.getElementById('admin-sidebar')?.classList.add('mobile-sidebar-open');
            document.getElementById('admin-sidebar-backdrop')?.classList.remove('hidden');
            document.body.classList.add('overflow-hidden');
        }

        function closeAdminSidebar() {
            document.getElementById('admin-sidebar')?.classList.remove('mobile-sidebar-open');
            document.getElementById('admin-sidebar-backdrop')?.classList.add('hidden');
            document.body.classList.remove('overflow-hidden');
        }

        window.addEventListener('resize', () => {
            if (window.innerWidth >= 768) closeAdminSidebar();
        });
    </script>
}
@section Styles {
    @await RenderSectionAsync("Styles", required: false)
    <style>
        @@media (max-width: 767px) {
            #admin-sidebar.mobile-sidebar-open {
                transform: translateX(0) !important;
            }
        }
    </style>
}
