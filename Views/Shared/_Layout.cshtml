<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | HMS - Quản lý Bệnh viện</title>

    <!-- Tailwind CSS CDN & Plugins -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>

    <!-- Google Fonts & Material Symbols -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <!-- Tailwind Custom Theme Configuration -->
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "on-tertiary-fixed": "#2a1700",
                        "primary-fixed": "#d7e2ff",
                        "on-secondary-container": "#00714d",
                        "surface-container": "#e5eeff",
                        "on-primary": "#ffffff",
                        "secondary-fixed-dim": "#4edea3",
                        "surface-container-highest": "#d3e4fe",
                        "inverse-surface": "#213145",
                        "surface-dim": "#cbdbf5",
                        "primary-fixed-dim": "#acc7ff",
                        "on-tertiary-fixed-variant": "#653e00",
                        "primary-container": "#0056b3",
                        "error-container": "#ffdad6",
                        "on-surface-variant": "#424752",
                        "outline-variant": "#c2c6d4",
                        "secondary": "#006c49",
                        "surface-container-low": "#eff4ff",
                        "surface-container-high": "#dce9ff",
                        "on-secondary-fixed": "#002113",
                        "on-tertiary": "#ffffff",
                        "inverse-on-surface": "#eaf1ff",
                        "on-background": "#0b1c30",
                        "secondary-container": "#6cf8bb",
                        "surface-container-lowest": "#ffffff",
                        "surface-variant": "#d3e4fe",
                        "tertiary-fixed-dim": "#ffb95f",
                        "on-surface": "#0b1c30",
                        "on-error-container": "#93000a",
                        "secondary-fixed": "#6ffbbe",
                        "inverse-primary": "#acc7ff",
                        "tertiary": "#5e3900",
                        "on-tertiary-container": "#ffc57f",
                        "on-error": "#ffffff",
                        "on-primary-fixed-variant": "#004491",
                        "on-primary-fixed": "#001a40",
                        "surface": "#f8f9ff",
                        "on-secondary-fixed-variant": "#005236",
                        "primary": "#003f87",
                        "error": "#ba1a1a",
                        "outline": "#727784",
                        "tertiary-fixed": "#ffddb8",
                        "surface-tint": "#115cb9",
                        "on-primary-container": "#bbd0ff",
                        "surface-bright": "#f8f9ff",
                        "tertiary-container": "#7d4e00",
                        "background": "#f8f9ff",
                        "on-secondary": "#ffffff"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.125rem",
                        "lg": "0.25rem",
                        "xl": "0.5rem",
                        "full": "0.75rem"
                    },
                    "spacing": {
                        "unit-md": "16px",
                        "unit-lg": "24px",
                        "unit-sm": "8px",
                        "container-max": "1440px",
                        "unit-xl": "48px",
                        "unit-xs": "4px",
                        "margin-mobile": "16px",
                        "margin-desktop": "40px",
                        "gutter": "24px"
                    }
                }
            }
        }
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .glass-card {
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid #e2e8f0;
        }
        .input-focus:focus {
            border-color: #0056B3;
            box-shadow: 0 0 0 4px rgba(0, 86, 179, 0.1);
            outline: none;
        }
        .toast-animate {
            animation: toastSlideDown 0.25s ease-out forwards;
        }
        #toast-container {
            top: max(1rem, env(safe-area-inset-top));
        }
        @@keyframes toastSlideDown {
            from { transform: translateY(-12px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }
    </style>
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="bg-surface min-h-screen">
    <!-- Notifications Container (Toasts) -->
    <div class="fixed left-4 right-4 sm:left-auto sm:right-6 sm:w-full sm:max-w-sm z-[9999] flex flex-col gap-unit-sm pointer-events-none" id="toast-container" role="region" aria-live="polite" aria-atomic="true">
        <!-- Toast Notification Element -->
        <div class="hidden w-full pointer-events-auto toast-animate bg-white border-l-4 border-error p-unit-md shadow-2xl rounded-lg flex items-start gap-unit-sm" id="global-toast">
            <span class="material-symbols-outlined text-error" id="global-toast-icon">error</span>
            <div class="flex-grow">
                <p class="font-title-lg text-body-md text-on-surface font-semibold" id="global-toast-title">Thông báo</p>
                <p class="text-caption text-on-surface-variant" id="global-toast-message">Nội dung thông báo.</p>
            </div>
            <button class="text-outline hover:text-on-surface" onclick="hideGlobalToast()"><span class="material-symbols-outlined">close</span></button>
        </div>
    </div>

    @RenderBody()

    <!-- Toast Helper JS -->
    <script>
        function showGlobalToast(title, msg, type = 'error') {
            const toast = document.getElementById('global-toast');
            const toastTitle = document.getElementById('global-toast-title');
            const toastMsg = document.getElementById('global-toast-message');
            const toastIcon = document.getElementById('global-toast-icon');

            toastTitle.innerText = title;
            toastMsg.innerText = msg;

            toast.className = "w-full pointer-events-auto toast-animate bg-white border-l-4 p-unit-md shadow-2xl rounded-lg flex items-start gap-unit-sm";
            if (type === 'success') {
                toast.classList.add('border-secondary');
                toastIcon.innerText = 'check_circle';
                toastIcon.className = 'material-symbols-outlined text-secondary';
            } else if (type === 'warning') {
                toast.classList.add('border-tertiary');
                toastIcon.innerText = 'warning';
                toastIcon.className = 'material-symbols-outlined text-tertiary';
            } else {
                toast.classList.add('border-error');
                toastIcon.innerText = 'error';
                toastIcon.className = 'material-symbols-outlined text-error';
            }

            toast.classList.remove('hidden');

            setTimeout(() => {
                hideGlobalToast();
            }, 6000);
        }

        function hideGlobalToast() {
            const toast = document.getElementById('global-toast');
            if (toast) toast.classList.add('hidden');
        }

        // Show temp messages from TempData if present
        @if (TempData["SuccessMessage"] != null)
        {
            <text>
                window.addEventListener('DOMContentLoaded', () => {
                    showGlobalToast('Thành công', '@Html.Raw(TempData["SuccessMessage"])', 'success');
                });
            </text>
        }
        @if (TempData["ErrorMessage"] != null)
        {
            <text>
                window.addEventListener('DOMContentLoaded', () => {
                    showGlobalToast('Lỗi', '@Html.Raw(TempData["ErrorMessage"])', 'error');
                });
            </text>
        }
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
