@{
    Layout = "_Layout";
    var action = ViewContext.RouteData.Values["action"]?.ToString();
}

<div class="home-shell w-full max-w-full overflow-x-hidden bg-surface text-on-surface min-h-screen flex flex-col font-sans">
    <!-- Header Navigation -->
    <header class="sticky top-0 z-50 bg-white/88 backdrop-blur-md border-b border-outline-variant/60 shadow-[0_8px_30px_-24px_rgba(15,45,85,0.5)]">
        <div class="w-full min-w-0 max-w-[1440px] mx-auto px-3 sm:px-4 md:px-unit-lg min-h-20 flex items-center justify-between gap-2 sm:gap-3">
            <!-- Logo -->
            <a href="/" class="flex min-w-0 items-center gap-2 sm:gap-unit-md group">
                <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center shadow-sm group-hover:scale-105 transition-transform duration-300">
                    <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">medical_services</span>
                </div>
                <div class="min-w-0">
                    <h1 class="font-headline-md text-lg sm:text-headline-md font-bold text-primary leading-tight whitespace-nowrap">MediFlow HMS</h1>
                    <p class="hidden sm:block text-[10px] text-on-surface-variant uppercase tracking-wider font-semibold">Chăm sóc sức khỏe toàn diện</p>
                </div>
            </a>

            <!-- Mid Navigation Links -->
            <nav class="hidden lg:flex items-center gap-8 text-body-md font-medium text-on-surface-variant">
                <a href="/" class="@(action == "Index" ? "text-primary font-bold" : "hover:text-primary transition-colors")">Trang chủ</a>
                <a href="/Home/About" class="@(action == "About" ? "text-primary font-bold" : "hover:text-primary transition-colors")">Giới thiệu</a>
                <a href="/Home/Specialities" class="@(action == "Specialities" ? "text-primary font-bold" : "hover:text-primary transition-colors")">Chuyên khoa</a>
                <a href="/Home/News" class="@(action == "News" || action == "NewsDetail" ? "text-primary font-bold" : "hover:text-primary transition-colors")">Tin tức</a>
                <a href="/Home/Features" class="@(action == "Features" ? "text-primary font-bold" : "hover:text-primary transition-colors")">Tính năng</a>
                <a href="/Home/Testimonials" class="@(action == "Testimonials" ? "text-primary font-bold" : "hover:text-primary transition-colors")">Ý kiến khách hàng</a>
                <a href="/Home/Contact" class="@(action == "Contact" ? "text-primary font-bold" : "hover:text-primary transition-colors")">Liên hệ</a>
            </nav>

            <!-- Authentication Actions -->
            <div class="flex shrink-0 items-center gap-1.5 md:gap-unit-md">
                <button type="button" id="home-menu-button" aria-expanded="false" aria-controls="home-mobile-menu"
                    class="lg:hidden w-10 h-10 rounded-xl border border-outline-variant text-primary flex items-center justify-center hover:bg-primary/5 transition-colors"
                    onclick="toggleHomeMenu()">
                    <span class="material-symbols-outlined" id="home-menu-icon">menu</span>
                    <span class="sr-only">Mở danh mục trang chủ</span>
                </button>
                <a href="/Auth/Login" class="px-3 md:px-unit-lg py-2.5 rounded-xl border border-primary/30 text-primary hover:bg-primary/5 transition-all duration-300 font-semibold text-sm md:text-body-md active:scale-95 whitespace-nowrap">
                    Đăng nhập
                </a>
                <a href="/Auth/Register" class="hidden sm:inline-flex px-unit-lg py-2.5 rounded-xl bg-primary hover:bg-primary-container text-white shadow-md shadow-primary/10 transition-all duration-300 font-semibold text-body-md active:scale-95">
                    Đăng ký tài khoản bệnh nhân
                </a>
            </div>
        </div>
        <nav id="home-mobile-menu" class="hidden lg:hidden border-t border-outline-variant/60 bg-white px-4 py-4 shadow-lg">
            <div class="grid grid-cols-2 gap-2 text-sm font-semibold">
                <a href="/" class="rounded-xl px-3 py-3 @(action == "Index" ? "bg-primary/10 text-primary" : "text-on-surface hover:bg-surface-container")">Trang chủ</a>
                <a href="/Home/About" class="rounded-xl px-3 py-3 @(action == "About" ? "bg-primary/10 text-primary" : "text-on-surface hover:bg-surface-container")">Giới thiệu</a>
                <a href="/Home/Specialities" class="rounded-xl px-3 py-3 @(action == "Specialities" ? "bg-primary/10 text-primary" : "text-on-surface hover:bg-surface-container")">Chuyên khoa</a>
                <a href="/Home/News" class="rounded-xl px-3 py-3 @(action == "News" || action == "NewsDetail" ? "bg-primary/10 text-primary" : "text-on-surface hover:bg-surface-container")">Tin tức</a>
                <a href="/Home/Features" class="rounded-xl px-3 py-3 @(action == "Features" ? "bg-primary/10 text-primary" : "text-on-surface hover:bg-surface-container")">Tính năng</a>
                <a href="/Home/Testimonials" class="rounded-xl px-3 py-3 @(action == "Testimonials" ? "bg-primary/10 text-primary" : "text-on-surface hover:bg-surface-container")">Ý kiến khách hàng</a>
                <a href="/Home/Contact" class="rounded-xl px-3 py-3 @(action == "Contact" ? "bg-primary/10 text-primary" : "text-on-surface hover:bg-surface-container")">Liên hệ</a>
                <a href="/Auth/Register" class="col-span-2 sm:hidden rounded-xl px-3 py-3 bg-primary text-white text-center">Đăng ký tài khoản bệnh nhân</a>
            </div>
        </nav>
    </header>

    <!-- Main Content -->
    <main class="home-content w-full min-w-0 max-w-full flex-grow overflow-x-hidden">
        @RenderBody()
    </main>

    <!-- Footer Section -->
    <footer class="bg-inverse-surface text-inverse-on-surface pt-16 pb-8 border-t border-outline-variant/20 z-10">
        <div class="w-full min-w-0 max-w-[1440px] mx-auto px-4 md:px-unit-lg">
            <div class="grid grid-cols-1 md:grid-cols-4 gap-unit-xl pb-12 border-b border-outline/25">
                <!-- Col 1: About Hospital logo -->
                <div class="space-y-4">
                    <div class="flex items-center gap-unit-md">
                        <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center">
                            <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">medical_services</span>
                        </div>
                        <h4 class="font-bold text-title-lg text-white">MediFlow HMS</h4>
                    </div>
                    <p class="text-caption text-outline-variant leading-relaxed">
                        Hệ thống bệnh viện đa khoa số 1 về chăm sóc sức khỏe trực tuyến và quản trị thông minh tại Việt Nam.
                    </p>
                </div>

                <!-- Col 2: Services / Hours -->
                <div class="space-y-4">
                    <h5 class="font-bold text-body-lg text-white">Giờ làm việc</h5>
                    <ul class="text-caption text-outline-variant space-y-2">
                        <li>Thứ Hai - Chủ Nhật: 07:30 - 21:00</li>
                        <li>Cấp cứu khẩn cấp: 24/7</li>
                        <li>Phòng khám yêu cầu: 08:00 - 18:00</li>
                    </ul>
                </div>

                <!-- Col 3: Quick Navigation -->
                <div class="space-y-4">
                    <h5 class="font-bold text-body-lg text-white">Liên kết nhanh</h5>
                    <ul class="text-caption text-outline-variant space-y-2">
                        <li><a href="/" class="hover:text-white transition-colors">Trang chủ</a></li>
                        <li><a href="/Home/About" class="hover:text-white transition-colors">Giới thiệu</a></li>
                        <li><a href="/Home/Specialities" class="hover:text-white transition-colors">Danh mục khoa</a></li>
                        <li><a href="/Home/News" class="hover:text-white transition-colors">Tin tức &amp; thông báo</a></li>
                        <li><a href="/Home/Features" class="hover:text-white transition-colors">Quy trình y tế số</a></li>
                        <li><a href="/Auth/Login" class="hover:text-white transition-colors">Đăng nhập tài khoản</a></li>
                    </ul>
                </div>

                <!-- Col 4: Contact Detail -->
                <div class="space-y-4">
                    <h5 class="font-bold text-body-lg text-white">Thông tin liên hệ</h5>
                    <ul class="text-caption text-outline-variant space-y-2">
                        <li class="flex items-start gap-2">
                            <span class="material-symbols-outlined text-[16px] text-primary pt-0.5">location_on</span>
                            <span>Số 120 Đường Ba Tháng Hai, Quận 10, TP. Hồ Chí Minh</span>
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-[16px] text-primary">call</span>
                            <span>Hotline: 1900 6868 (Cấp cứu: 028.115)</span>
                        </li>
                        <li class="flex items-center gap-2">
                            <span class="material-symbols-outlined text-[16px] text-primary">mail</span>
                            <span>support@mediflow.vn</span>
                        </li>
                    </ul>
                </div>
            </div>

            <div class="pt-8 text-center text-caption text-outline-variant flex flex-col md:flex-row justify-between items-center gap-4">
                <p>© 2026 HMS MediFlow • Hệ thống quản lý thông tin bệnh viện.</p>
                <div class="flex gap-4">
                    <a href="#" class="hover:text-white transition-colors">Điều khoản sử dụng</a>
                    <span>•</span>
                    <a href="#" class="hover:text-white transition-colors">Chính sách bảo mật y tế</a>
                </div>
            </div>
        </div>
    </footer>
</div>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        function toggleHomeMenu() {
            const menu = document.getElementById('home-mobile-menu');
            const button = document.getElementById('home-menu-button');
            const icon = document.getElementById('home-menu-icon');
            const isOpening = menu.classList.contains('hidden');
            menu.classList.toggle('hidden');
            button.setAttribute('aria-expanded', isOpening ? 'true' : 'false');
            icon.textContent = isOpening ? 'close' : 'menu';
        }
    </script>
}
@section Styles {
    @await RenderSectionAsync("Styles", required: false)
}
