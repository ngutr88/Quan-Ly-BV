@{
    Layout = "_Layout";
}

<div class="min-h-screen flex flex-col bg-surface">
    <!-- Responsive Header Navigation -->
    <header class="sticky top-0 bg-white/95 backdrop-blur-md border-b border-outline-variant z-40">
        <div class="max-w-[1280px] mx-auto px-margin-mobile md:px-unit-lg h-16 flex items-center justify-between">
            <!-- Brand Logo -->
            <a href="/Patient/Dashboard" class="flex items-center gap-unit-sm">
                <div class="w-9 h-9 bg-primary rounded-lg flex items-center justify-center text-white">
                    <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">local_hospital</span>
                </div>
                <span class="font-title-lg font-bold text-primary">MediFlow Patient</span>
            </a>

            <!-- Desktop Menu -->
            <nav class="hidden md:flex items-center gap-unit-md">
                <a class="px-unit-sm py-2 font-body-md rounded hover:bg-surface-container-low transition-colors @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "text-primary font-bold" : "text-on-surface-variant")"
                   href="/Patient/Dashboard">Trang chủ</a>
                <a class="px-unit-sm py-2 font-body-md rounded hover:bg-surface-container-low transition-colors @(ViewContext.RouteData.Values["controller"]?.ToString() == "Book" ? "text-primary font-bold" : "text-on-surface-variant")"
                   href="/Patient/Book">Đặt lịch khám</a>
                <a class="px-unit-sm py-2 font-body-md rounded hover:bg-surface-container-low transition-colors @(ViewContext.RouteData.Values["controller"]?.ToString() == "Record" ? "text-primary font-bold" : "text-on-surface-variant")"
                   href="/Patient/Record">Đơn thuốc &amp; Bệnh án</a>
                <a class="px-unit-sm py-2 font-body-md rounded hover:bg-surface-container-low transition-colors @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payment" ? "text-primary font-bold" : "text-on-surface-variant")"
                   href="/Patient/Payment">Thanh toán hóa đơn</a>
            </nav>

            <!-- User Actions -->
            <div class="flex items-center gap-unit-sm">
                <div class="relative group">
                    <button class="flex items-center gap-unit-sm hover:bg-surface-container-high p-1 px-2 rounded-lg cursor-pointer transition-all">
                        <div class="w-8 h-8 rounded-full bg-primary-fixed flex items-center justify-center text-primary font-bold text-body-md">
                            BN
                        </div>
                        <span class="hidden md:inline font-label-md text-label-md text-on-surface">@User.Identity?.Name</span>
                        <span class="material-symbols-outlined text-[16px] text-outline">arrow_drop_down</span>
                    </button>
                    <!-- Dropdown Menu -->
                    <div class="absolute right-0 top-full mt-1 w-48 bg-white border border-outline-variant rounded-lg shadow-xl hidden group-hover:block z-50">
                        <a href="/Patient/Record/Health" class="block px-4 py-2 text-body-md text-on-surface hover:bg-surface-container-low transition-colors">Sổ sức khỏe</a>
                        <a href="/Patient/Record/Dependents" class="block px-4 py-2 text-body-md text-on-surface hover:bg-surface-container-low transition-colors">Hồ sơ người thân</a>
                        <div class="border-t border-outline-variant my-1"></div>
                        <a href="/Auth/Logout" class="block px-4 py-2 text-body-md text-error hover:bg-error-container/20 transition-colors font-medium">Đăng xuất</a>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Mobile Nav Bar (bottom) -->
    <nav class="md:hidden fixed bottom-0 left-0 w-full bg-white border-t border-outline-variant h-14 flex items-center justify-around z-40 shadow-lg">
        <a href="/Patient/Dashboard" class="flex flex-col items-center text-on-surface-variant hover:text-primary">
            <span class="material-symbols-outlined text-[22px]">home</span>
            <span class="text-[10px]">Trang chủ</span>
        </a>
        <a href="/Patient/Book" class="flex flex-col items-center text-on-surface-variant hover:text-primary">
            <span class="material-symbols-outlined text-[22px]">add_box</span>
            <span class="text-[10px]">Đặt lịch</span>
        </a>
        <a href="/Patient/Record" class="flex flex-col items-center text-on-surface-variant hover:text-primary">
            <span class="material-symbols-outlined text-[22px]">medical_information</span>
            <span class="text-[10px]">Đơn thuốc</span>
        </a>
        <a href="/Patient/Payment" class="flex flex-col items-center text-on-surface-variant hover:text-primary">
            <span class="material-symbols-outlined text-[22px]">receipt_long</span>
            <span class="text-[10px]">Hóa đơn</span>
        </a>
    </nav>

    <!-- Main Content Area -->
    <main class="flex-grow max-w-[1280px] w-full mx-auto p-margin-mobile md:p-unit-lg pb-24 md:pb-8 flex flex-col">
        @RenderBody()
    </main>

    <!-- Footer -->
    <footer class="bg-surface-container-low border-t border-outline-variant py-unit-lg mt-auto text-center text-caption text-on-surface-variant hidden md:block">
        <div class="max-w-[1280px] mx-auto px-unit-lg flex justify-between items-center">
            <span>© 2026 Hệ thống HMS MediFlow • An toàn &amp; Bảo mật Y tế</span>
            <div class="flex gap-unit-md">
                <a href="#" class="hover:underline">Điều khoản sử dụng</a>
                <a href="#" class="hover:underline">Chính sách bảo mật</a>
            </div>
        </div>
    </footer>
</div>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}
@section Styles {
    @await RenderSectionAsync("Styles", required: false)
}
