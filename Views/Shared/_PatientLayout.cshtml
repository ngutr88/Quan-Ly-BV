@inject QuanLyBenhVien.Data.ApplicationDbContext _dbContext
@{
    Layout = "_Layout";
    var currentPatientUserClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier);
    var currentPatientUserId = currentPatientUserClaim != null ? int.Parse(currentPatientUserClaim.Value) : 3;
    var unreadNotificationCount = _dbContext.Notifications.Count(n => n.NguoiDungId == currentPatientUserId && !n.DaDoc);
}

<div class="patient-shell text-on-surface overflow-hidden flex h-screen w-full max-w-full">
    <!-- Side Navigation Bar (Desktop Only) -->
    <aside class="patient-sidebar hidden md:flex flex-col w-[280px] h-screen bg-surface-container-lowest border-r border-outline-variant py-unit-lg shrink-0 z-50">
        <!-- Logo -->
        <div class="px-unit-lg mb-unit-xl">
            <a href="/Patient/Dashboard" class="flex items-center gap-unit-md group">
                <div class="w-10 h-10 bg-primary rounded-xl flex items-center justify-center text-white shadow-sm group-hover:scale-105 transition-transform">
                    <span class="material-symbols-outlined text-white" style="font-variation-settings: 'FILL' 1;">medical_services</span>
                </div>
                <div>
                    <h1 class="font-headline-md text-headline-md font-bold text-primary leading-tight">MediFlow HMS</h1>
                    <p class="text-caption text-on-surface-variant font-semibold">Cổng Bệnh nhân</p>
                </div>
            </a>
        </div>

        <!-- Sidebar Navigation Menu -->
        <nav class="flex-1 px-unit-sm space-y-1 overflow-y-auto custom-scrollbar">
            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-all cursor-pointer active:scale-95 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Patient/Dashboard">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">dashboard</span>
                <span class="font-body-md text-body-md">Trang chủ</span>
            </a>

            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-all cursor-pointer active:scale-95 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Book" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Patient/Book">
                <span class="material-symbols-outlined">add_box</span>
                <span class="font-body-md text-body-md">Đặt lịch khám</span>
            </a>

            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-all cursor-pointer active:scale-95 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Record" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Patient/Record">
                <span class="material-symbols-outlined">medical_information</span>
                <span class="font-body-md text-body-md">Đơn thuốc &amp; Bệnh án</span>
            </a>

            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-colors active:scale-95 @(ViewContext.RouteData.Values["action"]?.ToString() == "Health" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Patient/Record/Health">
                <span class="material-symbols-outlined">favorite</span>
                <span class="font-body-md text-body-md">Sổ sức khỏe</span>
            </a>

            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-colors active:scale-95 @(ViewContext.RouteData.Values["action"]?.ToString() == "Dependents" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Patient/Record/Dependents">
                <span class="material-symbols-outlined">group</span>
                <span class="font-body-md text-body-md">Hồ sơ người thân</span>
            </a>

            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-all cursor-pointer active:scale-95 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payment" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Patient/Payment">
                <span class="material-symbols-outlined">receipt_long</span>
                <span class="font-body-md text-body-md">Thanh toán hóa đơn</span>
            </a>

            <a class="flex items-center gap-unit-md px-unit-md py-3 rounded-lg transition-all cursor-pointer active:scale-95 @(ViewContext.RouteData.Values["controller"]?.ToString() == "Notification" ? "text-primary font-bold bg-primary-container/10" : "text-on-surface-variant hover:bg-surface-container-low")"
               href="/Patient/Notification">
                <span class="material-symbols-outlined">notifications</span>
                <span class="font-body-md text-body-md">Thông báo cá nhân</span>
            </a>
        </nav>

        <!-- Bottom Actions -->
        <div class="px-unit-sm mt-auto space-y-1 border-t border-outline-variant pt-unit-sm">
            <a class="flex items-center gap-unit-md px-unit-md py-3 text-error hover:bg-error-container/20 rounded-lg transition-colors font-medium"
               href="/Auth/Logout">
                <span class="material-symbols-outlined text-error">logout</span>
                <span class="font-body-md text-body-md">Đăng xuất</span>
            </a>
        </div>
    </aside>

    <!-- Main Content Area -->
    <main class="flex-1 min-w-0 max-w-full h-screen overflow-x-hidden overflow-y-auto flex flex-col">
        <!-- Top App Bar -->
        <header class="patient-topbar h-16 w-full max-w-full sticky top-0 bg-surface/80 backdrop-blur-md border-b border-outline-variant flex items-center justify-between px-3 md:px-unit-lg gap-1 sm:gap-unit-md shrink-0 z-40">
            <!-- Brand Logo (Mobile Only) -->
            <a href="/Patient/Dashboard" class="flex items-center gap-unit-sm group md:hidden">
                <div class="w-9 h-9 bg-primary rounded-xl flex items-center justify-center text-white shadow-sm group-hover:scale-105 transition-transform">
                    <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">medical_services</span>
                </div>
                <div class="flex flex-col">
                    <span class="font-title-lg font-bold text-primary leading-tight">MediFlow</span>
                </div>
            </a>

            <!-- Desktop Welcome Message -->
            <div class="hidden md:flex items-center gap-unit-sm text-on-surface-variant font-medium">
                <span class="material-symbols-outlined text-[18px] text-primary">waving_hand</span>
                <span class="text-body-md">Xin chào, <strong class="text-on-surface">@User.Identity?.Name</strong></span>
            </div>

            <!-- Topbar User Actions (Notifications and Quick Profile) -->
            <div class="flex items-center gap-1 sm:gap-unit-sm shrink-0">
                <!-- Notification Bell -->
                <a href="/Patient/Notification" class="relative flex items-center justify-center p-2 rounded-full hover:bg-surface-container transition-colors text-primary" title="Thông báo">
                    <span class="material-symbols-outlined text-[24px]">notifications</span>
                    @if (unreadNotificationCount > 0)
                    {
                        <span id="header-unread-badge" class="absolute top-1.5 right-1.5 w-4 h-4 bg-error text-white font-semibold text-[10px] rounded-full flex items-center justify-center">
                            @unreadNotificationCount
                        </span>
                    }
                </a>

                <div class="h-8 w-px bg-outline-variant"></div>

                <!-- Static User Profile (dropdown removed as it is redundant) -->
                <div class="flex items-center gap-unit-sm p-1 px-2 rounded-lg">
                    <div class="w-8 h-8 rounded-full bg-primary-fixed flex items-center justify-center text-primary font-bold text-body-md">
                        @(User.Identity?.Name?.Length > 0 ? User.Identity.Name[0].ToString().ToUpper() : "B")
                    </div>
                    <span class="hidden sm:inline font-label-md text-label-md text-on-surface">@User.Identity?.Name</span>
                </div>

                <!-- Mobile logout is kept in the top bar because the desktop sidebar is hidden. -->
                <a href="/Auth/Logout"
                   class="md:hidden flex items-center justify-center p-2 rounded-full text-error hover:bg-error-container/20 transition-colors"
                   aria-label="Đăng xuất" title="Đăng xuất">
                    <span class="material-symbols-outlined text-[24px] text-error">logout</span>
                </a>
            </div>
        </header>

        <!-- Main Dynamic Content -->
        <div class="patient-content w-full min-w-0 max-w-full flex-grow overflow-x-hidden p-margin-mobile md:p-unit-lg pb-24 md:pb-8 flex flex-col">
            @RenderBody()
        </div>

        <!-- Desktop Footer -->
        <footer class="bg-surface-container-low border-t border-outline-variant py-unit-md mt-auto text-center text-caption text-on-surface-variant hidden md:block">
            <div class="max-w-[1280px] mx-auto px-unit-lg flex justify-between items-center">
                <span>© 2026 HMS MediFlow • An toàn &amp; Bảo mật Y tế</span>
                <div class="flex gap-unit-md">
                    <a href="#" class="hover:underline">Điều khoản sử dụng</a>
                    <a href="#" class="hover:underline">Chính sách bảo mật</a>
                </div>
            </div>
        </footer>
    </main>

    <!-- Mobile Navigation Tab Bar (Bottom) -->
    <nav class="md:hidden fixed bottom-0 left-0 w-full bg-surface-container-lowest border-t border-outline-variant h-14 flex items-center justify-around z-40 shadow-lg">
        <a href="/Patient/Dashboard" class="flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "text-primary" : "text-on-surface-variant hover:text-primary")">
            <span class="material-symbols-outlined text-[22px]" style="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "font-variation-settings: 'FILL' 1;" : "")">home</span>
            <span class="text-[10px] font-semibold">Trang chủ</span>
        </a>
        <a href="/Patient/Book" class="flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors @(ViewContext.RouteData.Values["controller"]?.ToString() == "Book" ? "text-primary" : "text-on-surface-variant hover:text-primary")">
            <span class="material-symbols-outlined text-[22px]" style="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Book" ? "font-variation-settings: 'FILL' 1;" : "")">add_box</span>
            <span class="text-[10px] font-semibold">Đặt lịch</span>
        </a>
        <a href="/Patient/Record" class="flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors @(ViewContext.RouteData.Values["controller"]?.ToString() == "Record" ? "text-primary" : "text-on-surface-variant hover:text-primary")">
            <span class="material-symbols-outlined text-[22px]" style="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Record" ? "font-variation-settings: 'FILL' 1;" : "")">medical_information</span>
            <span class="text-[10px] font-semibold">Đơn thuốc</span>
        </a>
        <a href="/Patient/Payment" class="flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payment" ? "text-primary" : "text-on-surface-variant hover:text-primary")">
            <span class="material-symbols-outlined text-[22px]" style="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Payment" ? "font-variation-settings: 'FILL' 1;" : "")">receipt_long</span>
            <span class="text-[10px] font-semibold">Hóa đơn</span>
        </a>
        <a href="/Patient/Notification" class="relative flex flex-col items-center gap-0.5 px-3 py-1 rounded-lg transition-colors @(ViewContext.RouteData.Values["controller"]?.ToString() == "Notification" ? "text-primary" : "text-on-surface-variant hover:text-primary")">
            <span class="material-symbols-outlined text-[22px]" style="@(ViewContext.RouteData.Values["controller"]?.ToString() == "Notification" ? "font-variation-settings: 'FILL' 1;" : "")">notifications</span>
            @if (unreadNotificationCount > 0)
            {
                <span class="absolute top-0 right-2 w-3.5 h-3.5 bg-error text-white font-semibold text-[9px] rounded-full flex items-center justify-center">
                    @unreadNotificationCount
                </span>
            }
            <span class="text-[10px] font-semibold">Thông báo</span>
        </a>
    </nav>
</div>

@section Scripts {
    @await RenderSectionAsync("Scripts", required: false)
}
@section Styles {
    @await RenderSectionAsync("Styles", required: false)
}
