@model IEnumerable<QuanLyBenhVien.Models.ExaminationRecord>

@{
    Layout = "~/Views/Shared/_DoctorLayout.cshtml";
    ViewData["Title"] = "Lịch sử điều trị";
    var searchString = ViewBag.SearchString as string;
    var records = Model.ToList();

    var header = new PageHeaderViewModel
    {
        Title = "Lịch sử điều trị đã khám",
        Subtitle = "Tra cứu và xem lại các hồ sơ bệnh án, đơn thuốc và hóa đơn bạn đã hoàn thành.",
        Breadcrumbs = new[] { new BreadcrumbItem("Bác sĩ", "/Doctor/Dashboard") },
        CurrentCrumb = "Lịch sử điều trị"
    };
}

<partial name="_PageHeader" model="header" />

<!-- Filters -->
<div class="hms-toolbar">
    <form method="GET" action="/Doctor/History" class="hms-toolbar-grid">
        <div style="grid-column: span 2 / span 2;">
            <label class="hms-field-label" for="history-search">Tìm kiếm bệnh nhân</label>
            <div class="hms-search">
                <span class="material-symbols-outlined">search</span>
                <input id="history-search" name="searchString" value="@searchString" type="text"
                       class="w-full py-2 pr-4 border border-outline-variant rounded-lg font-body-md"
                       placeholder="Tên bệnh nhân, số điện thoại..." />
            </div>
        </div>
        <div class="flex gap-2">
            <button type="submit" class="hms-btn hms-btn-primary">
                <span class="material-symbols-outlined">search</span> Tìm kiếm
            </button>
            @if (!string.IsNullOrEmpty(searchString))
            {
                <a href="/Doctor/History" class="hms-btn hms-btn-secondary">
                    <span class="material-symbols-outlined">refresh</span> Xóa lọc
                </a>
            }
        </div>
    </form>
</div>

<!-- Records Table -->
<div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-surface-container-low text-on-surface-variant font-label-md text-[12px] uppercase">
                    <th class="px-unit-md py-3">Ngày khám</th>
                    <th class="px-unit-md py-3">Mã ca khám</th>
                    <th class="px-unit-md py-3">Bệnh nhân</th>
                    <th class="px-unit-md py-3">Chẩn đoán</th>
                    <th class="px-unit-md py-3 text-right">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @if (records.Count == 0)
                {
                    <tr>
                        <td colspan="5">
                            <div class="hms-empty">
                                <div class="hms-empty-icon"><span class="material-symbols-outlined">history</span></div>
                                <p class="hms-empty-title">Chưa có ca khám nào</p>
                                <p class="hms-empty-text">Không tìm thấy ca khám khớp với từ khóa. Các ca bạn hoàn thành sẽ được lưu tại đây.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var rec in records)
                    {
                        <tr class="hover:bg-surface-container-low transition-colors group">
                            <td class="px-unit-md py-4">
                                <div class="font-body-md font-semibold text-on-surface">@rec.NgayKham.ToString("dd/MM/yyyy")</div>
                                <div class="text-caption text-on-surface-variant">@rec.NgayKham.ToString("HH:mm")</div>
                            </td>
                            <td class="px-unit-md py-4 font-mono font-bold text-primary">
                                EXM-@rec.Id.ToString("D4")
                            </td>
                            <td class="px-unit-md py-4">
                                <div class="font-body-md font-semibold text-on-surface">@rec.Appointment.Patient.User.HoTen</div>
                                <div class="text-caption text-on-surface-variant">SĐT: @rec.Appointment.Patient.User.Sdt</div>
                            </td>
                            <td class="px-unit-md py-4 font-body-md max-w-[300px] truncate" title="@rec.ChanDoan">
                                @rec.ChanDoan
                            </td>
                            <td class="px-unit-md py-4 text-right">
                                <a href="/Doctor/History/RecordDetails/@rec.LichKhamId" class="inline-flex items-center gap-0.5 bg-primary text-white px-3 py-1.5 rounded-lg text-label-md hover:bg-primary-container transition-all active:scale-95 font-semibold cursor-pointer shadow-sm">
                                    <span class="material-symbols-outlined text-[16px]">visibility</span> Xem chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
