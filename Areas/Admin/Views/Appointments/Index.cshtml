@model QuanLyBenhVien.Helpers.PagedList<QuanLyBenhVien.Models.Appointment>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Lịch khám";

    var appointments = Model.Items;
    var pendingCount = (int)(ViewBag.PendingCount ?? 0);
    var confirmedCount = (int)(ViewBag.ConfirmedCount ?? 0);
    var inProgressCount = (int)(ViewBag.InProgressCount ?? 0);
    var doneCount = (int)(ViewBag.DoneCount ?? 0);

    var filters = new Dictionary<string, string>
    {
        ["filterDate"] = ViewBag.FilterDate as string,
        ["statusFilter"] = ViewBag.StatusFilter as string
    };
    var exportQuery = string.Join("&", filters
        .Where(kv => !string.IsNullOrEmpty(kv.Value))
        .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value)}"));

    Func<object, IHtmlContent> pageActions = @<text>
        <a href="/Admin/Appointments/Export@(string.IsNullOrEmpty(exportQuery) ? "" : "?" + exportQuery)" class="hms-btn hms-btn-secondary">
            <span class="material-symbols-outlined">download</span> Xuất Excel
        </a>
    </text>;

    ViewData["PageActions"] = pageActions;

    var header = new PageHeaderViewModel
    {
        Title = "Điều phối lịch khám",
        Subtitle = "Phê duyệt lịch khám trực tuyến, sắp xếp ca khám và kiểm tra xung đột lịch trình của bác sĩ.",
        Breadcrumbs = new[] { new BreadcrumbItem("Quản trị", "/Admin/Dashboard") },
        CurrentCrumb = "Lịch khám"
    };
}

<partial name="_PageHeader" model="header" />

<div class="hms-stat-grid">
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-warn"><span class="material-symbols-outlined">pending_actions</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Chờ xác nhận</p>
            <p class="hms-stat-value">@pendingCount</p>
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-primary"><span class="material-symbols-outlined">event_available</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Đã xác nhận</p>
            <p class="hms-stat-value">@confirmedCount</p>
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-primary"><span class="material-symbols-outlined">clinical_notes</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Đang khám</p>
            <p class="hms-stat-value">@inProgressCount</p>
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-success"><span class="material-symbols-outlined">task_alt</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Hoàn thành</p>
            <p class="hms-stat-value">@doneCount</p>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="hms-toolbar">
    <form method="GET" action="/Admin/Appointments" class="hms-toolbar-grid">
        <div>
            <label class="hms-field-label" for="filterDate">Ngày khám</label>
            <input class="w-full py-2 px-3 border border-outline-variant rounded-lg font-body-md"
                   id="filterDate" name="filterDate" value="@ViewBag.FilterDate" type="date" />
        </div>
        <div>
            <label class="hms-field-label" for="statusFilter">Trạng thái lịch</label>
            <select class="w-full py-2 px-3 border border-outline-variant rounded-lg font-body-md"
                    id="statusFilter" name="statusFilter">
                <option value="">Tất cả trạng thái</option>
                <option value="ChoXacNhan" selected="@(ViewBag.StatusFilter == "ChoXacNhan")">Chờ xác nhận</option>
                <option value="DaXacNhan" selected="@(ViewBag.StatusFilter == "DaXacNhan")">Đã xác nhận</option>
                <option value="DangKham" selected="@(ViewBag.StatusFilter == "DangKham")">Đang khám</option>
                <option value="HoanThanh" selected="@(ViewBag.StatusFilter == "HoanThanh")">Hoàn thành</option>
                <option value="DaHuy" selected="@(ViewBag.StatusFilter == "DaHuy")">Đã hủy</option>
            </select>
        </div>
        <div class="flex gap-2">
            <button type="submit" class="hms-btn hms-btn-primary">
                <span class="material-symbols-outlined">filter_list</span> Lọc kết quả
            </button>
            <a href="/Admin/Appointments" class="hms-btn hms-btn-secondary">
                <span class="material-symbols-outlined">refresh</span> Đặt lại
            </a>
        </div>
    </form>
</div>

<!-- Appointments Table -->
<div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-surface-container-low text-on-surface-variant font-label-md text-[12px] uppercase">
                    <th class="px-unit-md py-3">Mã lịch</th>
                    <th class="px-unit-md py-3">Bệnh nhân</th>
                    <th class="px-unit-md py-3">Bác sĩ phụ trách</th>
                    <th class="px-unit-md py-3">Thời gian khám</th>
                    <th class="px-unit-md py-3">Trạng thái</th>
                    <th class="px-unit-md py-3 text-right">Chi tiết</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant text-body-md">
                @if (appointments.Count == 0)
                {
                    <tr>
                        <td colspan="6">
                            <div class="hms-empty">
                                <div class="hms-empty-icon"><span class="material-symbols-outlined">event_busy</span></div>
                                <p class="hms-empty-title">Không có lịch khám nào</p>
                                <p class="hms-empty-text">Không tìm thấy lịch khám khớp với ngày và trạng thái đang chọn. Hãy đặt lại bộ lọc để xem toàn bộ.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var app in appointments)
                    {
                        <tr class="hover:bg-surface-container-low transition-colors">
                            <td class="px-unit-md py-4 font-mono font-bold text-primary">#LK-@app.Id.ToString("D4")</td>
                            <td class="px-unit-md py-4">
                                <div class="font-semibold text-on-surface">@app.Patient.User.HoTen</div>
                                <div class="text-caption text-on-surface-variant">SĐT: @app.Patient.User.Sdt</div>
                            </td>
                            <td class="px-unit-md py-4">
                                @if (app.Doctor != null)
                                {
                                    <div class="font-medium text-on-surface">@app.Doctor.User.HoTen</div>
                                    <div class="text-caption text-primary">@app.Doctor.Department.TenKhoa</div>
                                }
                                else
                                {
                                    <span class="text-on-surface-variant italic">Chưa phân công</span>
                                }
                            </td>
                            <td class="px-unit-md py-4">
                                <div class="font-semibold text-on-surface">@app.ThoiGian.ToString("dd/MM/yyyy")</div>
                                <div class="text-caption text-primary">@app.ThoiGian.ToString("HH:mm") - @app.ThoiGian.AddMinutes(30).ToString("HH:mm")</div>
                            </td>
                            <td class="px-unit-md py-4">
                                @if (app.TrangThai == "ChoXacNhan")
                                {
                                    <span class="hms-badge hms-badge-warn"><span class="material-symbols-outlined">schedule</span> Chờ duyệt</span>
                                }
                                else if (app.TrangThai == "DaXacNhan")
                                {
                                    <span class="hms-badge hms-badge-info"><span class="material-symbols-outlined">event_available</span> Đã hẹn</span>
                                }
                                else if (app.TrangThai == "DangKham")
                                {
                                    <span class="hms-badge hms-badge-info"><span class="material-symbols-outlined">clinical_notes</span> Đang khám</span>
                                }
                                else if (app.TrangThai == "HoanThanh")
                                {
                                    <span class="hms-badge hms-badge-ok"><span class="material-symbols-outlined">task_alt</span> Đã xong</span>
                                }
                                else
                                {
                                    <span class="hms-badge hms-badge-danger"><span class="material-symbols-outlined">cancel</span> Đã hủy</span>
                                }
                            </td>
                            <td class="px-unit-md py-4 text-right">
                                <a href="/Admin/Appointments/Details/@app.Id" class="hms-btn hms-btn-secondary hms-btn-sm">
                                    Chi tiết <span class="material-symbols-outlined">chevron_right</span>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (appointments.Count > 0)
    {
        <partial name="_Pagination" model='PaginationViewModel.From(Model, "/Admin/Appointments", "lịch khám", filters)' />
    }
</div>
