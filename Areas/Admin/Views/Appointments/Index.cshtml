@model IEnumerable<QuanLyBenhVien.Models.Appointment>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Lịch khám";
}

<div class="mb-unit-lg">
    <h2 class="font-headline-lg text-headline-lg text-on-surface">Điều phối Lịch khám</h2>
    <p class="text-body-md text-on-surface-variant">Phê duyệt lịch khám trực tuyến, sắp xếp ca khám và kiểm tra xung đột lịch trình của bác sĩ.</p>
</div>

<!-- Filters Bar -->
<div class="bg-surface-container-lowest border border-outline-variant p-unit-md rounded-xl mb-unit-lg shadow-sm">
    <form method="GET" action="/Admin/Appointments" class="flex flex-col md:flex-row gap-unit-md items-end">
        <div class="w-full md:w-64">
            <label class="block text-caption font-semibold text-on-surface-variant mb-1" for="filterDate">Lọc theo ngày khám</label>
            <input class="w-full px-4 py-2 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                   id="filterDate" name="filterDate" value="@ViewBag.FilterDate" type="date" />
        </div>
        
        <div class="w-full md:w-64">
            <label class="block text-caption font-semibold text-on-surface-variant mb-1" for="statusFilter">Trạng thái lịch</label>
            <select class="w-full px-4 py-2 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                    id="statusFilter" name="statusFilter">
                <option value="">Tất cả trạng thái</option>
                <option value="ChoXacNhan" selected="@(ViewBag.StatusFilter == "ChoXacNhan")">Chờ xác nhận</option>
                <option value="DaXacNhan" selected="@(ViewBag.StatusFilter == "DaXacNhan")">Đã xác nhận</option>
                <option value="DangKham" selected="@(ViewBag.StatusFilter == "DangKham")">Đang khám</option>
                <option value="HoanThanh" selected="@(ViewBag.StatusFilter == "HoanThanh")">Hoàn thành</option>
                <option value="DaHuy" selected="@(ViewBag.StatusFilter == "DaHuy")">Đã hủy</option>
            </select>
        </div>

        <button type="submit" class="bg-primary hover:bg-primary-container text-white px-unit-lg py-2.5 rounded-lg font-label-md transition-colors font-semibold shadow-sm w-full md:w-auto">
            Lọc kết quả
        </button>
    </form>
</div>

<!-- Appointments Table -->
<div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-surface-container-low text-on-surface-variant font-label-md text-[12px] uppercase">
                    <th class="px-unit-md py-3">Mã lịch</th>
                    <th class="px-unit-md py-3">Bệnh nhân</th>
                    <th class="px-unit-md py-3">Bác sĩ phụ trách</th>
                    <th class="px-unit-md py-3">Thời gian khám</th>
                    <th class="px-unit-md py-3">Trạng thái</th>
                    <th class="px-unit-md py-3 text-right">Chi tiết</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant text-body-md">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="px-unit-md py-8 text-center text-on-surface-variant">Không tìm thấy lịch khám nào.</td>
                    </tr>
                }
                else
                {
                    @foreach (var app in Model)
                    {
                        <tr class="hover:bg-surface-container-low transition-colors">
                            <td class="px-unit-md py-4 font-mono font-bold text-primary">#LK-@app.Id.ToString("D4")</td>
                            <td class="px-unit-md py-4">
                                <div class="font-semibold text-on-surface">@app.Patient.User.HoTen</div>
                                <div class="text-caption text-on-surface-variant">SĐT: @app.Patient.User.Sdt</div>
                            </td>
                            <td class="px-unit-md py-4">
                                @if (app.Doctor != null)
                                {
                                    <div class="font-medium text-on-surface">@app.Doctor.User.HoTen</div>
                                    <div class="text-caption text-secondary">@app.Doctor.Department.TenKhoa</div>
                                }
                                else
                                {
                                    <span class="text-on-surface-variant italic">Chưa phân công</span>
                                }
                            </td>
                            <td class="px-unit-md py-4">
                                <div class="font-semibold text-on-surface">@app.ThoiGian.ToString("dd/MM/yyyy")</div>
                                <div class="text-caption text-primary">@app.ThoiGian.ToString("HH:mm") - @app.ThoiGian.AddMinutes(30).ToString("HH:mm")</div>
                            </td>
                            <td class="px-unit-md py-4">
                                @if (app.TrangThai == "ChoXacNhan")
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-primary-container/20 text-primary-fixed-dim text-[11px] font-bold">Chờ duyệt</span>
                                }
                                else if (app.TrangThai == "DaXacNhan")
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-tertiary-fixed/30 text-on-tertiary-fixed-variant text-[11px] font-bold">Đã hẹn</span>
                                }
                                else if (app.TrangThai == "DangKham")
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-secondary-container/20 text-on-secondary-container text-[11px] font-bold">Đang khám</span>
                                }
                                else if (app.TrangThai == "HoanThanh")
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-secondary/15 text-secondary text-[11px] font-bold">Đã xong</span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-error-container text-error text-[11px] font-bold">Đã hủy</span>
                                }
                            </td>
                            <td class="px-unit-md py-4 text-right">
                                <a href="/Admin/Appointments/Details/@app.Id" class="inline-flex items-center gap-0.5 bg-surface-container hover:bg-surface-container-high px-3 py-1.5 rounded-lg text-label-md transition-colors text-primary font-semibold border border-outline-variant/30">
                                    Chi tiết <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
