@model QuanLyBenhVien.Models.Appointment

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết Lịch khám";
}

<div class="mb-6">
    <a href="/Admin/Appointments" class="inline-flex items-center gap-1 text-primary hover:underline text-body-md font-semibold mb-2">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span> Quay lại danh sách điều phối
    </a>
    <h2 class="font-headline-lg text-headline-lg text-on-surface font-bold">Chi tiết Lịch khám #LK-@Model.Id.ToString("D4")</h2>
    <p class="text-body-md text-on-surface-variant">Phê duyệt hoặc điều chỉnh trạng thái cho ca khám của bệnh nhân.</p>
</div>

<!-- Page Header Section -->
<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 bg-surface-container-lowest p-6 rounded-xl border border-outline-variant shadow-sm mb-6">
    <div class="flex items-center gap-4">
        <div class="p-3 bg-primary-fixed rounded-lg text-primary">
            <span class="material-symbols-outlined text-3xl">assignment</span>
        </div>
        <div>
            <div class="flex items-center gap-3 mb-1">
                <h2 class="font-headline-md text-headline-md text-on-surface font-bold">#LK-@Model.Id.ToString("D4")</h2>
                @if (Model.TrangThai == "ChoXacNhan")
                {
                    <span class="px-3 py-1 bg-primary-container/20 text-primary-fixed-dim rounded-full text-label-md font-bold flex items-center gap-1">
                        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">pending</span> Chờ duyệt
                    </span>
                }
                else if (Model.TrangThai == "DaXacNhan")
                {
                    <span class="px-3 py-1 bg-secondary-container text-on-secondary-container rounded-full text-label-md font-bold flex items-center gap-1">
                        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">check_circle</span> Đã xác nhận
                    </span>
                }
                else if (Model.TrangThai == "DangKham")
                {
                    <span class="px-3 py-1 bg-tertiary-container/30 text-tertiary rounded-full text-label-md font-bold flex items-center gap-1">
                        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">stethoscope</span> Đang khám
                    </span>
                }
                else if (Model.TrangThai == "HoanThanh")
                {
                    <span class="px-3 py-1 bg-secondary/20 text-secondary rounded-full text-label-md font-bold flex items-center gap-1">
                        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">done_all</span> Đã hoàn thành
                    </span>
                }
                else
                {
                    <span class="px-3 py-1 bg-error-container text-error rounded-full text-label-md font-bold flex items-center gap-1">
                        <span class="material-symbols-outlined text-xs" style="font-variation-settings: 'FILL' 1;">cancel</span> Đã hủy
                    </span>
                }
            </div>
            <p class="text-on-surface-variant text-body-md">Thời gian đặt hẹn: <span class="font-semibold text-on-surface">@Model.ThoiGian.ToString("dd/MM/yyyy HH:mm")</span></p>
        </div>
    </div>
    <div class="flex flex-wrap items-center gap-2">
        @if (Model.TrangThai == "ChoXacNhan")
        {
            <form method="POST" action="/Admin/Appointments/Confirm/@Model.Id" class="inline">
                @Html.AntiForgeryToken()
                <button type="submit" class="px-6 h-11 bg-primary text-white font-label-md rounded-lg hover:opacity-90 active:scale-95 transition-all flex items-center gap-2 cursor-pointer shadow-md">
                    <span class="material-symbols-outlined text-sm">done</span> Xác nhận
                </button>
            </form>
            <button class="px-6 h-11 border border-primary text-primary font-label-md rounded-lg hover:bg-surface-container-low active:scale-95 transition-all flex items-center gap-2 cursor-pointer">
                <span class="material-symbols-outlined text-sm">schedule_send</span> Dời lịch
            </button>
            <button onclick="document.getElementById('modal-cancel').classList.remove('hidden')" class="px-6 h-11 border border-error text-error font-label-md rounded-lg hover:bg-error-container active:scale-95 transition-all flex items-center gap-2 cursor-pointer">
                <span class="material-symbols-outlined text-sm">close</span> Hủy lịch
            </button>
        }
        <button class="px-4 h-11 text-on-surface-variant font-label-md rounded-lg hover:bg-surface-container-low transition-all flex items-center gap-2 cursor-pointer border border-outline-variant/50">
            <span class="material-symbols-outlined text-sm">print</span> In phiếu hẹn
        </button>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
    <!-- Left Column: Patient & Appointment Info -->
    <div class="lg:col-span-8 space-y-6">
        <!-- Patient Card -->
        <section class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-sm hover:border-primary transition-colors">
            <div class="p-4 border-b border-outline-variant bg-surface-container-low/50 flex items-center justify-between">
                <h3 class="font-title-lg text-title-lg text-primary flex items-center gap-2 font-bold">
                    <span class="material-symbols-outlined">person</span>
                    Thông tin bệnh nhân
                </h3>
                <a href="/Admin/Patients/Details/@Model.Patient.Id" class="text-primary hover:underline font-label-md text-label-md cursor-pointer">Xem hồ sơ đầy đủ</a>
            </div>
            <div class="p-6 flex flex-col md:flex-row items-center md:items-start gap-8">
                <div class="w-32 h-32 rounded-xl overflow-hidden bg-surface-variant border-4 border-white shadow-md flex-shrink-0 flex items-center justify-center">
                    <span class="material-symbols-outlined text-6xl text-outline-variant">person</span>
                </div>
                <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-y-4 gap-x-8 w-full">
                    <div class="space-y-1">
                        <p class="text-on-surface-variant text-caption uppercase tracking-wider font-semibold">Họ và tên</p>
                        <p class="font-body-lg text-body-lg font-bold text-on-surface">@Model.Patient.User.HoTen</p>
                    </div>
                    <div class="space-y-1">
                        <p class="text-on-surface-variant text-caption uppercase tracking-wider font-semibold">Mã bệnh nhân</p>
                        <p class="font-body-lg text-body-lg text-primary font-bold">BN-@Model.Patient.Id.ToString("D4")</p>
                    </div>
                    <div class="space-y-1">
                        <p class="text-on-surface-variant text-caption uppercase tracking-wider font-semibold">Ngày sinh / Giới tính</p>
                        <p class="font-body-lg text-body-lg text-on-surface">@Model.Patient.NgaySinh.ToString("dd/MM/yyyy") • @Model.Patient.GioiTinh</p>
                    </div>
                    <div class="space-y-1">
                        <p class="text-on-surface-variant text-caption uppercase tracking-wider font-semibold">Số điện thoại</p>
                        <p class="font-body-lg text-body-lg text-on-surface">@Model.Patient.User.Sdt</p>
                    </div>
                    <div class="space-y-1 md:col-span-2">
                        <p class="text-on-surface-variant text-caption uppercase tracking-wider font-semibold">Số thẻ BHYT</p>
                        <p class="font-body-lg text-body-lg text-on-surface font-mono">@(string.IsNullOrEmpty(Model.Patient.SoBHYT) ? "Không sử dụng BHYT" : Model.Patient.SoBHYT)</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Appointment Details Card -->
        <section class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-sm hover:border-primary transition-colors">
            <div class="p-4 border-b border-outline-variant bg-surface-container-low/50 flex items-center justify-between">
                <h3 class="font-title-lg text-title-lg text-primary flex items-center gap-2 font-bold">
                    <span class="material-symbols-outlined">stethoscope</span>
                    Chi tiết đăng ký khám
                </h3>
                <button class="p-2 text-outline hover:text-primary transition-colors cursor-pointer">
                    <span class="material-symbols-outlined">edit_square</span>
                </button>
            </div>
            <div class="p-6 grid grid-cols-1 md:grid-cols-3 gap-6">
                @if (Model.Doctor != null)
                {
                    <div class="space-y-1">
                        <p class="text-on-surface-variant text-caption font-semibold">Chuyên khoa</p>
                        <p class="font-body-md text-body-md font-bold text-on-surface">@Model.Doctor.Department?.TenKhoa</p>
                    </div>
                    <div class="space-y-1">
                        <p class="text-on-surface-variant text-caption font-semibold">Bác sĩ phụ trách</p>
                        <p class="font-body-md text-body-md font-bold text-primary">BS. @Model.Doctor.User.HoTen</p>
                    </div>
                    <div class="space-y-1">
                        <p class="text-on-surface-variant text-caption font-semibold">Phòng khám</p>
                        <p class="font-body-md text-body-md font-bold text-on-surface">@Model.Doctor.Department?.ViTri</p>
                    </div>
                }
                else
                {
                    <div class="md:col-span-3">
                        <p class="text-on-surface-variant italic">Chưa phân công bác sĩ. Hệ thống sẽ tự động điều phối khi bệnh nhân đến khám.</p>
                    </div>
                }

                <div class="space-y-1">
                    <p class="text-on-surface-variant text-caption font-semibold">Thời gian</p>
                    <p class="font-body-md text-body-md font-bold text-error">@Model.ThoiGian.ToString("HH:mm - dd/MM/yyyy")</p>
                </div>
                <div class="space-y-1 md:col-span-2">
                    <p class="text-on-surface-variant text-caption font-semibold">Nguồn đặt</p>
                    <span class="inline-flex items-center px-2 py-0.5 mt-1 rounded text-[11px] font-bold bg-surface-container-high text-primary uppercase">HỆ THỐNG</span>
                </div>
                
                <div class="md:col-span-3 pt-2">
                    <div class="bg-surface-container-low p-4 rounded-lg border-l-4 border-primary">
                        <p class="text-on-surface-variant text-caption mb-1 font-semibold uppercase tracking-wider">Lý do khám / Triệu chứng</p>
                        <p class="text-body-md text-on-surface">@Model.LyDoKham</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- Modification History & Notifications -->
        <section class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-sm hover:border-primary transition-colors">
            <div class="p-4 border-b border-outline-variant bg-surface-container-low/50">
                <h3 class="font-title-lg text-title-lg text-primary flex items-center gap-2 font-bold">
                    <span class="material-symbols-outlined">history_edu</span>
                    Nhật ký &amp; Thông báo
                </h3>
            </div>
            <div class="p-0 overflow-x-auto">
                <table class="w-full text-left border-collapse min-w-[600px]">
                    <thead>
                        <tr class="bg-surface-container-low/30 border-b border-outline-variant">
                            <th class="px-6 py-3 font-label-md text-label-md text-on-surface-variant">THỜI GIAN</th>
                            <th class="px-6 py-3 font-label-md text-label-md text-on-surface-variant">SỰ KIỆN / CHI TIẾT</th>
                            <th class="px-6 py-3 font-label-md text-label-md text-on-surface-variant text-right">TRẠNG THÁI</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr class="hover:bg-surface-container-lowest transition-colors">
                            <td class="px-6 py-4 text-caption text-on-surface-variant whitespace-nowrap">@Model.ThoiGian.AddDays(-1).ToString("HH:mm - dd/MM/yyyy")</td>
                            <td class="px-6 py-4">
                                <p class="text-body-md text-on-surface font-semibold">Tạo lịch đăng ký mới</p>
                                <p class="text-caption text-on-surface-variant">Khách hàng đặt lịch khám</p>
                            </td>
                            <td class="px-6 py-4 text-right">
                                <span class="flex items-center gap-1 text-[11px] text-secondary font-bold justify-end"><span class="material-symbols-outlined text-[14px]">notifications_active</span> Ghi nhận thành công</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </section>
    </div>

    <!-- Right Column: Timeline & Internal Notes -->
    <div class="lg:col-span-4 space-y-6">
        <!-- Status Timeline -->
        <section class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-sm hover:border-primary transition-colors">
            <div class="p-4 border-b border-outline-variant bg-surface-container-low/50">
                <h3 class="font-title-lg text-title-lg text-primary flex items-center gap-2 font-bold">
                    <span class="material-symbols-outlined">timeline</span>
                    Trạng thái xử lý
                </h3>
            </div>
            <div class="p-6">
                <div class="relative space-y-8">
                    <div class="absolute left-[11px] top-2 bottom-2 w-0.5 bg-outline-variant"></div>
                    
                    <div class="relative flex items-center gap-4">
                        <div class="w-6 h-6 rounded-full bg-secondary flex items-center justify-center text-white z-10">
                            <span class="material-symbols-outlined text-xs">done</span>
                        </div>
                        <div>
                            <p class="font-label-md text-label-md text-on-surface font-bold">Tạo lịch</p>
                            <p class="text-[11px] text-on-surface-variant">Thành công</p>
                        </div>
                    </div>

                    <div class="relative flex items-center gap-4 @(Model.TrangThai == "ChoXacNhan" ? "opacity-100" : (Model.TrangThai == "DaHuy" ? "opacity-100" : "opacity-100"))">
                        @if (Model.TrangThai == "ChoXacNhan")
                        {
                            <div class="w-6 h-6 rounded-full bg-surface-container-lowest border-2 border-primary flex items-center justify-center text-primary z-10 shadow-sm">
                                <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
                            </div>
                            <div>
                                <p class="font-label-md text-label-md text-primary font-bold">Chờ xác nhận</p>
                                <p class="text-[11px] text-outline italic">Đang chờ Admin duyệt</p>
                            </div>
                        }
                        else if (Model.TrangThai == "DaHuy")
                        {
                            <div class="w-6 h-6 rounded-full bg-error flex items-center justify-center text-white z-10">
                                <span class="material-symbols-outlined text-xs">close</span>
                            </div>
                            <div>
                                <p class="font-label-md text-label-md text-error font-bold">Đã hủy</p>
                                <p class="text-[11px] text-outline italic">Ca khám bị hủy</p>
                            </div>
                        }
                        else
                        {
                            <div class="w-6 h-6 rounded-full bg-secondary flex items-center justify-center text-white z-10">
                                <span class="material-symbols-outlined text-xs">done</span>
                            </div>
                            <div>
                                <p class="font-label-md text-label-md text-on-surface font-bold">Đã xác nhận lịch</p>
                            </div>
                        }
                    </div>

                    <div class="relative flex items-center gap-4 @(Model.TrangThai == "DaXacNhan" ? "opacity-100" : (Model.TrangThai == "ChoXacNhan" || Model.TrangThai == "DaHuy" ? "opacity-40" : "opacity-100"))">
                        @if (Model.TrangThai == "DaXacNhan")
                        {
                            <div class="w-6 h-6 rounded-full bg-surface-container-lowest border-2 border-primary flex items-center justify-center text-primary z-10 shadow-sm">
                                <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
                            </div>
                            <div>
                                <p class="font-label-md text-label-md text-primary font-bold">Chờ khám</p>
                                <p class="text-[11px] text-outline italic">Đang chờ bệnh nhân</p>
                            </div>
                        }
                        else if (Model.TrangThai == "DangKham" || Model.TrangThai == "HoanThanh")
                        {
                            <div class="w-6 h-6 rounded-full bg-secondary flex items-center justify-center text-white z-10">
                                <span class="material-symbols-outlined text-xs">done</span>
                            </div>
                            <div>
                                <p class="font-label-md text-label-md text-on-surface font-bold">Đã check-in</p>
                            </div>
                        }
                        else
                        {
                            <div class="w-6 h-6 rounded-full bg-surface-container-lowest border-2 border-outline-variant flex items-center justify-center text-outline-variant z-10">
                            </div>
                            <div>
                                <p class="font-label-md text-label-md text-on-surface">Check-in tại quầy</p>
                            </div>
                        }
                    </div>

                    <div class="relative flex items-center gap-4 @(Model.TrangThai == "DangKham" ? "opacity-100" : (Model.TrangThai == "HoanThanh" ? "opacity-100" : "opacity-40"))">
                        @if (Model.TrangThai == "DangKham")
                        {
                            <div class="w-6 h-6 rounded-full bg-surface-container-lowest border-2 border-primary flex items-center justify-center text-primary z-10 shadow-sm">
                                <span class="w-2 h-2 bg-primary rounded-full animate-pulse"></span>
                            </div>
                            <div>
                                <p class="font-label-md text-label-md text-primary font-bold">Đang khám</p>
                                <p class="text-[11px] text-outline italic">Bác sĩ đang tiếp nhận</p>
                            </div>
                        }
                        else if (Model.TrangThai == "HoanThanh")
                        {
                            <div class="w-6 h-6 rounded-full bg-secondary flex items-center justify-center text-white z-10">
                                <span class="material-symbols-outlined text-xs">done</span>
                            </div>
                            <div>
                                <p class="font-label-md text-label-md text-on-surface font-bold">Hoàn thành khám</p>
                            </div>
                        }
                        else
                        {
                            <div class="w-6 h-6 rounded-full bg-surface-container-lowest border-2 border-outline-variant flex items-center justify-center text-outline-variant z-10">
                            </div>
                            <div>
                                <p class="font-label-md text-label-md text-on-surface">Bắt đầu khám</p>
                            </div>
                        }
                    </div>

                </div>
            </div>
        </section>

        <!-- Internal Notes -->
        <section class="bg-surface-container-lowest rounded-xl border border-outline-variant overflow-hidden shadow-sm hover:border-primary transition-colors">
            <div class="p-4 border-b border-outline-variant bg-surface-container-low/50">
                <h3 class="font-title-lg text-title-lg text-primary flex items-center gap-2 font-bold">
                    <span class="material-symbols-outlined">notes</span>
                    Ghi chú nội bộ
                </h3>
            </div>
            <div class="p-6 space-y-4">
                <textarea class="w-full h-32 p-4 bg-surface-container-low/50 border border-outline-variant rounded-lg text-body-md focus:ring-1 focus:ring-primary focus:border-primary outline-none placeholder:text-outline italic" placeholder="Thêm ghi chú quan trọng cho nhân viên điều phối..."></textarea>
                <div class="flex justify-between items-center">
                    <p class="text-[11px] text-on-surface-variant flex items-center gap-1 font-semibold">
                        <span class="material-symbols-outlined text-[14px]">lock</span>
                        Chỉ hiển thị nội bộ
                    </p>
                    <button class="px-4 py-2.5 bg-primary-container/20 text-primary-fixed-dim font-label-md rounded-lg hover:bg-primary-container hover:text-white transition-all cursor-pointer font-bold">Lưu ghi chú</button>
                </div>
            </div>
        </section>

        <!-- Quick Contact Support -->
        <div class="bg-primary text-white p-6 rounded-xl flex items-center gap-4 shadow-md">
            <div class="w-12 h-12 bg-white/20 rounded-full flex items-center justify-center flex-shrink-0">
                <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">support_agent</span>
            </div>
            <div>
                <p class="font-label-md text-label-md font-bold mb-1">Hỗ trợ khẩn cấp?</p>
                <p class="text-body-md text-white/90 text-sm">Gọi bộ phận trực ban điều phối</p>
                <p class="font-bold text-lg mt-1">Ext: 2011</p>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Cancel Appointment -->
<div class="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm hidden" id="modal-cancel">
    <div class="bg-surface-container-lowest w-full max-w-md rounded-xl shadow-2xl overflow-hidden border border-outline-variant transform transition-all duration-300 scale-100">
        <form method="POST" action="/Admin/Appointments/Cancel/@Model.Id">
            @Html.AntiForgeryToken()
            <div class="px-6 py-4 border-b border-outline-variant flex justify-between items-center bg-error/5">
                <div class="flex items-center gap-2 text-error">
                    <span class="material-symbols-outlined">warning</span>
                    <h3 class="font-bold text-lg">Hủy lịch hẹn</h3>
                </div>
                <button type="button" class="material-symbols-outlined text-on-surface-variant hover:text-error cursor-pointer" onclick="document.getElementById('modal-cancel').classList.add('hidden')">close</button>
            </div>
            <div class="p-6 space-y-4">
                <p class="text-sm text-on-surface-variant">Bạn đang thực hiện hủy lịch khám <span class="font-bold text-on-surface">LK-@Model.Id.ToString("D4")</span> của bệnh nhân <span class="font-bold text-on-surface">@Model.Patient.User.HoTen</span>.</p>
                <div>
                    <label class="block text-sm font-semibold mb-2" for="lyDoHuy">Lý do hủy (Sẽ thông báo cho bệnh nhân) <span class="text-error">*</span></label>
                    <textarea id="lyDoHuy" name="lyDoHuy" class="w-full border border-outline-variant rounded-lg px-4 py-3 text-sm focus:ring-1 focus:ring-error outline-none" placeholder="Vui lòng nhập lý do chi tiết..." rows="4" required></textarea>
                </div>
            </div>
            <div class="px-6 py-4 bg-surface border-t border-outline-variant flex justify-end gap-3">
                <button type="button" class="px-4 py-2 text-sm font-semibold text-on-surface-variant hover:bg-surface-container rounded-lg cursor-pointer transition-colors" onclick="document.getElementById('modal-cancel').classList.add('hidden')">Bỏ qua</button>
                <button type="submit" class="px-6 py-2 bg-error text-white text-sm font-bold rounded-lg shadow-lg shadow-error/20 hover:opacity-90 transition-all cursor-pointer">Xác nhận hủy</button>
            </div>
        </form>
    </div>
</div>

<script>
    document.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('mousedown', () => btn.style.transform = 'scale(0.98)');
        btn.addEventListener('mouseup', () => btn.style.transform = 'scale(1)');
        btn.addEventListener('mouseleave', () => btn.style.transform = 'scale(1)');
    });
</script>
