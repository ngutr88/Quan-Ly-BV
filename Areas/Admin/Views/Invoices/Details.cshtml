@model QuanLyBenhVien.Models.Invoice

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết hóa đơn";
}

<!-- Alert Messages -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="mb-6 p-4 bg-secondary-container/20 text-on-secondary-container border border-secondary/20 rounded-xl flex items-center gap-2">
        <span class="material-symbols-outlined text-secondary">check_circle</span>
        <span class="font-body-md font-semibold">@TempData["SuccessMessage"]</span>
    </div>
}

<!-- Header Section -->
<div class="flex flex-col md:flex-row md:items-end justify-between gap-6 mb-10">
    <div class="space-y-2">
        <div class="flex items-center gap-4">
            <h2 class="font-headline-lg text-headline-lg text-on-surface font-bold">HD-@Model.Id.ToString("D5")</h2>
            @if (Model.TrangThaiThanhToan == "DaThanhToan")
            {
                <span class="px-4 py-1.5 bg-secondary-container text-on-secondary-container font-semibold text-xs rounded-full flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-secondary"></span> Đã thanh toán
                </span>
            }
            else if (Model.TrangThaiThanhToan == "ChuaThanhToan")
            {
                <span class="px-4 py-1.5 bg-tertiary-fixed text-on-tertiary-fixed font-semibold text-xs rounded-full flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-tertiary"></span> Chưa thanh toán
                </span>
            }
            else
            {
                <span class="px-4 py-1.5 bg-surface-container-high text-on-surface-variant font-semibold text-xs rounded-full flex items-center gap-2">
                    <span class="w-2 h-2 rounded-full bg-outline"></span> Đã hủy
                </span>
            }
        </div>
        <div class="flex items-baseline gap-2">
            <span class="text-on-surface-variant text-body-md">Tổng số tiền:</span>
            <span class="text-3xl font-bold text-primary">@Model.TongTien.ToString("N0") VND</span>
        </div>
    </div>
    <div class="flex flex-wrap items-center gap-3">
        @if (Model.TrangThaiThanhToan == "ChuaThanhToan")
        {
            <button class="px-6 py-2.5 text-error font-semibold hover:bg-error-container transition-colors rounded-lg cursor-pointer" onclick="document.getElementById('modal-cancel').classList.remove('hidden')">
                Hủy hóa đơn
            </button>
        }
        <button class="px-6 py-2.5 border border-primary text-primary font-semibold hover:bg-surface-container transition-colors rounded-lg flex items-center gap-2 cursor-pointer">
            <span class="material-symbols-outlined text-sm">print</span>
            In hóa đơn
        </button>
        <button class="px-6 py-2.5 border border-primary text-primary font-semibold hover:bg-surface-container transition-colors rounded-lg flex items-center gap-2 cursor-pointer">
            <span class="material-symbols-outlined text-sm">picture_as_pdf</span>
            Xuất PDF
        </button>
        @if (Model.TrangThaiThanhToan == "ChuaThanhToan")
        {
            <button class="px-8 py-2.5 bg-primary text-white font-bold hover:opacity-90 transition-all rounded-lg flex items-center gap-2 cursor-pointer shadow-md" onclick="document.getElementById('modal-confirm').classList.remove('hidden')">
                <span class="material-symbols-outlined text-sm">check_circle</span>
                Xác nhận thanh toán
            </button>
        }
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-unit-lg">
    <!-- Left Column (Main Content) -->
    <div class="lg:col-span-2 space-y-unit-lg">
        <!-- Patient Info & Session Info - Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-unit-lg">
            <!-- Patient Card -->
            <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-xl shadow-sm hover:border-primary transition-colors">
                <div class="flex items-center gap-3 mb-4 border-b border-outline-variant pb-3">
                    <span class="material-symbols-outlined text-primary">person</span>
                    <h3 class="font-semibold text-on-surface">Thông tin bệnh nhân</h3>
                </div>
                <div class="space-y-3">
                    <div class="flex justify-between">
                        <span class="text-sm text-on-surface-variant">Họ và tên:</span>
                        <span class="text-sm font-semibold text-on-surface">@Model.ExaminationRecord.Appointment.Patient.User.HoTen</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-sm text-on-surface-variant">Mã bệnh nhân:</span>
                        <span class="text-sm font-semibold text-on-surface">BN-@Model.ExaminationRecord.Appointment.Patient.Id.ToString("D4")</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-sm text-on-surface-variant">Số điện thoại:</span>
                        <span class="text-sm font-semibold text-on-surface">@Model.ExaminationRecord.Appointment.Patient.User.Sdt</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-sm text-on-surface-variant">Bảo hiểm (BHYT):</span>
                        @if (!string.IsNullOrEmpty(Model.ExaminationRecord.Appointment.Patient.SoBHYT))
                        {
                            <span class="text-sm px-2 py-0.5 bg-secondary-container text-on-secondary-container rounded font-bold">@Model.ExaminationRecord.Appointment.Patient.SoBHYT</span>
                        }
                        else
                        {
                            <span class="text-sm px-2 py-0.5 bg-surface-container-high text-on-surface-variant rounded font-bold">KHÔNG CÓ</span>
                        }
                    </div>
                </div>
            </div>
            
            <!-- Session Card -->
            <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-xl shadow-sm hover:border-primary transition-colors">
                <div class="flex items-center gap-3 mb-4 border-b border-outline-variant pb-3">
                    <span class="material-symbols-outlined text-primary">medical_information</span>
                    <h3 class="font-semibold text-on-surface">Phiên khám lâm sàng</h3>
                </div>
                <div class="space-y-3">
                    <div class="flex justify-between">
                        <span class="text-sm text-on-surface-variant">Ngày khám:</span>
                        <span class="text-sm font-semibold text-on-surface">@Model.ExaminationRecord.NgayKham.ToString("dd/MM/yyyy HH:mm")</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-sm text-on-surface-variant">Khoa:</span>
                        <span class="text-sm font-semibold text-on-surface">@Model.ExaminationRecord.Appointment.Doctor.Department?.TenKhoa</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-sm text-on-surface-variant">Bác sĩ:</span>
                        <span class="text-sm font-semibold text-on-surface">BS. @Model.ExaminationRecord.Appointment.Doctor.User.HoTen</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-sm text-on-surface-variant">Mã phiên (SID):</span>
                        <span class="text-sm font-semibold text-on-surface">SID-@Model.ExaminationRecord.Id.ToString("D5")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Fee Breakdown Table -->
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
            <div class="px-6 py-4 border-b border-outline-variant flex justify-between items-center">
                <h3 class="font-semibold text-on-surface">Chi tiết các hạng mục phí</h3>
                <span class="text-xs text-on-surface-variant uppercase tracking-widest font-bold">@Model.InvoiceDetails.Count Hạng mục</span>
            </div>
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse min-w-[600px]">
                    <thead class="bg-surface-container-low text-xs text-on-surface-variant uppercase">
                        <tr>
                            <th class="px-6 py-3 font-semibold">Tên dịch vụ / Thuốc</th>
                            <th class="px-6 py-3 font-semibold text-right">Số lượng</th>
                            <th class="px-6 py-3 font-semibold text-right">Đơn giá</th>
                            <th class="px-6 py-3 font-semibold text-right">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant">
                        @foreach (var detail in Model.InvoiceDetails)
                        {
                            <tr class="hover:bg-surface transition-colors">
                                <td class="px-6 py-4 text-sm font-medium">@detail.LoaiPhi</td>
                                <td class="px-6 py-4 text-sm text-right">1</td>
                                <td class="px-6 py-4 text-sm text-right">@detail.SoTien.ToString("N0")</td>
                                <td class="px-6 py-4 text-sm font-semibold text-right">@detail.SoTien.ToString("N0")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            <div class="p-8 bg-surface-container-lowest border-t border-outline-variant flex justify-end">
                <div class="w-80 space-y-3">
                    <div class="flex justify-between text-on-surface-variant">
                        <span>Tạm tính:</span>
                        <span>@Model.TongTien.ToString("N0") VND</span>
                    </div>
                    <div class="flex justify-between text-secondary font-semibold">
                        <span>BHYT / Giảm giá:</span>
                        <span>- 0 VND</span>
                    </div>
                    <div class="pt-3 border-t border-outline-variant flex justify-between items-baseline">
                        <span class="text-on-surface font-bold">Tổng thanh toán:</span>
                        <span class="text-2xl font-bold text-primary">@Model.TongTien.ToString("N0") VND</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Notes -->
        <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-xl shadow-sm">
            <div class="flex items-center gap-3 mb-3 text-on-surface-variant">
                <span class="material-symbols-outlined text-sm">notes</span>
                <span class="text-sm font-bold uppercase tracking-wider">Ghi chú hóa đơn</span>
            </div>
            <p class="text-sm text-on-surface leading-relaxed italic">
                Hóa đơn thanh toán viện phí bao gồm chi phí khám chữa bệnh và đơn thuốc (nếu có). Vui lòng kiểm tra kỹ thông tin trước khi thanh toán. Hệ thống tự động ghi nhận vào báo cáo tài chính ngay khi xác nhận thu tiền.
            </p>
        </div>
    </div>

    <!-- Right Column (Panels) -->
    <div class="space-y-unit-lg">
        <!-- Payment Status Panel -->
        <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-xl shadow-sm">
            <h3 class="font-semibold text-on-surface mb-6 border-b border-outline-variant pb-3">Hình thức thanh toán</h3>
            <div class="space-y-5">
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant mb-2 uppercase">Phương thức</label>
                    <div class="grid grid-cols-2 gap-2">
                        @if (Model.TrangThaiThanhToan == "DaThanhToan")
                        {
                            <div class="flex items-center justify-center gap-2 @(Model.PhuongThuc == "TienMat" ? "border-2 border-primary bg-primary-fixed text-primary" : "border border-outline-variant text-on-surface-variant opacity-60") py-2 rounded-lg text-xs font-bold">
                                Tiền mặt
                            </div>
                            <div class="flex items-center justify-center gap-2 @(Model.PhuongThuc == "ChuyenKhoan" ? "border-2 border-primary bg-primary-fixed text-primary" : "border border-outline-variant text-on-surface-variant opacity-60") py-2 rounded-lg text-xs font-bold">
                                Chuyển khoản
                            </div>
                            <div class="flex items-center justify-center gap-2 @(Model.PhuongThuc == "TheATM" ? "border-2 border-primary bg-primary-fixed text-primary" : "border border-outline-variant text-on-surface-variant opacity-60") py-2 rounded-lg text-xs font-bold">
                                Thẻ ATM
                            </div>
                            <div class="flex items-center justify-center gap-2 @(Model.PhuongThuc == "VNPay" ? "border-2 border-primary bg-primary-fixed text-primary" : "border border-outline-variant text-on-surface-variant opacity-60") py-2 rounded-lg text-xs font-bold">
                                VNPay/Momo
                            </div>
                        }
                        else
                        {
                            <div class="col-span-2 text-center text-sm italic text-on-surface-variant">
                                Thu ngân sẽ chọn phương thức khi xác nhận
                            </div>
                        }
                    </div>
                </div>
                <div>
                    <label class="block text-xs font-bold text-on-surface-variant mb-2 uppercase">Mã giao dịch (N/A)</label>
                    <input class="w-full bg-background border border-outline-variant rounded-lg px-4 py-2 text-sm focus:ring-1 focus:ring-primary outline-none" placeholder="Nhập mã tham chiếu..." type="text" disabled />
                </div>
                <div class="pt-4 space-y-2 text-xs">
                    <div class="flex justify-between">
                        <span class="text-on-surface-variant">Xác nhận bởi:</span>
                        <span class="font-semibold">@(Model.TrangThaiThanhToan == "DaThanhToan" ? "Hệ thống / Thu ngân" : "---")</span>
                    </div>
                    <div class="flex justify-between">
                        <span class="text-on-surface-variant">Thời gian thanh toán:</span>
                        <span class="font-semibold">@(Model.TrangThaiThanhToan == "DaThanhToan" ? Model.NgayThanhToan?.ToString("dd/MM/yyyy HH:mm") : "Đang chờ...")</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Audit Trail Section -->
        <div class="bg-surface-container-lowest border border-outline-variant p-6 rounded-xl shadow-sm">
            <h3 class="font-semibold text-on-surface mb-6 border-b border-outline-variant pb-3">Lịch sử thay đổi</h3>
            <div class="relative space-y-6 before:absolute before:left-3.5 before:top-2 before:bottom-2 before:w-0.5 before:bg-outline-variant">
                @if (Model.TrangThaiThanhToan == "DaThanhToan")
                {
                    <div class="relative flex gap-4 pl-8">
                        <div class="absolute left-0 w-7 h-7 bg-surface-container flex items-center justify-center rounded-full border border-outline-variant z-10">
                            <span class="material-symbols-outlined text-xs text-primary">check</span>
                        </div>
                        <div>
                            <p class="text-sm font-semibold text-on-surface">Đã thanh toán thành công</p>
                            <p class="text-xs text-on-surface-variant">Hệ thống • @Model.NgayThanhToan?.ToString("dd/MM/yyyy HH:mm")</p>
                        </div>
                    </div>
                }
                <div class="relative flex gap-4 pl-8">
                    <div class="absolute left-0 w-7 h-7 bg-surface-container flex items-center justify-center rounded-full border border-outline-variant z-10">
                        <span class="material-symbols-outlined text-xs text-primary">add</span>
                    </div>
                    <div>
                        <p class="text-sm font-semibold text-on-surface">Hóa đơn được tạo</p>
                        <p class="text-xs text-on-surface-variant">Hệ thống • @Model.NgayTao.ToString("dd/MM/yyyy HH:mm")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal: Confirm Payment -->
@if (Model.TrangThaiThanhToan == "ChuaThanhToan")
{
    <div class="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm hidden" id="modal-confirm">
        <form method="POST" action="/Admin/Invoices/PayCounter/@Model.Id" class="bg-surface-container-lowest w-full max-w-md rounded-xl shadow-2xl overflow-hidden border border-outline-variant transform transition-all duration-300 scale-100">
            <div class="px-6 py-4 border-b border-outline-variant flex justify-between items-center">
                <h3 class="font-bold text-on-surface">Xác nhận thanh toán</h3>
                <button type="button" class="material-symbols-outlined text-on-surface-variant hover:text-error cursor-pointer" onclick="document.getElementById('modal-confirm').classList.add('hidden')">close</button>
            </div>
            <div class="p-6 space-y-4">
                <div class="bg-surface-container p-4 rounded-lg flex justify-between items-center">
                    <span class="text-sm font-medium text-on-surface-variant">Tổng tiền cần thu:</span>
                    <span class="text-xl font-bold text-primary">@Model.TongTien.ToString("N0") VND</span>
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-2">Phương thức thanh toán</label>
                    <select name="phuongThuc" class="w-full border-2 border-primary rounded-lg px-4 py-3 text-body-md outline-none focus:ring-1 focus:ring-primary cursor-pointer" required>
                        <option value="TienMat">Tiền mặt</option>
                        <option value="ChuyenKhoan">Chuyển khoản</option>
                        <option value="TheATM">Thẻ ATM / Quẹt thẻ</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-semibold mb-2">Số tiền nhận từ khách</label>
                    <input class="w-full text-lg font-bold border-2 border-primary rounded-lg px-4 py-3 outline-none" type="text" value="@Model.TongTien.ToString("N0")" readonly />
                </div>
            </div>
            <div class="px-6 py-4 bg-surface border-t border-outline-variant flex justify-end gap-3">
                <button type="button" class="px-4 py-2 text-sm font-semibold text-on-surface-variant hover:bg-surface-container rounded-lg cursor-pointer transition-colors" onclick="document.getElementById('modal-confirm').classList.add('hidden')">Quay lại</button>
                <button type="submit" class="px-6 py-2 bg-primary text-white text-sm font-bold rounded-lg shadow-lg shadow-primary/20 hover:opacity-90 transition-all cursor-pointer">Xác nhận & In biên lai</button>
            </div>
        </form>
    </div>
}

<!-- Modal: Cancel Invoice -->
<div class="fixed inset-0 z-[60] flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm hidden" id="modal-cancel">
    <div class="bg-surface-container-lowest w-full max-w-md rounded-xl shadow-2xl overflow-hidden border border-outline-variant transform transition-all duration-300 scale-100">
        <div class="px-6 py-4 border-b border-outline-variant flex justify-between items-center">
            <div class="flex items-center gap-2 text-error">
                <span class="material-symbols-outlined">warning</span>
                <h3 class="font-bold">Hủy hóa đơn</h3>
            </div>
            <button type="button" class="material-symbols-outlined text-on-surface-variant hover:text-error cursor-pointer" onclick="document.getElementById('modal-cancel').classList.add('hidden')">close</button>
        </div>
        <div class="p-6 space-y-4">
            <p class="text-sm text-on-surface-variant">Bạn đang thực hiện hủy hóa đơn <span class="font-bold text-on-surface">HD-@Model.Id.ToString("D5")</span>. Hành động này không thể hoàn tác và sẽ được ghi lại trong nhật ký hệ thống.</p>
            <div>
                <label class="block text-sm font-semibold mb-2">Lý do hủy <span class="text-error">*</span></label>
                <textarea class="w-full border border-outline-variant rounded-lg px-4 py-3 text-sm focus:ring-1 focus:ring-error outline-none" placeholder="Vui lòng nhập lý do chi tiết..." rows="4"></textarea>
            </div>
        </div>
        <div class="px-6 py-4 bg-surface border-t border-outline-variant flex justify-end gap-3">
            <button type="button" class="px-4 py-2 text-sm font-semibold text-on-surface-variant hover:bg-surface-container rounded-lg cursor-pointer transition-colors" onclick="document.getElementById('modal-cancel').classList.add('hidden')">Bỏ qua</button>
            <button type="button" class="px-6 py-2 bg-error text-white text-sm font-bold rounded-lg shadow-lg shadow-error/20 hover:opacity-90 transition-all cursor-pointer" onclick="alert('Tính năng đang phát triển'); document.getElementById('modal-cancel').classList.add('hidden')">Xác nhận hủy</button>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('button').forEach(btn => {
        btn.addEventListener('mousedown', () => btn.style.transform = 'scale(0.98)');
        btn.addEventListener('mouseup', () => btn.style.transform = 'scale(1)');
        btn.addEventListener('mouseleave', () => btn.style.transform = 'scale(1)');
    });
</script>
