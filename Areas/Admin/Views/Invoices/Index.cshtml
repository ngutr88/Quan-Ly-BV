@model QuanLyBenhVien.Helpers.PagedList<QuanLyBenhVien.Models.Invoice>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Hóa đơn";

    var invoices = Model.Items;
    var totalMatching = (int)(ViewBag.TotalMatching ?? 0);
    var paidCount = (int)(ViewBag.PaidCount ?? 0);
    var paidAmount = (decimal)(ViewBag.PaidAmount ?? 0m);
    var unpaidCount = (int)(ViewBag.UnpaidCount ?? 0);
    var unpaidAmount = (decimal)(ViewBag.UnpaidAmount ?? 0m);
    var cancelledCount = (int)(ViewBag.CancelledCount ?? 0);

    var filters = new Dictionary<string, string>
    {
        ["searchString"] = ViewBag.SearchString as string,
        ["statusFilter"] = ViewBag.StatusFilter as string
    };
    var exportQuery = string.Join("&", filters
        .Where(kv => !string.IsNullOrEmpty(kv.Value))
        .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value)}"));

    Func<object, IHtmlContent> pageActions = @<text>
        <a href="/Admin/Invoices/Export@(string.IsNullOrEmpty(exportQuery) ? "" : "?" + exportQuery)" class="hms-btn hms-btn-secondary">
            <span class="material-symbols-outlined">download</span> Xuất Excel
        </a>
    </text>;

    ViewData["PageActions"] = pageActions;

    var header = new PageHeaderViewModel
    {
        Title = "Hóa đơn & doanh thu",
        Subtitle = "Lập biên lai khám, đối soát hóa đơn cận lâm sàng và thuốc đã cấp cho bệnh nhân.",
        Breadcrumbs = new[] { new BreadcrumbItem("Quản trị", "/Admin/Dashboard") },
        CurrentCrumb = "Hóa đơn"
    };
}

<partial name="_PageHeader" model="header" />

<div class="hms-stat-grid">
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-primary"><span class="material-symbols-outlined">receipt_long</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Hóa đơn khớp lọc</p>
            <p class="hms-stat-value">@totalMatching.ToString("N0")</p>
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-success"><span class="material-symbols-outlined">payments</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Đã thu</p>
            <p class="hms-stat-value">@paidAmount.ToString("N0") ₫</p>
            <p class="hms-stat-hint">@paidCount hóa đơn</p>
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-warn"><span class="material-symbols-outlined">pending</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Chưa thu</p>
            <p class="hms-stat-value">@unpaidAmount.ToString("N0") ₫</p>
            <p class="hms-stat-hint">@unpaidCount hóa đơn</p>
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-danger"><span class="material-symbols-outlined">cancel</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Đã hủy</p>
            <p class="hms-stat-value">@cancelledCount</p>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="hms-toolbar">
    <form method="GET" action="/Admin/Invoices" class="hms-toolbar-grid">
        <div style="grid-column: span 2 / span 2;">
            <label class="hms-field-label" for="invoice-search">Tìm kiếm</label>
            <div class="hms-search">
                <span class="material-symbols-outlined">search</span>
                <input id="invoice-search" class="w-full py-2 pr-4 border border-outline-variant rounded-lg font-body-md"
                       name="searchString" value="@ViewBag.SearchString" placeholder="Tên bệnh nhân..." type="text" />
            </div>
        </div>
        <div>
            <label class="hms-field-label" for="statusFilter">Trạng thái thanh toán</label>
            <select class="w-full py-2 px-3 border border-outline-variant rounded-lg font-body-md"
                    id="statusFilter" name="statusFilter">
                <option value="">Tất cả trạng thái</option>
                <option value="ChuaThanhToan" selected="@(ViewBag.StatusFilter == "ChuaThanhToan")">Chưa thanh toán</option>
                <option value="DaThanhToan" selected="@(ViewBag.StatusFilter == "DaThanhToan")">Đã thanh toán</option>
                <option value="DaHuy" selected="@(ViewBag.StatusFilter == "DaHuy")">Đã hủy</option>
            </select>
        </div>
        <div class="flex gap-2">
            <button type="submit" class="hms-btn hms-btn-primary">
                <span class="material-symbols-outlined">filter_list</span> Tìm kiếm
            </button>
            <a href="/Admin/Invoices" class="hms-btn hms-btn-secondary">
                <span class="material-symbols-outlined">refresh</span> Đặt lại
            </a>
        </div>
    </form>
</div>

<!-- Invoices Table -->
<div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-surface-container-low text-on-surface-variant font-label-md text-[12px] uppercase">
                    <th class="px-unit-md py-3">Số Hóa đơn</th>
                    <th class="px-unit-md py-3">Bệnh nhân</th>
                    <th class="px-unit-md py-3">Ngày phát sinh</th>
                    <th class="px-unit-md py-3">Tổng số tiền</th>
                    <th class="px-unit-md py-3">Phương thức</th>
                    <th class="px-unit-md py-3">Trạng thái</th>
                    <th class="px-unit-md py-3 text-right">Chi tiết</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant text-body-md">
                @if (invoices.Count == 0)
                {
                    <tr>
                        <td colspan="7">
                            <div class="hms-empty">
                                <div class="hms-empty-icon"><span class="material-symbols-outlined">receipt_long</span></div>
                                <p class="hms-empty-title">Không tìm thấy hóa đơn nào</p>
                                <p class="hms-empty-text">Thử đổi từ khóa tìm kiếm hoặc chọn "Tất cả trạng thái" để xem toàn bộ hóa đơn.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var inv in invoices)
                    {
                        <tr class="hover:bg-surface-container-low transition-colors">
                            <td class="px-unit-md py-4 font-mono font-bold text-primary">#HD-@inv.Id.ToString("D5")</td>
                            <td class="px-unit-md py-4">
                                <div class="font-semibold text-on-surface">@inv.ExaminationRecord.Appointment.Patient.User.HoTen</div>
                                <div class="text-caption text-on-surface-variant">BN-@inv.ExaminationRecord.Appointment.Patient.Id.ToString("D4")</div>
                            </td>
                            <td class="px-unit-md py-4">@inv.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-unit-md py-4 font-bold text-on-surface">@inv.TongTien.ToString("N0") đ</td>
                            <td class="px-unit-md py-4">
                                @if (inv.TrangThaiThanhToan == "DaThanhToan")
                                {
                                    <span>@inv.PhuongThuc</span>
                                }
                                else
                                {
                                    <span class="text-on-surface-variant italic">--/--</span>
                                }
                            </td>
                            <td class="px-unit-md py-4">
                                @if (inv.TrangThaiThanhToan == "DaThanhToan")
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-secondary/15 text-secondary text-[11px] font-bold">Đã thanh toán</span>
                                }
                                else if (inv.TrangThaiThanhToan == "ChuaThanhToan")
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-error-container text-error text-[11px] font-bold">Chưa thanh toán</span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-surface-container-high text-on-surface-variant text-[11px] font-bold">Đã hủy</span>
                                }
                            </td>
                            <td class="px-unit-md py-4 text-right">
                                <a href="/Admin/Invoices/Details/@inv.Id" class="inline-flex items-center gap-0.5 bg-surface-container hover:bg-surface-container-high px-3 py-1.5 rounded-lg text-label-md transition-colors text-primary font-semibold border border-outline-variant/30">
                                    Biên lai <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (invoices.Count > 0)
    {
        <partial name="_Pagination" model='PaginationViewModel.From(Model, "/Admin/Invoices", "hóa đơn", filters)' />
    }
</div>
