@model IEnumerable<QuanLyBenhVien.Models.Invoice>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Hóa đơn";
}

<div class="mb-unit-lg">
    <h2 class="font-headline-lg text-headline-lg text-on-surface">Quản lý Hóa đơn &amp; Doanh thu</h2>
    <p class="text-body-md text-on-surface-variant">Lập biên lai khám, đối soát hóa đơn cận lâm sàng &amp; thuốc cấp cho bệnh nhân.</p>
</div>

<!-- Filters Bar -->
<div class="bg-surface-container-lowest border border-outline-variant p-unit-md rounded-xl mb-unit-lg shadow-sm">
    <form method="GET" action="/Admin/Invoices" class="flex flex-col md:flex-row gap-unit-md items-end">
        <div class="flex-grow relative w-full">
            <span class="absolute inset-y-0 left-0 pl-3 flex items-center text-outline">
                <span class="material-symbols-outlined text-[20px]">search</span>
            </span>
            <input class="w-full pl-10 pr-4 py-2 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                   name="searchString" value="@ViewBag.SearchString" placeholder="Tìm kiếm theo tên bệnh nhân..." type="text" />
        </div>
        
        <div class="w-full md:w-64">
            <label class="block text-caption font-semibold text-on-surface-variant mb-1" for="statusFilter">Trạng thái thanh toán</label>
            <select class="w-full px-4 py-2 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                    id="statusFilter" name="statusFilter">
                <option value="">Tất cả trạng thái</option>
                <option value="ChuaThanhToan" selected="@(ViewBag.StatusFilter == "ChuaThanhToan")">Chưa thanh toán</option>
                <option value="DaThanhToan" selected="@(ViewBag.StatusFilter == "DaThanhToan")">Đã thanh toán</option>
                <option value="DaHuy" selected="@(ViewBag.StatusFilter == "DaHuy")">Đã hủy</option>
            </select>
        </div>

        <button type="submit" class="bg-primary hover:bg-primary-container text-white px-unit-lg py-2.5 rounded-lg font-label-md transition-colors font-semibold shadow-sm w-full md:w-auto">
            Tìm kiếm
        </button>
    </form>
</div>

<!-- Invoices Table -->
<div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-surface-container-low text-on-surface-variant font-label-md text-[12px] uppercase">
                    <th class="px-unit-md py-3">Số Hóa đơn</th>
                    <th class="px-unit-md py-3">Bệnh nhân</th>
                    <th class="px-unit-md py-3">Ngày phát sinh</th>
                    <th class="px-unit-md py-3">Tổng số tiền</th>
                    <th class="px-unit-md py-3">Phương thức</th>
                    <th class="px-unit-md py-3">Trạng thái</th>
                    <th class="px-unit-md py-3 text-right">Chi tiết</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant text-body-md">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="7" class="px-unit-md py-8 text-center text-on-surface-variant">Không tìm thấy hóa đơn nào.</td>
                    </tr>
                }
                else
                {
                    @foreach (var inv in Model)
                    {
                        <tr class="hover:bg-surface-container-low transition-colors">
                            <td class="px-unit-md py-4 font-mono font-bold text-primary">#HD-@inv.Id.ToString("D5")</td>
                            <td class="px-unit-md py-4">
                                <div class="font-semibold text-on-surface">@inv.ExaminationRecord.Appointment.Patient.User.HoTen</div>
                                <div class="text-caption text-on-surface-variant">BN-@inv.ExaminationRecord.Appointment.Patient.Id.ToString("D4")</div>
                            </td>
                            <td class="px-unit-md py-4">@inv.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-unit-md py-4 font-bold text-on-surface">@inv.TongTien.ToString("N0") đ</td>
                            <td class="px-unit-md py-4">
                                @if (inv.TrangThaiThanhToan == "DaThanhToan")
                                {
                                    <span>@inv.PhuongThuc</span>
                                }
                                else
                                {
                                    <span class="text-on-surface-variant italic">--/--</span>
                                }
                            </td>
                            <td class="px-unit-md py-4">
                                @if (inv.TrangThaiThanhToan == "DaThanhToan")
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-secondary/15 text-secondary text-[11px] font-bold">Đã thanh toán</span>
                                }
                                else if (inv.TrangThaiThanhToan == "ChuaThanhToan")
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-error-container text-error text-[11px] font-bold">Chưa thanh toán</span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-surface-container-high text-on-surface-variant text-[11px] font-bold">Đã hủy</span>
                                }
                            </td>
                            <td class="px-unit-md py-4 text-right">
                                <a href="/Admin/Invoices/Details/@inv.Id" class="inline-flex items-center gap-0.5 bg-surface-container hover:bg-surface-container-high px-3 py-1.5 rounded-lg text-label-md transition-colors text-primary font-semibold border border-outline-variant/30">
                                    Biên lai <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
