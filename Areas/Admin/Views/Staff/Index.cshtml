@model QuanLyBenhVien.Helpers.PagedList<QuanLyBenhVien.Models.User>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Nhân sự & Phân quyền";

    var staffList = Model.Items;
    var totalMatching = (int)(ViewBag.TotalMatching ?? 0);
    var adminCount = (int)(ViewBag.AdminCount ?? 0);
    var doctorCount = (int)(ViewBag.DoctorCount ?? 0);
    var activeStaff = (int)(ViewBag.ActiveStaff ?? 0);

    var filters = new Dictionary<string, string>
    {
        ["searchString"] = ViewBag.SearchString as string,
        ["roleFilter"] = ViewBag.RoleFilter as string
    };
    var exportQuery = string.Join("&", filters
        .Where(kv => !string.IsNullOrEmpty(kv.Value))
        .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value)}"));

    var header = new PageHeaderViewModel
    {
        Title = "Nhân sự & phân quyền",
        Subtitle = "Quản lý tài khoản quản trị viên và đội ngũ bác sĩ, phân quyền truy cập hệ thống.",
        Breadcrumbs = new[] { new BreadcrumbItem("Quản trị", "/Admin/Dashboard") },
        CurrentCrumb = "Nhân sự"
    };

    Func<object, IHtmlContent> pageActions = @<text>
        <a href="/Admin/Staff/Export@(string.IsNullOrEmpty(exportQuery) ? "" : "?" + exportQuery)" class="hms-btn hms-btn-secondary">
            <span class="material-symbols-outlined">download</span> Xuất Excel
        </a>
        <a href="/Admin/Staff/Create" class="hms-btn hms-btn-primary">
            <span class="material-symbols-outlined">person_add</span> Thêm nhân sự mới
        </a>
    </text>;

    ViewData["PageActions"] = pageActions;
}

<partial name="_PageHeader" model="header" />

@if (TempData["SuccessMessage"] != null)
{
    <div class="mb-unit-md p-4 bg-secondary-container/20 text-on-secondary-container border border-secondary/20 rounded-lg flex items-center gap-2">
        <span class="material-symbols-outlined text-secondary">check_circle</span>
        <span class="font-label-md">@TempData["SuccessMessage"]</span>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="mb-unit-md p-4 bg-error-container/25 text-error border border-error/20 rounded-lg flex items-center gap-2">
        <span class="material-symbols-outlined text-error">error</span>
        <span class="font-label-md">@TempData["ErrorMessage"]</span>
    </div>
}

<div class="hms-stat-grid">
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-primary"><span class="material-symbols-outlined">badge</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Tài khoản khớp lọc</p>
            <p class="hms-stat-value">@totalMatching.ToString("N0")</p>
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-primary"><span class="material-symbols-outlined">admin_panel_settings</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Quản trị viên</p>
            <p class="hms-stat-value">@adminCount</p>
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-primary"><span class="material-symbols-outlined">stethoscope</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Bác sĩ</p>
            <p class="hms-stat-value">@doctorCount</p>
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-success"><span class="material-symbols-outlined">verified_user</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Đang hoạt động</p>
            <p class="hms-stat-value">@activeStaff</p>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="hms-toolbar">
    <form method="GET" action="/Admin/Staff" class="hms-toolbar-grid">
        <div style="grid-column: span 2 / span 2;">
            <label class="hms-field-label" for="staff-search">Tìm kiếm</label>
            <div class="hms-search">
                <span class="material-symbols-outlined">search</span>
                <input id="staff-search" class="w-full py-2 pr-4 border border-outline-variant rounded-lg font-body-md"
                       name="searchString" value="@ViewBag.SearchString" placeholder="Tên, email hoặc SĐT nhân viên..." type="text" />
            </div>
        </div>

        <div>
            <label class="hms-field-label" for="roleFilter">Vai trò</label>
            <select id="roleFilter" class="w-full py-2 px-3 border border-outline-variant rounded-lg font-body-md" name="roleFilter">
                <option value="">Tất cả vai trò</option>
                <option value="Admin" selected="@(ViewBag.RoleFilter == "Admin")">Quản trị viên</option>
                <option value="Doctor" selected="@(ViewBag.RoleFilter == "Doctor")">Bác sĩ</option>
            </select>
        </div>

        <button type="submit" class="hms-btn hms-btn-primary">
            <span class="material-symbols-outlined">filter_list</span> Áp dụng lọc
        </button>
    </form>
</div>

<!-- Staff Table -->
<div class="w-full min-w-0 max-w-full bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
    <div class="staff-table-scroll overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-surface-container-low text-on-surface-variant font-label-md text-[12px] uppercase">
                    <th class="px-unit-md py-3">Mã NV</th>
                    <th class="px-unit-md py-3">Họ và tên</th>
                    <th class="px-unit-md py-3">Thông tin liên hệ</th>
                    <th class="px-unit-md py-3">Vai trò</th>
                    <th class="px-unit-md py-3 whitespace-nowrap">Trạng thái</th>
                    <th class="px-unit-md py-3 whitespace-nowrap">Ngày tham gia</th>
                    <th class="px-unit-md py-3 text-right whitespace-nowrap">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @if (staffList.Count == 0)
                {
                    <tr>
                        <td colspan="7">
                            <div class="hms-empty">
                                <div class="hms-empty-icon"><span class="material-symbols-outlined">badge</span></div>
                                <p class="hms-empty-title">Không tìm thấy nhân sự nào phù hợp</p>
                                <p class="hms-empty-text">Thử đổi từ khóa tìm kiếm hoặc chọn "Tất cả vai trò" để xem toàn bộ tài khoản.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var staff in staffList)
                    {
                        <tr class="hover:bg-surface-container-low transition-colors group">
                            <td class="px-unit-md py-4 font-bold text-primary">STAFF-@staff.Id.ToString("D3")</td>
                            <td class="px-unit-md py-4">
                                <div class="font-body-md font-semibold text-on-surface flex items-center gap-2">
                                    @staff.HoTen
                                    @if (staff.VaiTro == "Admin")
                                    {
                                        <span class="px-1.5 py-0.5 bg-primary/10 text-primary text-[10px] font-bold rounded">Admin</span>
                                    }
                                    else if (staff.VaiTro == "Doctor" && staff.DoctorProfile != null)
                                    {
                                        <span class="px-1.5 py-0.5 bg-primary/10 text-primary text-[10px] font-bold rounded">@staff.DoctorProfile.ChucVu</span>
                                    }
                                </div>
                                @if (staff.VaiTro == "Doctor" && staff.DoctorProfile != null)
                                {
                                    <div class="text-[11px] text-on-surface-variant">
                                        Khoa: <strong>@staff.DoctorProfile.Department.TenKhoa</strong> | @staff.DoctorProfile.HocVi (@staff.DoctorProfile.ChuyenKhoa)
                                    </div>
                                }
                            </td>
                            <td class="px-unit-md py-4">
                                <div class="font-body-md text-on-surface">@staff.Email</div>
                                <div class="text-caption text-on-surface-variant">SĐT: @staff.Sdt</div>
                            </td>
                            <td class="px-unit-md py-4">
                                @if (staff.VaiTro == "Admin")
                                {
                                    <span class="flex items-center gap-1 text-primary font-semibold">
                                        <span class="material-symbols-outlined text-[16px]">admin_panel_settings</span>
                                        Quản trị viên
                                    </span>
                                }
                                else
                                {
                                    <span class="flex items-center gap-1 text-primary font-semibold">
                                        <span class="material-symbols-outlined text-[16px]">stethoscope</span>
                                        Bác sĩ
                                    </span>
                                }
                            </td>
                            <td class="px-unit-md py-4 whitespace-nowrap">
                                @if (staff.TrangThai == "Active")
                                {
                                    <span class="px-2.5 py-1 rounded-full bg-secondary-container/20 text-on-secondary-container text-[11px] font-bold whitespace-nowrap">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-1 rounded-full bg-error-container text-error text-[11px] font-bold whitespace-nowrap">Đã khóa</span>
                                }
                            </td>
                            <td class="px-unit-md py-4 text-body-md text-on-surface-variant whitespace-nowrap">
                                @staff.NgayTao.ToString("dd/MM/yyyy")
                            </td>
                            <td class="px-unit-md py-4 text-right">
                                <div class="flex items-center justify-end gap-unit-sm">
                                    <a href="/Admin/Staff/Details/@staff.Id" class="p-1 text-on-surface-variant hover:text-primary transition-colors" title="Chi tiết & Đổi MK">
                                        <span class="material-symbols-outlined">visibility</span>
                                    </a>
                                    <a href="/Admin/Staff/Edit/@staff.Id" class="p-1 text-on-surface-variant hover:text-tertiary transition-colors" title="Chỉnh sửa">
                                        <span class="material-symbols-outlined">edit</span>
                                    </a>
                                    <form method="POST" action="/Admin/Staff/ToggleStatus/@staff.Id" class="inline" onsubmit="return confirm('Bạn có chắc chắn muốn thay đổi trạng thái hoạt động của nhân viên này?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="p-1 @(staff.TrangThai == "Active" ? "text-error hover:text-red-700" : "text-secondary hover:text-green-700") transition-colors" title="@(staff.TrangThai == "Active" ? "Khóa tài khoản" : "Mở khóa tài khoản")">
                                            <span class="material-symbols-outlined">@(staff.TrangThai == "Active" ? "lock" : "lock_open")</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (staffList.Count > 0)
    {
        <partial name="_Pagination" model='PaginationViewModel.From(Model, "/Admin/Staff", "nhân sự", filters)' />
    }
</div>
