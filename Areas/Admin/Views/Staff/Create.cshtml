@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Thêm Nhân sự mới";
}

<div class="mb-unit-lg">
    <a href="/Admin/Staff" class="inline-flex items-center gap-1 text-primary hover:underline font-label-md mb-unit-sm">
        <span class="material-symbols-outlined text-[16px]">arrow_back</span>
        Quay lại danh sách
    </a>
    <h2 class="font-headline-lg text-headline-lg text-on-surface">Thêm Nhân sự mới</h2>
    <p class="text-body-md text-on-surface-variant">Tạo tài khoản quản trị viên mới hoặc đăng ký hồ sơ bác sĩ kèm phân khoa công tác.</p>
</div>

<div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm p-unit-lg max-w-3xl">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="mb-unit-md p-4 bg-error-container/20 text-error border border-error/20 rounded-lg">
            <div asp-validation-summary="All" class="text-label-md font-semibold space-y-1"></div>
        </div>
    }

    <form method="POST" action="/Admin/Staff/Create" class="space-y-6">
        @Html.AntiForgeryToken()

        <!-- Account Info Section -->
        <div>
            <h3 class="font-title-lg text-title-lg text-primary border-b border-outline-variant pb-2 mb-4 flex items-center gap-1">
                <span class="material-symbols-outlined">account_circle</span>
                Thông tin Tài khoản
            </h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-unit-md">
                <div class="space-y-unit-xs">
                    <label class="block text-caption font-semibold text-on-surface-variant">Họ và tên *</label>
                    <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                           name="hoTen" placeholder="Nhập họ và tên nhân sự" required type="text" />
                </div>

                <div class="space-y-unit-xs">
                    <label class="block text-caption font-semibold text-on-surface-variant">Vai trò hệ thống *</label>
                    <select class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                            name="vaiTro" id="role-select" onchange="toggleDoctorFields()" required>
                        <option value="Admin">Quản trị viên (Admin)</option>
                        <option value="Doctor">Bác sĩ (Doctor)</option>
                    </select>
                </div>

                <div class="space-y-unit-xs">
                    <label class="block text-caption font-semibold text-on-surface-variant">Địa chỉ Email *</label>
                    <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                           name="email" placeholder="example@hms.com" required type="email" />
                </div>

                <div class="space-y-unit-xs">
                    <label class="block text-caption font-semibold text-on-surface-variant">Số điện thoại *</label>
                    <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                           name="sdt" placeholder="Ví dụ: 0912345678" required type="text" />
                </div>

                <div class="space-y-unit-xs md:col-span-2">
                    <label class="block text-caption font-semibold text-on-surface-variant">Mật khẩu đăng nhập ban đầu *</label>
                    <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                           name="matKhau" placeholder="Nhập mật khẩu (tối thiểu 6 ký tự)" required type="password" />
                </div>
            </div>
        </div>

        <!-- Doctor Profile Section (Initially Hidden) -->
        <div id="doctor-profile-section" class="hidden animate-fade-in">
            <h3 class="font-title-lg text-title-lg text-primary border-b border-outline-variant pb-2 mb-4 flex items-center gap-1">
                <span class="material-symbols-outlined">medical_information</span>
                Thông tin Chuyên môn Bác sĩ
            </h3>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-unit-md">
                <div class="space-y-unit-xs">
                    <label class="block text-caption font-semibold text-on-surface-variant">Khoa công tác *</label>
                    <select class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                            name="khoaId" asp-items="ViewBag.KhoaId">
                        <option value="">Chọn khoa chuyên môn...</option>
                    </select>
                </div>

                <div class="space-y-unit-xs">
                    <label class="block text-caption font-semibold text-on-surface-variant">Chuyên khoa cụ thể *</label>
                    <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                           name="chuyenKhoa" placeholder="Ví dụ: Tim mạch nhi, Nội tổng hợp" type="text" />
                </div>

                <div class="space-y-unit-xs">
                    <label class="block text-caption font-semibold text-on-surface-variant">Học vị *</label>
                    <select class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                            name="hocVi">
                        <option value="BS">Bác sĩ (BS)</option>
                        <option value="ThS">Thạc sĩ (ThS)</option>
                        <option value="TS">Tiến sĩ (TS)</option>
                        <option value="PGS">Phó Giáo sư (PGS)</option>
                        <option value="GS">Giáo sư (GS)</option>
                    </select>
                </div>

                <div class="space-y-unit-xs">
                    <label class="block text-caption font-semibold text-on-surface-variant">Số năm kinh nghiệm *</label>
                    <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                           name="soNamKinhNghiem" value="1" min="0" type="number" />
                </div>

                <div class="space-y-unit-xs">
                    <label class="block text-caption font-semibold text-on-surface-variant">Chức vụ tại khoa *</label>
                    <select class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                            name="chucVu">
                        <option value="Bác sĩ">Bác sĩ điều trị</option>
                        <option value="Trưởng khoa">Trưởng khoa</option>
                        <option value="Phó trưởng khoa">Phó trưởng khoa</option>
                    </select>
                </div>

                <div class="space-y-unit-xs">
                    <label class="block text-caption font-semibold text-on-surface-variant">Lịch làm việc mặc định</label>
                    <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                           name="lichLamViec" value="Ca sang (08:00 - 12:00) & Chiều (13:30 - 17:30)" placeholder="Nhập mô tả lịch làm việc" type="text" />
                </div>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="flex items-center gap-unit-md pt-4 border-t border-outline-variant">
            <button type="submit" class="bg-primary text-white px-unit-lg py-2.5 rounded-lg font-label-md hover:bg-primary-container transition-colors shadow-sm font-bold flex items-center gap-1">
                <span class="material-symbols-outlined text-[20px]">save</span>
                Lưu thông tin
            </button>
            <a href="/Admin/Staff" class="bg-surface-container-high hover:bg-surface-container-highest px-unit-lg py-2.5 rounded-lg font-label-md transition-colors text-on-surface-variant font-semibold">
                Hủy bỏ
            </a>
        </div>
    </form>
</div>

<script>
    function toggleDoctorFields() {
        const role = document.getElementById("role-select").value;
        const doctorSection = document.getElementById("doctor-profile-section");
        
        // Find inputs under doctor section to toggle required attribute
        const inputs = doctorSection.querySelectorAll("input, select");

        if (role === "Doctor") {
            doctorSection.classList.remove("hidden");
            inputs.forEach(input => {
                if (input.name === "khoaId" || input.name === "chuyenKhoa") {
                    input.required = true;
                }
            });
        } else {
            doctorSection.classList.add("hidden");
            inputs.forEach(input => {
                input.required = false;
            });
        }
    }
    
    // Initial call on page load
    document.addEventListener("DOMContentLoaded", toggleDoctorFields);
</script>
