@model QuanLyBenhVien.Areas.Admin.Controllers.HospitalSettings

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Cấu hình Hệ thống";
}

<div class="mb-unit-lg">
    <h2 class="font-headline-lg text-headline-lg text-on-surface font-bold">Cấu hình Hệ thống</h2>
    <p class="text-body-md text-on-surface-variant">Thiết lập các tham số hoạt động chung của bệnh viện, cấu hình đặt lịch và các cảnh báo vận hành.</p>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="mb-unit-md p-4 bg-secondary-container/20 text-on-secondary-container border border-secondary/20 rounded-lg flex items-center gap-2">
        <span class="material-symbols-outlined text-secondary">check_circle</span>
        <span class="font-label-md">@TempData["SuccessMessage"]</span>
    </div>
}
@if (!ViewData.ModelState.IsValid)
{
    <div class="mb-unit-md p-4 bg-error-container/25 text-error border border-error/20 rounded-lg">
        <div asp-validation-summary="All" class="text-label-md font-semibold space-y-1"></div>
    </div>
}

<form method="POST" action="/Admin/Settings" class="space-y-unit-lg max-w-4xl">
    @Html.AntiForgeryToken()

    <!-- Card 1: Hospital Info -->
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm p-unit-lg">
        <h3 class="font-title-lg text-title-lg text-primary border-b border-outline-variant pb-2 mb-unit-md flex items-center gap-2">
            <span class="material-symbols-outlined">apartment</span>
            Thông tin Bệnh viện &amp; Liên hệ
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-unit-md">
            <div class="space-y-unit-xs md:col-span-2">
                <label class="block text-caption font-semibold text-on-surface-variant uppercase">Tên Bệnh viện *</label>
                <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                       name="TenBenhVien" value="@Model.TenBenhVien" required type="text" />
            </div>

            <div class="space-y-unit-xs">
                <label class="block text-caption font-semibold text-on-surface-variant uppercase">Hotline Tổng đài *</label>
                <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                       name="Hotline" value="@Model.Hotline" required type="text" />
            </div>

            <div class="space-y-unit-xs">
                <label class="block text-caption font-semibold text-on-surface-variant uppercase">Đường dây nóng Cấp cứu *</label>
                <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus text-error font-bold" 
                       name="HotlineCapCuu" value="@Model.HotlineCapCuu" required type="text" />
            </div>

            <div class="space-y-unit-xs">
                <label class="block text-caption font-semibold text-on-surface-variant uppercase">Email hỗ trợ *</label>
                <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                       name="EmailHoTro" value="@Model.EmailHoTro" required type="email" />
            </div>

            <div class="space-y-unit-xs">
                <label class="block text-caption font-semibold text-on-surface-variant uppercase">Thời gian làm việc khám bệnh *</label>
                <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                       name="GioLamViec" value="@Model.GioLamViec" required type="text" />
            </div>

            <div class="space-y-unit-xs md:col-span-2">
                <label class="block text-caption font-semibold text-on-surface-variant uppercase">Địa chỉ trụ sở bệnh viện *</label>
                <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                       name="DiaChi" value="@Model.DiaChi" required type="text" />
            </div>
        </div>
    </div>

    <!-- Card 2: Appointment Booking Config -->
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm p-unit-lg">
        <h3 class="font-title-lg text-title-lg text-primary border-b border-outline-variant pb-2 mb-unit-md flex items-center gap-2">
            <span class="material-symbols-outlined">schedule</span>
            Cấu hình Quy trình &amp; Đặt lịch hẹn
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-unit-md">
            <div class="space-y-unit-xs">
                <label class="block text-caption font-semibold text-on-surface-variant uppercase">Thời lượng khám trung bình (Phút) *</label>
                <div class="relative">
                    <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus pr-16" 
                           name="ThoiGianKhamCa" value="@Model.ThoiGianKhamCa" min="5" max="120" required type="number" />
                    <span class="absolute inset-y-0 right-0 pr-4 flex items-center text-on-surface-variant text-caption font-semibold">Phút / Ca</span>
                </div>
                <p class="text-[11px] text-on-surface-variant">Dùng để phân chia slot khám tự động cho lịch làm việc của Bác sĩ.</p>
            </div>

            <div class="space-y-unit-xs">
                <label class="block text-caption font-semibold text-on-surface-variant uppercase">Số bệnh nhân tối đa mỗi ca trực *</label>
                <div class="relative">
                    <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus pr-16" 
                           name="SoBenhNhanToiDaMoiCa" value="@Model.SoBenhNhanToiDaMoiCa" min="1" max="100" required type="number" />
                    <span class="absolute inset-y-0 right-0 pr-4 flex items-center text-on-surface-variant text-caption font-semibold">Bệnh nhân</span>
                </div>
                <p class="text-[11px] text-on-surface-variant">Số lượng slot tối đa bệnh nhân có thể đặt trực tuyến cho một khung giờ trực.</p>
            </div>
        </div>
    </div>

    <!-- Card 3: Finance and Pharmacy Alerts -->
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm p-unit-lg">
        <h3 class="font-title-lg text-title-lg text-primary border-b border-outline-variant pb-2 mb-unit-md flex items-center gap-2">
            <span class="material-symbols-outlined">analytics</span>
            Cấu hình Kho thuốc &amp; Tài chính
        </h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-unit-md">
            <div class="space-y-unit-xs">
                <label class="block text-caption font-semibold text-on-surface-variant uppercase">Ngưỡng cảnh báo tồn kho tối thiểu *</label>
                <div class="relative">
                    <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus pr-16" 
                           name="NguongCanhBaoTonKho" value="@Model.NguongCanhBaoTonKho" min="1" required type="number" />
                    <span class="absolute inset-y-0 right-0 pr-4 flex items-center text-on-surface-variant text-caption font-semibold">Đơn vị</span>
                </div>
                <p class="text-[11px] text-on-surface-variant">Khi lượng tồn kho của thuốc dưới ngưỡng này, hệ thống sẽ phát tín hiệu cảnh báo trên Dashboard.</p>
            </div>

            <div class="space-y-unit-xs">
                <label class="block text-caption font-semibold text-on-surface-variant uppercase">Thuế suất hóa đơn mặc định (%) *</label>
                <div class="relative">
                    <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus pr-12" 
                           name="ThueVat" value="@Model.ThueVat" min="0" max="30" required type="number" />
                    <span class="absolute inset-y-0 right-0 pr-4 flex items-center text-on-surface-variant text-caption font-semibold">% VAT</span>
                </div>
                <p class="text-[11px] text-on-surface-variant">Thuế VAT tự động cộng thêm khi xuất hóa đơn khám bệnh và bán thuốc tại quầy.</p>
            </div>

            <div class="md:col-span-2 flex items-center justify-between p-3 bg-surface-container-low/40 border border-outline-variant/60 rounded-lg">
                <div>
                    <span class="font-label-md font-bold text-on-surface flex items-center gap-1">
                        <span class="material-symbols-outlined text-[20px] text-secondary">notifications_active</span>
                        Kích hoạt dịch vụ thông báo tự động (OTP / Nhắc lịch)
                    </span>
                    <p class="text-caption text-on-surface-variant">Tự động gửi email/sms nhắc nhở bệnh nhân khi xác nhận hoặc thay đổi giờ khám.</p>
                </div>
                <label class="inline-flex items-center cursor-pointer">
                    <input type="checkbox" name="BatTatThongBao" value="true" class="sr-only peer" @(Model.BatTatThongBao ? "checked" : "") />
                    <input type="hidden" name="BatTatThongBao" value="false" />
                    <div class="relative w-11 h-6 bg-outline-variant peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-outline-variant after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                </label>
            </div>
        </div>
    </div>

    <!-- Actions -->
    <div class="flex items-center gap-unit-md pt-4">
        <button type="submit" class="bg-primary text-white px-unit-lg py-2.5 rounded-lg font-label-md hover:bg-primary-container transition-colors shadow-sm font-bold flex items-center gap-1">
            <span class="material-symbols-outlined text-[20px]">save</span>
            Lưu cấu hình hệ thống
        </button>
        <a href="/Admin/Dashboard" class="bg-surface-container-high hover:bg-surface-container-highest px-unit-lg py-2.5 rounded-lg font-label-md transition-colors text-on-surface-variant font-semibold">
            Hủy bỏ
        </a>
    </div>
</form>
