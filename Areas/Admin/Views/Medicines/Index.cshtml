@model IEnumerable<QuanLyBenhVien.Models.Medicine>

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Thuốc";

    var medicines = Model.ToList();

    var header = new PageHeaderViewModel
    {
        Title = "Kho dược phẩm",
        Subtitle = "Quản lý danh mục thuốc, định giá và kiểm tra ngưỡng tồn kho tối thiểu.",
        Breadcrumbs = new[] { new BreadcrumbItem("Quản trị", "/Admin/Dashboard") },
        CurrentCrumb = "Thuốc & kho"
    };

    Func<object, IHtmlContent> pageActions = @<text>
        <a href="/Admin/Medicines/Batches" class="hms-btn hms-btn-secondary">
            <span class="material-symbols-outlined">layers</span> Danh sách lô thuốc
        </a>
        <a href="/Admin/Medicines/ReceiveBatch" class="hms-btn hms-btn-primary">
            <span class="material-symbols-outlined">input</span> Nhập kho lô mới
        </a>
    </text>;

    ViewData["PageActions"] = pageActions;
}

<partial name="_PageHeader" model="header" />

<!-- Filters -->
<div class="hms-toolbar">
    <form method="GET" action="/Admin/Medicines" class="hms-toolbar-grid">
        <div style="grid-column: span 2 / span 2;">
            <label class="hms-field-label" for="medicine-search">Tìm kiếm</label>
            <div class="hms-search">
                <span class="material-symbols-outlined">search</span>
                <input id="medicine-search" class="w-full py-2 pr-4 border border-outline-variant rounded-lg font-body-md"
                       name="searchString" value="@ViewBag.SearchString" placeholder="Tên thuốc, hoạt chất..." type="text" />
            </div>
        </div>

        <div class="flex items-center gap-unit-sm">
            <input type="checkbox" id="lowStock" name="lowStock" value="true" class="rounded text-primary focus:ring-primary h-4 w-4" checked="@ViewBag.LowStockOnly" />
            <label for="lowStock" class="font-label-md text-on-surface cursor-pointer select-none">Chỉ hiện thuốc sắp hết kho</label>
        </div>

        <button type="submit" class="hms-btn hms-btn-primary">
            <span class="material-symbols-outlined">filter_list</span> Áp dụng lọc
        </button>
    </form>
</div>

<!-- Medicines Table -->
<div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-surface-container-low text-on-surface-variant font-label-md text-[12px] uppercase">
                    <th class="px-unit-md py-3">Mã Thuốc</th>
                    <th class="px-unit-md py-3">Tên thuốc</th>
                    <th class="px-unit-md py-3">Hoạt chất</th>
                    <th class="px-unit-md py-3">Đơn giá bán</th>
                    <th class="px-unit-md py-3">Số lượng tồn</th>
                    <th class="px-unit-md py-3">Cảnh báo</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="px-unit-md py-8 text-center text-on-surface-variant">Không tìm thấy thuốc nào trong kho.</td>
                    </tr>
                }
                else
                {
                    @foreach (var med in Model)
                    {
                        var isLowStock = med.TonKho <= med.NguongToiThieu;
                        <tr class="hover:bg-surface-container-low transition-colors @(isLowStock ? "bg-error-container/5" : "")">
                            <td class="px-unit-md py-4 font-bold text-primary">MED-@med.Id.ToString("D4")</td>
                            <td class="px-unit-md py-4">
                                <div class="font-body-md font-semibold text-on-surface">@med.TenThuoc</div>
                                <div class="text-caption text-on-surface-variant">Đơn vị: @med.DonViTinh</div>
                            </td>
                            <td class="px-unit-md py-4">
                                <span class="font-body-md text-on-surface-variant">@med.HoatChat</span>
                            </td>
                            <td class="px-unit-md py-4">
                                <span class="font-body-md font-semibold">@med.Gia.ToString("N0") đ</span>
                            </td>
                            <td class="px-unit-md py-4">
                                <div class="font-body-md font-bold @(isLowStock ? "text-error" : "text-on-surface")">
                                    @med.TonKho @med.DonViTinh
                                </div>
                                <div class="text-caption text-on-surface-variant">Ngưỡng tối thiểu: @med.NguongToiThieu</div>
                            </td>
                            <td class="px-unit-md py-4">
                                @if (isLowStock)
                                {
                                    <span class="inline-flex items-center gap-0.5 px-2 py-0.5 rounded-full bg-error-container text-error text-[10px] font-bold uppercase tracking-tight">
                                        <span class="material-symbols-outlined text-[12px]">warning</span> Sắp hết
                                    </span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center gap-0.5 px-2 py-0.5 rounded-full bg-secondary-container/20 text-on-secondary-container text-[10px] font-bold uppercase tracking-tight">
                                        An toàn
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
