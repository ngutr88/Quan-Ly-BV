@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Nhập kho lô thuốc mới";
}

<div class="mb-unit-lg">
    <a href="/Admin/Medicines" class="inline-flex items-center gap-1 text-primary hover:underline text-body-md font-semibold mb-unit-sm">
        <span class="material-symbols-outlined text-[18px]">arrow_back</span> Quay lại kho dược phẩm
    </a>
    <h2 class="font-headline-lg text-headline-lg text-on-surface">Nhập kho Lô thuốc mới</h2>
    <p class="text-body-md text-on-surface-variant">Lập phiếu nhập kho lô thuốc mới, hạn sử dụng và số lượng thực tế.</p>
</div>

<div class="glass-card rounded-xl p-unit-lg shadow-sm max-w-xl">
    <form action="/Admin/Medicines/ReceiveBatch" method="POST" class="space-y-unit-md">
        @Html.AntiForgeryToken()

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="p-unit-md bg-error-container/20 border-l-4 border-error text-error text-body-md rounded-r mb-unit-md">
                @Html.ValidationSummary(true)
            </div>
        }

        <!-- Medicine Select -->
        <div class="space-y-unit-xs">
            <label class="block text-caption font-semibold text-on-surface-variant" for="thuocId">Dược phẩm <span class="text-error">*</span></label>
            <select class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                    id="thuocId" name="thuocId" asp-items="ViewBag.ThuocId" required>
                <option value="">Chọn thuốc nhập kho</option>
            </select>
        </div>

        <!-- Lot Number -->
        <div class="space-y-unit-xs">
            <label class="block text-caption font-semibold text-on-surface-variant" for="soLo">Mã số Lô nhập (Batch/Lot No.) <span class="text-error">*</span></label>
            <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus font-mono" 
                   id="soLo" name="soLo" placeholder="Ví dụ: LOT-PARA-003" required type="text" />
        </div>

        <!-- Expiry Date -->
        <div class="space-y-unit-xs">
            <label class="block text-caption font-semibold text-on-surface-variant" for="hanSuDung">Hạn sử dụng (Expiry Date) <span class="text-error">*</span></label>
            <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                   id="hanSuDung" name="hanSuDung" required type="date" min="@DateTime.Today.ToString("yyyy-MM-dd")" />
        </div>

        <!-- Quantity -->
        <div class="space-y-unit-xs">
            <label class="block text-caption font-semibold text-on-surface-variant" for="soLuongNhap">Số lượng viên / lọ nhập kho <span class="text-error">*</span></label>
            <input class="w-full px-4 py-2.5 bg-surface border border-outline-variant rounded-lg font-body-md input-focus" 
                   id="soLuongNhap" name="soLuongNhap" placeholder="Nhập số lượng thực tế" required min="1" type="number" />
        </div>

        <!-- Actions -->
        <div class="flex items-center gap-unit-md pt-unit-md border-t border-outline-variant mt-unit-lg">
            <button class="bg-primary text-on-primary font-body-lg font-semibold px-unit-lg py-3 rounded-lg hover:bg-primary-container transition-all active:scale-[0.98] shadow-md flex items-center justify-center gap-1" type="submit">
                <span class="material-symbols-outlined text-[20px]">save</span> Lưu phiếu nhập kho
            </button>
            <a href="/Admin/Medicines" class="text-on-surface-variant hover:underline font-label-md">Hủy bỏ</a>
        </div>
    </form>
</div>
