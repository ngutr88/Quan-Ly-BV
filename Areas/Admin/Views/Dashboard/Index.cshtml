@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard tổng quan";
    var recentApps = ViewBag.RecentAppointments as List<QuanLyBenhVien.Models.Appointment> ?? new List<QuanLyBenhVien.Models.Appointment>();
    var lowStockMeds = ViewBag.LowStockMedicines as List<QuanLyBenhVien.Models.Medicine> ?? new List<QuanLyBenhVien.Models.Medicine>();
    var nearExpiryBatches = ViewBag.NearExpiryBatches as List<QuanLyBenhVien.Models.MedicineBatch> ?? new List<QuanLyBenhVien.Models.MedicineBatch>();
    var recentLogs = ViewBag.RecentLogs as List<QuanLyBenhVien.Models.AuditLog> ?? new List<QuanLyBenhVien.Models.AuditLog>();
    var doctorPerf = ViewBag.DoctorPerformance as List<QuanLyBenhVien.Areas.Admin.Controllers.DashboardDoctorPerformanceDto> ?? new List<QuanLyBenhVien.Areas.Admin.Controllers.DashboardDoctorPerformanceDto>();
}

<!-- Dashboard Header & Filters -->
<div class="flex flex-col md:flex-row md:items-end justify-between gap-unit-md mb-unit-lg">
    <div>
        <h2 class="font-headline-lg text-headline-lg text-on-surface font-bold">Bảng điều khiển Admin</h2>
        <p class="text-body-md text-on-surface-variant">Thời gian hệ thống: @DateTime.Now.ToString("dddd, dd MMMM, yyyy • hh:mm tt")</p>
    </div>
    <div class="flex items-center gap-unit-sm">
        <span class="px-3 py-1.5 bg-secondary/15 text-secondary text-label-md rounded-md font-bold flex items-center gap-1">
            <span class="w-2 h-2 rounded-full bg-secondary animate-ping"></span> Live System
        </span>
    </div>
</div>

<!-- KPI Cards Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-unit-md mb-unit-lg">
    <!-- KPI 1: Doctors -->
    <div class="bg-surface-container-lowest border border-outline-variant p-unit-md rounded-xl shadow-sm">
        <div class="flex items-center justify-between mb-unit-sm">
            <span class="text-label-md text-on-surface-variant font-medium">Bác sĩ chuyên khoa</span>
            <div class="w-8 h-8 rounded bg-primary-container/10 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-[20px]">medical_information</span>
            </div>
        </div>
        <div class="flex items-baseline gap-2">
            <span class="text-[28px] font-bold text-on-surface">@ViewBag.DoctorCount</span>
            <span class="text-body-md text-on-surface-variant">/ @ViewBag.DepartmentCount khoa</span>
        </div>
        <div class="mt-unit-sm text-caption text-secondary flex items-center gap-1 font-semibold">
            <span class="material-symbols-outlined text-[14px]">check_circle</span> Đang hoạt động ổn định
        </div>
    </div>

    <!-- KPI 2: Patients -->
    <div class="bg-surface-container-lowest border border-outline-variant p-unit-md rounded-xl shadow-sm">
        <div class="flex items-center justify-between mb-unit-sm">
            <span class="text-label-md text-on-surface-variant font-medium">Sổ Bệnh nhân</span>
            <div class="w-8 h-8 rounded bg-secondary-container/20 flex items-center justify-center text-secondary">
                <span class="material-symbols-outlined text-[20px]">group</span>
            </div>
        </div>
        <div class="flex items-baseline gap-2">
            <span class="text-[28px] font-bold text-on-surface">@ViewBag.PatientCount</span>
            <span class="text-body-md text-secondary font-bold">+@ViewBag.NewPatientsToday mới hôm nay</span>
        </div>
        <div class="w-full bg-surface-container h-1.5 rounded-full mt-unit-sm overflow-hidden">
            <div class="bg-secondary h-full w-[100%]"></div>
        </div>
    </div>

    <!-- KPI 3: Appointments Today -->
    <div class="bg-surface-container-lowest border border-outline-variant p-unit-md rounded-xl shadow-sm">
        <div class="flex items-center justify-between mb-unit-sm">
            <span class="text-label-md text-on-surface-variant font-medium">Lịch khám hôm nay</span>
            <div class="w-8 h-8 rounded bg-tertiary-fixed/30 flex items-center justify-center text-tertiary">
                <span class="material-symbols-outlined text-[20px]">event_note</span>
            </div>
        </div>
        <div class="text-[28px] font-bold text-on-surface mb-unit-xs">@ViewBag.TotalAppointmentsToday <span class="text-body-md font-normal text-on-surface-variant">tổng ca</span></div>
        <div class="grid grid-cols-2 gap-1 text-[11px] font-bold">
            <div class="flex items-center gap-1 text-primary"><div class="w-1.5 h-1.5 rounded-full bg-primary"></div> @ViewBag.PendingAppCount Chờ duyệt</div>
            <div class="flex items-center gap-1 text-secondary"><div class="w-1.5 h-1.5 rounded-full bg-secondary"></div> @ViewBag.CompletedAppCount Đã xong</div>
            <div class="flex items-center gap-1 text-tertiary"><div class="w-1.5 h-1.5 rounded-full bg-tertiary"></div> @ViewBag.ConfirmedAppCount Đã hẹn</div>
            <div class="flex items-center gap-1 text-error"><div class="w-1.5 h-1.5 rounded-full bg-error"></div> @ViewBag.CancelledAppCount Hủy</div>
        </div>
    </div>

    <!-- KPI 4: Revenue -->
    <div class="bg-surface-container-lowest border border-outline-variant p-unit-md rounded-xl shadow-sm">
        <div class="flex items-center justify-between mb-unit-sm">
            <span class="text-label-md text-on-surface-variant font-medium">Doanh thu tài chính</span>
            <div class="w-8 h-8 rounded bg-primary-container/10 flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-[20px]">payments</span>
            </div>
        </div>
        <div class="space-y-1">
            <div class="flex justify-between items-center">
                <span class="text-caption text-on-surface-variant">Hôm nay:</span>
                <span class="text-body-md font-bold text-on-surface">@ViewBag.RevenueToday.ToString("N0") đ</span>
            </div>
            <div class="flex justify-between items-center">
                <span class="text-caption text-on-surface-variant">Tháng này:</span>
                <span class="text-title-lg font-bold text-primary">@ViewBag.RevenueThisMonth.ToString("N0") đ</span>
            </div>
        </div>
    </div>
</div>

<!-- ==================== ANALYTICS & CHARTS SECTION ==================== -->
<div id="reports-section" class="scroll-mt-20 space-y-unit-lg">
    <div class="border-b border-outline-variant pb-3 mb-unit-md">
        <h2 class="font-headline-md text-headline-md text-primary font-bold flex items-center gap-2">
            <span class="material-symbols-outlined text-[28px]">analytics</span>
            Báo cáo &amp; Phân tích hoạt động toàn viện
        </h2>
        <p class="text-body-md text-on-surface-variant">Thống kê vĩ mô, cơ cấu tài chính khoa lâm sàng và xu hướng lịch khám.</p>
    </div>

    <!-- Macro Reports KPI Cards -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-unit-md">
        <!-- Annual Revenue -->
        <div class="bg-surface-container-lowest border border-outline-variant p-unit-md rounded-xl shadow-sm flex items-center gap-unit-md">
            <div class="w-12 h-12 bg-primary/10 rounded-xl flex items-center justify-center text-primary">
                <span class="material-symbols-outlined text-[28px]">payments</span>
            </div>
            <div>
                <p class="text-caption text-on-surface-variant font-semibold uppercase tracking-wider">Doanh thu năm nay</p>
                <h3 class="text-title-lg font-bold text-on-surface mt-0.5">@string.Format("{0:N0} đ", ViewBag.AnnualRevenue)</h3>
            </div>
        </div>

        <!-- Appointment Count -->
        <div class="bg-surface-container-lowest border border-outline-variant p-unit-md rounded-xl shadow-sm flex items-center gap-unit-md">
            <div class="w-12 h-12 bg-secondary/15 rounded-xl flex items-center justify-center text-secondary">
                <span class="material-symbols-outlined text-[28px]">calendar_today</span>
            </div>
            <div>
                <p class="text-caption text-on-surface-variant font-semibold uppercase tracking-wider">Lượt đặt lịch năm nay</p>
                <h3 class="text-title-lg font-bold text-on-surface mt-0.5">@ViewBag.TotalAppointmentsThisYear ca</h3>
            </div>
        </div>

        <!-- Success Rate -->
        <div class="bg-surface-container-lowest border border-outline-variant p-unit-md rounded-xl shadow-sm flex items-center gap-unit-md">
            <div class="w-12 h-12 bg-tertiary/10 rounded-xl flex items-center justify-center text-tertiary">
                <span class="material-symbols-outlined text-[28px]">check_circle</span>
            </div>
            <div>
                <p class="text-caption text-on-surface-variant font-semibold uppercase tracking-wider">Tỷ lệ khám thành công</p>
                <h3 class="text-title-lg font-bold text-on-surface mt-0.5">@string.Format("{0:F1}%", ViewBag.CompletionRate)</h3>
            </div>
        </div>
    </div>

    <!-- Charts Hub Row 1: Weekly Trends & Today's distribution -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-unit-lg">
        <!-- Chart 1: Daily appointments & revenue (2/3 cols) -->
        <div class="lg:col-span-2 bg-white border border-outline-variant p-unit-md rounded-xl shadow-sm">
            <h3 class="font-title-lg text-title-lg text-on-surface mb-unit-md flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">show_chart</span>
                Xu hướng hoạt động &amp; Doanh thu 7 ngày qua
            </h3>
            <div class="relative w-full h-80">
                <canvas id="trendsChart"></canvas>
            </div>
        </div>

        <!-- Chart 2: Today's appointment status (1/3 cols) -->
        <div class="bg-white border border-outline-variant p-unit-md rounded-xl shadow-sm flex flex-col">
            <h3 class="font-title-lg text-title-lg text-on-surface mb-unit-md flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">pie_chart</span>
                Phân bổ lịch khám hôm nay
            </h3>
            @{
                var todayTotal = (int)(ViewBag.TotalAppointmentsToday ?? 0);
            }
            @* Chart.js paints nothing when every slice is zero, so on a day with
               no appointments the card looked like a chart had failed to load.
               Say so explicitly instead of leaving an empty box. *@
            <div class="relative w-full flex-grow flex items-center justify-center h-64">
                <canvas id="statusChart" class="@(todayTotal == 0 ? "hidden" : "")"></canvas>
                @if (todayTotal == 0)
                {
                    <div class="flex flex-col items-center justify-center text-center px-4">
                        <span class="material-symbols-outlined text-[44px] text-outline mb-1">event_busy</span>
                        <p class="text-body-md font-semibold text-on-surface-variant">Hôm nay chưa có lịch khám nào</p>
                        <p class="text-caption text-outline mt-0.5">Biểu đồ sẽ hiển thị khi có lịch khám trong ngày.</p>
                    </div>
                }
            </div>
            @if (todayTotal > 0)
            {
                <div class="grid grid-cols-2 gap-2 mt-unit-sm pt-unit-sm border-t border-outline-variant/60">
                    <p class="text-caption text-on-surface-variant flex items-center justify-between">
                        <span>Chờ duyệt</span><strong class="text-on-surface">@ViewBag.PendingAppCount</strong>
                    </p>
                    <p class="text-caption text-on-surface-variant flex items-center justify-between">
                        <span>Đã hẹn</span><strong class="text-on-surface">@ViewBag.ConfirmedAppCount</strong>
                    </p>
                    <p class="text-caption text-on-surface-variant flex items-center justify-between">
                        <span>Hoàn thành</span><strong class="text-on-surface">@ViewBag.CompletedAppCount</strong>
                    </p>
                    <p class="text-caption text-on-surface-variant flex items-center justify-between">
                        <span>Đã hủy</span><strong class="text-on-surface">@ViewBag.CancelledAppCount</strong>
                    </p>
                </div>
            }
        </div>
    </div>

    <!-- Charts Hub Row 2: Annual Monthly Revenue & Dept Revenue Breakdown -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-unit-lg">
        <!-- Chart 3: Line monthly revenue -->
        <div class="lg:col-span-2 bg-white border border-outline-variant p-unit-md rounded-xl shadow-sm">
            <h3 class="font-title-lg text-title-lg text-on-surface mb-unit-md flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">analytics</span>
                Biểu đồ Doanh thu 12 tháng năm nay (VNĐ)
            </h3>
            <div class="relative w-full h-80">
                <canvas id="monthlyRevenueChart"></canvas>
            </div>
        </div>

        <!-- Chart 4: Dept Revenue doughnut -->
        <div class="bg-white border border-outline-variant p-unit-md rounded-xl shadow-sm flex flex-col">
            <h3 class="font-title-lg text-title-lg text-on-surface mb-unit-md flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">donut_large</span>
                Cơ cấu Doanh thu theo Khoa
            </h3>
            <div class="relative w-full flex-grow flex items-center justify-center h-64">
                <canvas id="deptRevenueChart"></canvas>
            </div>
        </div>
    </div>

    <!-- Charts Hub Row 3: Dept appointments & Top Doctors performance table -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-unit-lg">
        <!-- Chart 5: Appointments by Dept -->
        <div class="bg-white border border-outline-variant p-unit-md rounded-xl shadow-sm">
            <h3 class="font-title-lg text-title-lg text-on-surface mb-unit-md flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">bar_chart</span>
                Số ca khám bệnh theo Khoa
            </h3>
            <div class="relative w-full h-80">
                <canvas id="deptAppChart"></canvas>
            </div>
        </div>

        <!-- Table 3: Top doctors -->
        <div class="bg-white border border-outline-variant p-unit-md rounded-xl shadow-sm flex flex-col">
            <h3 class="font-title-lg text-title-lg text-on-surface mb-unit-md flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">star</span>
                Top 5 Bác sĩ năng suất cao nhất (Ca đã khám xong)
            </h3>
            <div class="overflow-x-auto flex-grow">
                <table class="w-full text-left mt-2">
                    <thead>
                        <tr class="bg-surface-container-low text-on-surface-variant font-label-md text-[11px] uppercase border-b border-outline-variant">
                            <th class="px-3 py-2.5">Bác sĩ</th>
                            <th class="px-3 py-2.5">Khoa công tác</th>
                            <th class="px-3 py-2.5 text-right">Số ca hoàn thành</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant">
                        @if (!doctorPerf.Any())
                        {
                            <tr>
                                <td colspan="3" class="px-3 py-6 text-center text-on-surface-variant text-body-md">Chưa ghi nhận ca khám hoàn thành nào.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var doc in doctorPerf)
                            {
                                <tr class="hover:bg-surface-container-low transition-colors">
                                    <td class="px-3 py-3 font-body-md font-semibold text-on-surface">@doc.DoctorName</td>
                                    <td class="px-3 py-3 text-body-md text-on-surface-variant">@doc.Department</td>
                                    <td class="px-3 py-3 text-body-md font-bold text-primary text-right">@doc.CompletedCount ca</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<hr class="border-outline-variant my-unit-xl" />

<!-- ==================== OPERATIONS & ACTION CENTER ==================== -->
<div>
    <div class="border-b border-outline-variant pb-3 mb-unit-md">
        <h2 class="font-headline-md text-headline-md text-primary font-bold flex items-center gap-2">
            <span class="material-symbols-outlined text-[28px]">monitoring</span>
            Giám sát vận hành &amp; Danh sách trực tiếp
        </h2>
        <p class="text-body-md text-on-surface-variant">Xem nhanh các lượt đăng ký khám gần nhất và cảnh báo kho dược.</p>
    </div>

    <div class="grid grid-cols-12 gap-unit-lg">
        <!-- Live Appointments Table (8 cols) -->
        <div class="col-span-12 lg:col-span-8 bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm flex flex-col">
            <div class="p-unit-md border-b border-outline-variant flex items-center justify-between bg-surface-container-low/30">
                <h3 class="font-title-md text-body-lg font-bold flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">patient_list</span>
                    Danh sách lịch khám gần đây
                </h3>
                <a class="text-label-md text-primary font-bold hover:underline" href="/Admin/Appointments">Quản lý lịch khám</a>
            </div>
            <div class="overflow-x-auto flex-grow">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-surface-container-low text-on-surface-variant font-label-md text-[12px] uppercase">
                            <th class="px-unit-md py-3">Thời gian</th>
                            <th class="px-unit-md py-3">Bệnh nhân</th>
                            <th class="px-unit-md py-3">Bác sĩ</th>
                            <th class="px-unit-md py-3">Khoa</th>
                            <th class="px-unit-md py-3">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant">
                        @if (!recentApps.Any())
                        {
                            <tr>
                                <td colspan="5" class="px-unit-md py-8 text-center text-on-surface-variant">Không có lịch khám nào trong hệ thống.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var app in recentApps)
                            {
                                <tr class="hover:bg-surface-container-low transition-colors cursor-pointer" onclick="location.href='/Admin/Appointments/Details/@app.Id'">
                                    <td class="px-unit-md py-4 font-bold text-primary">@app.ThoiGian.ToString("dd/MM HH:mm")</td>
                                    <td class="px-unit-md py-4">
                                        <div class="font-body-md font-medium text-on-surface">@app.Patient.User.HoTen</div>
                                        <div class="text-caption text-on-surface-variant font-medium">BN-@app.Patient.Id.ToString("D4") • @app.Patient.User.Sdt</div>
                                    </td>
                                    <td class="px-unit-md py-4">@(app.Doctor != null ? app.Doctor.User.HoTen : "Chưa phân bổ")</td>
                                    <td class="px-unit-md py-4">@(app.Doctor != null ? app.Doctor.Department.TenKhoa : "N/A")</td>
                                    <td class="px-unit-md py-4 whitespace-nowrap">
                                        @if (app.TrangThai == "ChoXacNhan")
                                        {
                                            <span class="px-2 py-1 rounded-full bg-primary-container/20 text-primary-fixed-dim text-[11px] font-bold">Chờ duyệt</span>
                                        }
                                        else if (app.TrangThai == "DaXacNhan")
                                        {
                                            <span class="px-2 py-1 rounded-full bg-tertiary-fixed/30 text-on-tertiary-fixed-variant text-[11px] font-bold">Đã hẹn</span>
                                        }
                                        else if (app.TrangThai == "DangKham")
                                        {
                                            <span class="px-2 py-1 rounded-full bg-secondary-container/20 text-on-secondary-container text-[11px] font-bold">Đang khám</span>
                                        }
                                        else if (app.TrangThai == "HoanThanh")
                                        {
                                            <span class="px-2 py-1 rounded-full bg-secondary/20 text-secondary text-[11px] font-bold">Hoàn thành</span>
                                        }
                                        else
                                        {
                                            <span class="px-2 py-1 rounded-full bg-error-container text-error text-[11px] font-bold">Đã hủy</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Operational Alerts (4 cols) -->
        <div class="col-span-12 lg:col-span-4 bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm flex flex-col">
            <div class="p-unit-md border-b border-outline-variant flex items-center gap-2">
                <span class="material-symbols-outlined text-error">warning</span>
                <h3 class="font-title-md text-body-lg font-bold">Cảnh báo dược &amp; vận hành</h3>
            </div>
            <div class="p-unit-md flex-grow space-y-unit-sm">
                <!-- Low stock medicines alert -->
                @if (lowStockMeds.Any())
                {
                    <div class="flex items-start gap-unit-md p-3 bg-error-container/5 rounded-lg border border-error/10">
                        <span class="material-symbols-outlined text-error mt-0.5">inventory_2</span>
                        <div class="flex-grow">
                            <p class="font-label-md text-on-surface font-semibold">Thuốc sắp hết kho (@lowStockMeds.Count mục)</p>
                            <div class="text-caption text-on-surface-variant mt-1 space-y-0.5">
                                @foreach (var med in lowStockMeds)
                                {
                                    <div>• @med.TenThuoc: Còn <strong>@med.TonKho</strong> @med.DonViTinh (Ngưỡng: @med.NguongToiThieu)</div>
                                }
                            </div>
                            <a href="/Admin/Medicines" class="mt-2 inline-block text-[11px] font-bold text-error uppercase hover:underline">Nhập kho thuốc</a>
                        </div>
                    </div>
                }

                <!-- Near expiry batches alert -->
                @if (nearExpiryBatches.Any())
                {
                    <div class="flex items-start gap-unit-md p-3 bg-tertiary-fixed/5 rounded-lg border border-tertiary/10">
                        <span class="material-symbols-outlined text-tertiary mt-0.5">pending_actions</span>
                        <div class="flex-grow">
                            <p class="font-label-md text-on-surface font-semibold">Lô thuốc sắp hết hạn (@nearExpiryBatches.Count lô)</p>
                            <div class="text-caption text-on-surface-variant mt-1 space-y-0.5">
                                @foreach (var batch in nearExpiryBatches)
                                {
                                    <div>• Lô: <strong>@batch.SoLo</strong> (@batch.Medicine.TenThuoc) - HSD: <strong>@batch.HanSuDung.ToString("dd/MM/yyyy")</strong> (Còn @((batch.HanSuDung - DateTime.Today).Days) ngày)</div>
                                }
                            </div>
                            <a href="/Admin/Medicines/Batches" class="mt-2 inline-block text-[11px] font-bold text-tertiary uppercase hover:underline">Quản lý lô thuốc</a>
                        </div>
                    </div>
                }

                @if (!lowStockMeds.Any() && !nearExpiryBatches.Any())
                {
                    <div class="h-full flex flex-col items-center justify-center text-center text-on-surface-variant p-unit-md py-12">
                        <span class="material-symbols-outlined text-[48px] text-secondary">verified_user</span>
                        <p class="mt-2 font-label-md">Không có cảnh báo kho dược.</p>
                        <p class="text-caption">Tất cả thuốc ở mức an toàn và còn hạn dài.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Retrieve data from ViewBag
            const labels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartLabels));
            const appointmentData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.ChartData));
            const revenueData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RevenueChartData));

            const pending = @ViewBag.PendingAppCount;
            const confirmed = @ViewBag.ConfirmedAppCount;
            const completed = @ViewBag.CompletedAppCount;
            const cancelled = @ViewBag.CancelledAppCount;

            // 1. Trends Chart (Mixed Bar & Line)
            const ctxTrends = document.getElementById('trendsChart').getContext('2d');
            new Chart(ctxTrends, {
                type: 'bar',
                data: {
                    labels: labels,
                    datasets: [
                        {
                            label: 'Lượt khám (ca)',
                            data: appointmentData,
                            backgroundColor: 'rgba(0, 63, 135, 0.75)',
                            borderColor: '#003f87',
                            borderWidth: 1,
                            yAxisID: 'yApp',
                            order: 2,
                            borderRadius: 6
                        },
                        {
                            label: 'Doanh thu (VNĐ)',
                            data: revenueData,
                            type: 'line',
                            borderColor: '#006c49',
                            backgroundColor: 'rgba(0, 108, 73, 0.1)',
                            borderWidth: 3,
                            pointBackgroundColor: '#006c49',
                            pointHoverRadius: 7,
                            tension: 0.35,
                            fill: true,
                            yAxisID: 'yRevenue',
                            order: 1
                        }
                    ]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'top',
                            labels: {
                                font: {
                                    family: 'Inter, system-ui, sans-serif',
                                    size: 12
                                }
                            }
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    let label = context.dataset.label || '';
                                    if (label) {
                                        label += ': ';
                                    }
                                    if (context.dataset.type === 'line') {
                                        label += new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(context.raw);
                                    } else {
                                        label += context.raw + ' ca';
                                    }
                                    return label;
                                }
                            }
                        }
                    },
                    scales: {
                        yApp: {
                            type: 'linear',
                            position: 'left',
                            title: {
                                display: true,
                                text: 'Lượt khám (ca)'
                            },
                            grid: {
                                drawOnChartArea: false
                            },
                            ticks: {
                                stepSize: 1
                            }
                        },
                        yRevenue: {
                            type: 'linear',
                            position: 'right',
                            title: {
                                display: true,
                                text: 'Doanh thu (VNĐ)'
                            },
                            ticks: {
                                callback: function(value) {
                                    return (value / 1000).toLocaleString() + 'k';
                                }
                            }
                        }
                    }
                }
            });

            // 2. Status Chart (Doughnut) — skipped on days with no appointments,
            // where the card shows an empty state instead of a blank canvas.
            const statusCanvas = document.getElementById('statusChart');
            const statusTotal = pending + confirmed + completed + cancelled;
            if (statusCanvas && statusTotal > 0) {
            const ctxStatus = statusCanvas.getContext('2d');
            new Chart(ctxStatus, {
                type: 'doughnut',
                data: {
                    labels: ['Chờ duyệt', 'Đã hẹn', 'Hoàn thành', 'Đã hủy'],
                    datasets: [{
                        data: [pending, confirmed, completed, cancelled],
                        backgroundColor: [
                            '#003f87', // Primary Blue
                            '#f59e0b', // Amber
                            '#10b981', // Emerald
                            '#ef4444'  // Red
                        ],
                        borderWidth: 2,
                        borderColor: '#ffffff',
                        hoverOffset: 6
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: {
                                font: {
                                    family: 'Inter, system-ui, sans-serif',
                                    size: 11
                                },
                                boxWidth: 12
                              }
                        }
                    },
                    cutout: '65%'
                }
            });
            }

            // 3. Monthly Revenue Chart (Line)
            const ctxMonthly = document.getElementById('monthlyRevenueChart').getContext('2d');
            const monthlyLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.MonthlyRevenueLabels));
            const monthlyData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.MonthlyRevenueData));

            new Chart(ctxMonthly, {
                type: 'line',
                data: {
                    labels: monthlyLabels,
                    datasets: [{
                        label: 'Doanh thu hàng tháng',
                        data: monthlyData,
                        borderColor: '#003f87',
                        backgroundColor: 'rgba(0, 63, 135, 0.05)',
                        borderWidth: 3,
                        pointBackgroundColor: '#003f87',
                        pointHoverRadius: 7,
                        tension: 0.3,
                        fill: true
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        y: {
                            ticks: {
                                callback: function(value) {
                                    return (value / 1000000).toLocaleString() + 'M đ';
                                }
                            }
                        }
                    }
                }
            });

            // 4. Department Revenue Chart (Doughnut)
            const ctxDeptRev = document.getElementById('deptRevenueChart').getContext('2d');
            const deptRevLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RevenueByDeptLabels));
            const deptRevData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.RevenueByDeptData));

            new Chart(ctxDeptRev, {
                type: 'doughnut',
                data: {
                    labels: deptRevLabels,
                    datasets: [{
                        data: deptRevData,
                        backgroundColor: [
                            '#003f87', '#006c49', '#e09f00', '#ba1a1a', '#008080', '#5c3a21', '#4b0082'
                        ],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: {
                            position: 'bottom',
                            labels: { boxWidth: 10, font: { size: 10 } }
                        }
                    }
                }
            });

            // 5. Department Appointment Chart (Horizontal Bar)
            const ctxDeptApp = document.getElementById('deptAppChart').getContext('2d');
            const deptAppLabels = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AppByDeptLabels));
            const deptAppData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AppByDeptData));

            new Chart(ctxDeptApp, {
                type: 'bar',
                data: {
                    labels: deptAppLabels,
                    datasets: [{
                        label: 'Số ca khám',
                        data: deptAppData,
                        backgroundColor: 'rgba(0, 108, 73, 0.75)',
                        borderColor: '#006c49',
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    indexAxis: 'y',
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { display: false }
                    },
                    scales: {
                        x: {
                            ticks: { stepSize: 1 }
                        }
                    }
                }
            });
        });
    </script>
}
