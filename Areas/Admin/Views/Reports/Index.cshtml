@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Báo cáo - Thống kê";
}

<div class="mb-unit-lg">
    <h2 class="font-headline-lg text-headline-lg text-on-surface">Báo cáo &amp; Thống kê</h2>
    <p class="text-body-md text-on-surface-variant">Tổng hợp hoạt động khám chữa bệnh, doanh thu và vận hành bệnh viện.</p>
</div>

<div class="grid grid-cols-1 md:grid-cols-3 gap-unit-md mb-unit-lg">
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-unit-lg shadow-sm">
        <p class="text-caption text-on-surface-variant font-semibold uppercase">Lịch khám hôm nay</p>
        <p class="mt-2 text-headline-lg font-bold text-primary">Xem trên Dashboard</p>
        <a class="mt-4 inline-flex items-center gap-1 text-label-md text-primary font-semibold" href="/Admin/Dashboard#reports-section">Mở tổng quan <span class="material-symbols-outlined text-[18px]">arrow_forward</span></a>
    </div>
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-unit-lg shadow-sm">
        <p class="text-caption text-on-surface-variant font-semibold uppercase">Doanh thu</p>
        <p class="mt-2 text-body-md text-on-surface-variant">Dữ liệu được tổng hợp từ module hóa đơn.</p>
        <a class="mt-4 inline-flex items-center gap-1 text-label-md text-primary font-semibold" href="/Admin/Invoices">Xem hóa đơn <span class="material-symbols-outlined text-[18px]">arrow_forward</span></a>
    </div>
    <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-unit-lg shadow-sm">
        <p class="text-caption text-on-surface-variant font-semibold uppercase">Báo cáo chi tiết</p>
        <p class="mt-2 text-body-md text-on-surface-variant">Bộ lọc, biểu đồ và xuất PDF/Excel sẽ được bổ sung theo PRD.</p>
    </div>
</div>

<div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-unit-lg shadow-sm">
    <div class="flex items-start gap-unit-md">
        <span class="material-symbols-outlined text-primary">info</span>
        <div>
            <h3 class="font-headline-sm text-headline-sm text-on-surface">Phạm vi hiện tại</h3>
            <p class="mt-1 text-body-md text-on-surface-variant">Trang báo cáo đã có route và giao diện riêng. Số liệu chi tiết cần được nối vào query/service báo cáo trước khi coi là hoàn thiện nghiệp vụ.</p>
        </div>
    </div>
</div>
