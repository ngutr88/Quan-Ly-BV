@model QuanLyBenhVien.Helpers.PagedList<QuanLyBenhVien.Models.Doctor>
@using Microsoft.AspNetCore.Html
@using QuanLyBenhVien.Models.ViewModels

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Quản lý Bác sĩ";

    var doctors = Model.Items;
    var totalMatching = (int)(ViewBag.TotalMatching ?? 0);
    var activeDoctors = (int)(ViewBag.ActiveDoctors ?? 0);
    var departmentCount = (int)(ViewBag.DepartmentCount ?? 0);
    var leadCount = (int)(ViewBag.LeadCount ?? 0);

    var filters = new Dictionary<string, string>
    {
        ["searchString"] = ViewBag.SearchString as string,
        ["departmentId"] = (ViewBag.DepartmentId as int?)?.ToString()
    };
    var exportQuery = string.Join("&", filters
        .Where(kv => !string.IsNullOrEmpty(kv.Value))
        .Select(kv => $"{kv.Key}={Uri.EscapeDataString(kv.Value)}"));

    var header = new PageHeaderViewModel
    {
        Title = "Đội ngũ bác sĩ",
        Subtitle = "Quản lý hồ sơ chuyên môn, khoa công tác và trạng thái hành nghề của bác sĩ toàn bệnh viện.",
        Breadcrumbs = new[] { new BreadcrumbItem("Quản trị", "/Admin/Dashboard") },
        CurrentCrumb = "Bác sĩ"
    };

    Func<object, IHtmlContent> pageActions = @<text>
        <a href="/Admin/Doctors/Export@(string.IsNullOrEmpty(exportQuery) ? "" : "?" + exportQuery)" class="hms-btn hms-btn-secondary">
            <span class="material-symbols-outlined">download</span> Xuất Excel
        </a>
        <a href="/Admin/Doctors/Create" class="hms-btn hms-btn-primary">
            <span class="material-symbols-outlined">person_add</span> Thêm bác sĩ mới
        </a>
    </text>;

    ViewData["PageActions"] = pageActions;
}

<partial name="_PageHeader" model="header" />

<div class="hms-stat-grid">
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-primary"><span class="material-symbols-outlined">stethoscope</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Bác sĩ khớp lọc</p>
            <p class="hms-stat-value">@totalMatching.ToString("N0")</p>
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-success"><span class="material-symbols-outlined">verified_user</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Đang hành nghề</p>
            <p class="hms-stat-value">@activeDoctors</p>
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-warn"><span class="material-symbols-outlined">account_tree</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Khoa có nhân sự</p>
            <p class="hms-stat-value">@departmentCount</p>
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-primary"><span class="material-symbols-outlined">workspace_premium</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Trưởng / phó khoa</p>
            <p class="hms-stat-value">@leadCount</p>
        </div>
    </div>
</div>

<!-- Filters -->
<div class="hms-toolbar">
    <form method="GET" action="/Admin/Doctors" class="hms-toolbar-grid">
        <div style="grid-column: span 2 / span 2;">
            <label class="hms-field-label" for="doctor-search">Tìm kiếm</label>
            <div class="hms-search">
                <span class="material-symbols-outlined">search</span>
                <input id="doctor-search" name="searchString" value="@ViewBag.SearchString" type="text"
                       class="w-full py-2 pr-4 border border-outline-variant rounded-lg font-body-md"
                       placeholder="Tên bác sĩ, chuyên khoa..." />
            </div>
        </div>
        <div>
            <label class="hms-field-label" for="doctor-department">Khoa công tác</label>
            <select id="doctor-department" class="w-full py-2 px-3 border border-outline-variant rounded-lg font-body-md"
                    name="departmentId" asp-items="ViewBag.Departments">
                <option value="">Tất cả chuyên khoa</option>
            </select>
        </div>
        <div>
            <button type="submit" class="hms-btn hms-btn-primary">
                <span class="material-symbols-outlined">filter_list</span> Áp dụng lọc
            </button>
        </div>
    </form>
</div>

<!-- Doctors Table -->
<div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm">
    <div class="hms-table-scroll overflow-x-auto" role="region" aria-label="Danh sách bác sĩ" tabindex="0">
        <table class="w-full text-left">
            <thead>
                <tr class="bg-surface-container-low text-on-surface-variant font-label-md text-[12px] uppercase">
                    <th class="px-unit-md py-3">Mã BS</th>
                    <th class="px-unit-md py-3">Bác sĩ</th>
                    <th class="px-unit-md py-3">Khoa công tác</th>
                    <th class="px-unit-md py-3">Chuyên môn</th>
                    <th class="px-unit-md py-3 whitespace-nowrap">Trạng thái</th>
                    <th class="px-unit-md py-3 text-right whitespace-nowrap">Thao tác</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @if (doctors.Count == 0)
                {
                    <tr>
                        <td colspan="6">
                            <div class="hms-empty">
                                <div class="hms-empty-icon"><span class="material-symbols-outlined">stethoscope</span></div>
                                <p class="hms-empty-title">Không tìm thấy bác sĩ nào phù hợp</p>
                                <p class="hms-empty-text">Thử đổi từ khóa tìm kiếm hoặc chọn "Tất cả chuyên khoa" để xem toàn bộ đội ngũ.</p>
                            </div>
                        </td>
                    </tr>
                }
                else
                {
                    @foreach (var doc in doctors)
                    {
                        <tr class="hover:bg-surface-container-low transition-colors group">
                            <td class="px-unit-md py-4 font-bold text-primary">BS-@doc.Id.ToString("D3")</td>
                            <td class="px-unit-md py-4">
                                <div class="font-body-md font-semibold text-on-surface flex items-center gap-2">
                                    @doc.User.HoTen
                                    @if (doc.ChucVu == "Trưởng khoa")
                                    {
                                        <span class="px-1.5 py-0.5 bg-primary/10 text-primary text-[10px] font-bold rounded">Trưởng khoa</span>
                                    }
                                    else if (doc.ChucVu == "Phó trưởng khoa")
                                    {
                                        <span class="px-1.5 py-0.5 bg-primary/10 text-primary text-[10px] font-bold rounded">Phó khoa</span>
                                    }
                                </div>
                                <div class="text-caption text-on-surface-variant">@doc.User.Email • @doc.User.Sdt</div>
                            </td>
                            <td class="px-unit-md py-4">
                                <div class="font-body-md">@doc.Department.TenKhoa</div>
                                <div class="text-caption text-on-surface-variant">@doc.Department.ViTri</div>
                            </td>
                            <td class="px-unit-md py-4">
                                <div class="font-body-md font-medium">@doc.HocVi</div>
                                <div class="text-caption text-on-surface-variant">@doc.ChuyenKhoa (@doc.SoNamKinhNghiem năm KN)</div>
                            </td>
                            <td class="px-unit-md py-4 whitespace-nowrap">
                                @if (doc.User.TrangThai == "Active")
                                {
                                    <span class="hms-badge hms-badge-ok">
                                        <span class="material-symbols-outlined">check_circle</span> Hoạt động
                                    </span>
                                }
                                else
                                {
                                    <span class="hms-badge hms-badge-danger">
                                        <span class="material-symbols-outlined">block</span> Đã khóa
                                    </span>
                                }
                            </td>
                            <td class="px-unit-md py-4 text-right">
                                <div class="flex items-center justify-end gap-1">
                                    <a href="/Admin/Doctors/Details/@doc.Id" class="hms-icon-btn" title="Xem chi tiết">
                                        <span class="material-symbols-outlined">visibility</span>
                                    </a>
                                    <a href="/Admin/Doctors/Edit/@doc.Id" class="hms-icon-btn" title="Chỉnh sửa">
                                        <span class="material-symbols-outlined">edit</span>
                                    </a>
                                    <form method="POST" action="/Admin/Doctors/ToggleStatus/@doc.Id" class="inline" onsubmit="return confirm('Bạn có chắc muốn thay đổi trạng thái của bác sĩ này?')">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="hms-icon-btn @(doc.User.TrangThai == "Active" ? "hms-icon-btn-danger" : "")" title="@(doc.User.TrangThai == "Active" ? "Khóa tài khoản" : "Mở khóa tài khoản")">
                                            <span class="material-symbols-outlined">@(doc.User.TrangThai == "Active" ? "lock" : "lock_open")</span>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    @if (doctors.Count > 0)
    {
        <partial name="_Pagination" model='PaginationViewModel.From(Model, "/Admin/Doctors", "bác sĩ", filters)' />
    }
</div>
