@model QuanLyBenhVien.Models.Doctor

@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Chi tiết Bác sĩ";
    var appointments = ViewBag.Appointments as List<QuanLyBenhVien.Models.Appointment> ?? new List<QuanLyBenhVien.Models.Appointment>();
    var reviews = ViewBag.Reviews as List<QuanLyBenhVien.Models.Review> ?? new List<QuanLyBenhVien.Models.Review>();
    double avgRating = ViewBag.AverageRating;
}

<div class="mb-unit-lg flex flex-col md:flex-row justify-between items-start md:items-end gap-unit-sm">
    <div>
        <a href="/Admin/Doctors" class="inline-flex items-center gap-1 text-primary hover:underline text-body-md font-semibold mb-unit-sm">
            <span class="material-symbols-outlined text-[18px]">arrow_back</span> Quay lại danh sách bác sĩ
        </a>
        <h2 class="font-headline-lg text-headline-lg text-on-surface">@Model.HocVi @Model.User.HoTen</h2>
        <p class="text-body-md text-on-surface-variant">Chi tiết hồ sơ chuyên môn và lịch sử khám chữa bệnh.</p>
    </div>
    <div class="flex gap-unit-sm">
        <a href="/Admin/Doctors/Edit/@Model.Id" class="flex items-center gap-1 bg-surface-container-high hover:bg-surface-container-highest px-unit-md py-2 rounded-lg font-label-md transition-colors text-on-surface font-semibold border border-outline-variant">
            <span class="material-symbols-outlined text-[18px]">edit</span> Chỉnh sửa hồ sơ
        </a>
    </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-unit-lg">
    <!-- Profile Card (1 col) -->
    <div class="space-y-unit-lg">
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-unit-lg shadow-sm text-center">
            <div class="w-24 h-24 rounded-full overflow-hidden bg-primary-fixed flex items-center justify-center text-primary font-bold text-[36px] mx-auto mb-unit-md border-4 border-surface-container">
                @(string.IsNullOrWhiteSpace(Model.User.HoTen) ? "BS" : Model.User.HoTen.Trim().Split(' ').Last().Substring(0, 1).ToUpper())
            </div>
            <h3 class="font-title-lg text-on-surface">@Model.HocVi. @Model.User.HoTen</h3>
            <p class="text-caption text-on-surface-variant font-medium mt-unit-xs">@Model.ChuyenKhoa</p>
            <div class="mt-2 flex items-center justify-center gap-1.5">
                @if (Model.ChucVu == "Trưởng khoa")
                {
                    <span class="px-2.5 py-1 bg-primary text-white text-[12px] font-bold rounded-full">Trưởng khoa</span>
                }
                else if (Model.ChucVu == "Phó trưởng khoa")
                {
                    <span class="px-2.5 py-1 bg-primary/10 text-primary text-[12px] font-bold rounded-full">Phó trưởng khoa</span>
                }
                else
                {
                    <span class="px-2.5 py-1 bg-surface-container-high text-on-surface-variant text-[12px] font-bold rounded-full">Bác sĩ điều trị</span>
                }
            </div>
            
            <div class="flex items-center justify-center gap-1 text-secondary mt-unit-sm">
                <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'FILL' 1;">star</span>
                <span class="font-bold">@avgRating.ToString("F1")</span>
                <span class="text-caption text-on-surface-variant">(@reviews.Count đánh giá)</span>
            </div>

            <div class="border-t border-outline-variant my-unit-lg pt-unit-lg text-left space-y-unit-sm">
                <div>
                    <span class="text-caption text-on-surface-variant block">Địa chỉ Email</span>
                    <span class="font-body-md font-medium text-on-surface">@Model.User.Email</span>
                </div>
                <div>
                    <span class="text-caption text-on-surface-variant block">Số điện thoại</span>
                    <span class="font-body-md font-medium text-on-surface">@Model.User.Sdt</span>
                </div>
                <div>
                    <span class="text-caption text-on-surface-variant block">Trạng thái tài khoản</span>
                    @if (Model.User.TrangThai == "Active")
                    {
                        <span class="inline-block mt-0.5 px-2.5 py-0.5 rounded-full bg-secondary-container/20 text-on-secondary-container text-[11px] font-bold">Hoạt động</span>
                    }
                    else
                    {
                        <span class="inline-block mt-0.5 px-2.5 py-0.5 rounded-full bg-error-container text-error text-[11px] font-bold">Tài khoản Khóa</span>
                    }
                </div>
            </div>
        </div>

        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-unit-lg shadow-sm">
            <h4 class="font-label-md text-on-surface uppercase tracking-wider mb-unit-md font-bold text-primary">Thông tin chuyên môn</h4>
            <div class="space-y-unit-md">
                <div>
                    <span class="text-caption text-on-surface-variant block">Khoa công tác</span>
                    <span class="font-body-md font-semibold">@Model.Department.TenKhoa</span>
                    <p class="text-caption text-on-surface-variant">@Model.Department.ViTri</p>
                </div>
                <div>
                    <span class="text-caption text-on-surface-variant block">Số năm kinh nghiệm</span>
                    <span class="font-body-md font-medium text-on-surface">@Model.SoNamKinhNghiem năm kinh nghiệm khám lâm sàng</span>
                </div>
                <div>
                    <span class="text-caption text-on-surface-variant block">Lịch làm việc cố định</span>
                    <span class="font-body-md text-on-surface">@Model.LichLamViec</span>
                </div>
            </div>
        </div>
    </div>

    <!-- History & Feedback (2 cols) -->
    <div class="lg:col-span-2 space-y-unit-lg">
        <!-- Recent Appointments -->
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl overflow-hidden shadow-sm flex flex-col">
            <div class="p-unit-md border-b border-outline-variant bg-surface-container-low/30">
                <h3 class="font-title-lg text-title-lg">Lượt khám phụ trách gần đây</h3>
            </div>
            <div class="hms-table-scroll overflow-x-auto" role="region" aria-label="Lượt khám gần đây của bác sĩ" tabindex="0">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-surface-container-low text-on-surface-variant font-label-md text-[12px] uppercase">
                            <th class="px-unit-md py-3">Thời gian</th>
                            <th class="px-unit-md py-3">Bệnh nhân</th>
                            <th class="px-unit-md py-3">Lý do khám</th>
                            <th class="px-unit-md py-3">Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-outline-variant">
                        @if (!appointments.Any())
                        {
                            <tr>
                                <td colspan="4" class="px-unit-md py-6 text-center text-on-surface-variant">Chưa có lịch sử khám chữa bệnh nào.</td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var app in appointments)
                            {
                                <tr class="hover:bg-surface-container-low transition-colors">
                                    <td class="px-unit-md py-4 font-semibold text-primary">@app.ThoiGian.ToString("dd/MM/yyyy HH:mm")</td>
                                    <td class="px-unit-md py-4">
                                        <div class="font-body-md font-medium text-on-surface">@app.Patient.User.HoTen</div>
                                        <div class="text-caption text-on-surface-variant">BN-@app.Patient.Id.ToString("D4")</div>
                                    </td>
                                    <td class="px-unit-md py-4 text-body-md text-on-surface-variant truncate max-w-[200px]" title="@app.LyDoKham">@app.LyDoKham</td>
                                    <td class="px-unit-md py-4">
                                        @if (app.TrangThai == "HoanThanh")
                                        {
                                            <span class="px-2.5 py-0.5 rounded-full bg-secondary/15 text-secondary text-[11px] font-bold">Hoàn thành</span>
                                        }
                                        else if (app.TrangThai == "DaXacNhan")
                                        {
                                            <span class="px-2.5 py-0.5 rounded-full bg-tertiary-fixed/30 text-on-tertiary-fixed-variant text-[11px] font-bold">Chờ khám</span>
                                        }
                                        else if (app.TrangThai == "DaHuy")
                                        {
                                            <span class="px-2.5 py-0.5 rounded-full bg-error-container text-error text-[11px] font-bold">Đã hủy</span>
                                        }
                                        else
                                        {
                                            <span class="px-2.5 py-0.5 rounded-full bg-surface-container-high text-on-surface-variant text-[11px] font-bold">@app.TrangThai</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Reviews & Feedback -->
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-unit-lg shadow-sm">
            <h3 class="font-title-lg text-title-lg mb-unit-md">Phản hồi và Đánh giá từ bệnh nhân</h3>
            <div class="space-y-unit-md divide-y divide-outline-variant">
                @if (!reviews.Any())
                {
                    <p class="text-on-surface-variant py-4 text-center">Bác sĩ này chưa nhận được đánh giá nào từ bệnh nhân.</p>
                }
                else
                {
                    @foreach (var review in reviews)
                    {
                        <div class="pt-unit-md first:pt-0">
                            <div class="flex items-center justify-between">
                                <span class="font-label-md text-on-surface">@review.Patient.User.HoTen</span>
                                <div class="flex text-secondary">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <span class="material-symbols-outlined text-[16px] @(i <= review.SoSao ? "fill-current" : "")" style="font-variation-settings: 'FILL' @(i <= review.SoSao ? "1" : "0");">star</span>
                                    }
                                </div>
                            </div>
                            <p class="text-caption text-on-surface-variant mt-1">@review.NgayTao.ToString("dd/MM/yyyy HH:mm")</p>
                            <p class="text-body-md text-on-surface-variant mt-unit-xs">@review.NhanXet</p>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>
