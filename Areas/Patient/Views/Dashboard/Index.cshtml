@model IEnumerable<QuanLyBenhVien.Models.Appointment>

@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "Trang chủ Bệnh nhân";

    var patient = ViewBag.Patient as QuanLyBenhVien.Models.Patient;
    var recentPres = ViewBag.RecentPres as List<QuanLyBenhVien.Models.Prescription> ?? new List<QuanLyBenhVien.Models.Prescription>();
    var unpaidInvoices = ViewBag.UnpaidInvoices as List<QuanLyBenhVien.Models.Invoice> ?? new List<QuanLyBenhVien.Models.Invoice>();
    var notifications = ViewBag.RecentNotifications as List<QuanLyBenhVien.Models.Notification> ?? new List<QuanLyBenhVien.Models.Notification>();
    var nextApp = ViewBag.NextAppointment as QuanLyBenhVien.Models.Appointment;
    var vitals = ViewBag.LatestVitals as QuanLyBenhVien.Models.ExaminationRecord;

    var upcoming = Model.ToList();
    var unpaidCount = (int)(ViewBag.UnpaidCount ?? 0);
    var unpaidAmount = (decimal)(ViewBag.UnpaidAmount ?? 0m);
    var totalVisits = (int)(ViewBag.TotalVisits ?? 0);
    var lastVisit = ViewBag.LastVisit as DateTime?;
    var unread = (int)(ViewBag.UnreadNotifications ?? 0);

    var hour = DateTime.Now.Hour;
    var greeting = hour < 11 ? "Chào buổi sáng" : hour < 14 ? "Chào buổi trưa" : hour < 18 ? "Chào buổi chiều" : "Chào buổi tối";

    // Notifications are stored as "[Type] Title|Body"; split for display.
    (string title, string body) SplitNotification(string raw)
    {
        if (string.IsNullOrEmpty(raw)) return ("Thông báo", "");
        var text = raw.StartsWith("[") && raw.Contains(']') ? raw[(raw.IndexOf(']') + 1)..].Trim() : raw;
        var parts = text.Split('|', 2);
        return parts.Length == 2 ? (parts[0].Trim(), parts[1].Trim()) : (text, "");
    }
}

<!-- Greeting -->
<div class="mb-unit-lg">
    <p class="text-body-md text-on-surface-variant">@greeting,</p>
    <div class="flex flex-wrap items-center gap-3 mt-1">
        <h1 class="hms-page-title">@patient?.User.HoTen</h1>
        <span class="hms-badge hms-badge-info">
            <span class="material-symbols-outlined">badge</span>
            BN-@patient?.Id.ToString("D4")
        </span>
        @if (!string.IsNullOrWhiteSpace(patient?.NhomMau))
        {
            <span class="hms-badge hms-badge-danger">
                <span class="material-symbols-outlined">water_drop</span>
                Nhóm máu @patient.NhomMau
            </span>
        }
    </div>
</div>

<!-- Hero: next appointment -->
@if (nextApp != null)
{
    var isConfirmed = nextApp.TrangThai != "ChoXacNhan";
    var daysAway = (nextApp.ThoiGian.Date - DateTime.Today).Days;
    var whenLabel = daysAway == 0 ? "Hôm nay" : daysAway == 1 ? "Ngày mai" : $"Còn {daysAway} ngày";

    <div class="patient-hero rounded-2xl p-unit-lg mb-unit-lg text-white shadow-md">
        <div class="flex flex-col lg:flex-row lg:items-center justify-between gap-unit-lg">
            <div class="min-w-0">
                <div class="flex items-center gap-2 mb-2">
                    <span class="material-symbols-outlined">event_upcoming</span>
                    <span class="text-label-md font-bold uppercase tracking-wider opacity-90">Lịch khám sắp tới</span>
                    <span class="patient-hero-chip">@whenLabel</span>
                </div>

                <p class="text-[28px] leading-9 font-bold">
                    @nextApp.ThoiGian.ToString("HH:mm") • @nextApp.ThoiGian.ToString("dd/MM/yyyy")
                </p>

                <div class="mt-3 grid grid-cols-1 sm:grid-cols-3 gap-3 text-body-md">
                    <div>
                        <p class="opacity-75 text-caption">Bác sĩ</p>
                        <p class="font-semibold">@(nextApp.Doctor != null ? nextApp.Doctor.User.HoTen : "Sẽ được phân công")</p>
                    </div>
                    <div>
                        <p class="opacity-75 text-caption">Chuyên khoa</p>
                        <p class="font-semibold">@(nextApp.Doctor != null ? nextApp.Doctor.Department.TenKhoa : "Tiếp đón chung")</p>
                    </div>
                    <div>
                        <p class="opacity-75 text-caption">Địa điểm</p>
                        <p class="font-semibold">@(nextApp.Doctor != null ? nextApp.Doctor.Department.ViTri : "Sảnh chờ tầng 1")</p>
                    </div>
                </div>
            </div>

            <div class="flex flex-col items-start lg:items-end gap-2 shrink-0">
                <span class="patient-hero-status">
                    <span class="material-symbols-outlined">@(isConfirmed ? "verified" : "schedule")</span>
                    @(isConfirmed ? "Đã xác nhận" : "Chờ xác nhận")
                </span>
                <a href="/Patient/Record" class="patient-hero-btn">
                    <span class="material-symbols-outlined">description</span> Xem hồ sơ khám
                </a>
                @if (!isConfirmed)
                {
                    <p class="text-caption opacity-80 max-w-[240px] lg:text-right">Nhân viên sẽ liên hệ qua điện thoại để xác nhận lịch.</p>
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="patient-hero patient-hero-empty rounded-2xl p-unit-lg mb-unit-lg text-white shadow-md">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-unit-md">
            <div>
                <div class="flex items-center gap-2 mb-1">
                    <span class="material-symbols-outlined">event_available</span>
                    <span class="text-label-md font-bold uppercase tracking-wider opacity-90">Lịch khám</span>
                </div>
                <p class="text-title-lg font-bold">Bạn chưa có lịch khám nào sắp tới</p>
                <p class="text-body-md opacity-90 mt-1">Đặt lịch trước để chủ động chọn bác sĩ và khung giờ phù hợp.</p>
            </div>
            <a href="/Patient/Book" class="patient-hero-btn shrink-0">
                <span class="material-symbols-outlined">add_circle</span> Đặt lịch khám ngay
            </a>
        </div>
    </div>
}

<!-- Outstanding balance alert -->
@if (unpaidCount > 0)
{
    <a href="/Patient/Payment" class="patient-alert mb-unit-lg">
        <span class="material-symbols-outlined patient-alert-icon">receipt_long</span>
        <div class="min-w-0 flex-1">
            <p class="font-bold text-on-surface">Bạn có @unpaidCount hóa đơn chưa thanh toán</p>
            <p class="text-body-md text-on-surface-variant">
                Tổng cộng <strong class="text-error">@unpaidAmount.ToString("N0") ₫</strong> — thanh toán trực tuyến 24/7.
            </p>
        </div>
        <span class="hms-btn hms-btn-primary shrink-0">
            <span class="material-symbols-outlined">payments</span> Thanh toán
        </span>
    </a>
}

<!-- At-a-glance -->
<div class="hms-stat-grid">
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-primary"><span class="material-symbols-outlined">event_upcoming</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Lịch hẹn sắp tới</p>
            <p class="hms-stat-value">@upcoming.Count</p>
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-success"><span class="material-symbols-outlined">history</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Lượt khám đã hoàn tất</p>
            <p class="hms-stat-value">@totalVisits</p>
            @if (lastVisit.HasValue)
            {
                <p class="hms-stat-hint">Gần nhất @lastVisit.Value.ToString("dd/MM/yyyy")</p>
            }
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon @(unpaidCount > 0 ? "hms-stat-icon-danger" : "hms-stat-icon-success")">
            <span class="material-symbols-outlined">payments</span>
        </div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Hóa đơn chưa thanh toán</p>
            <p class="hms-stat-value">@unpaidCount</p>
            @if (unpaidCount > 0)
            {
                <p class="hms-stat-hint">@unpaidAmount.ToString("N0") ₫</p>
            }
        </div>
    </div>
    <div class="hms-stat">
        <div class="hms-stat-icon hms-stat-icon-warn"><span class="material-symbols-outlined">notifications</span></div>
        <div class="hms-stat-body">
            <p class="hms-stat-label">Thông báo chưa đọc</p>
            <p class="hms-stat-value">@unread</p>
        </div>
    </div>
</div>

<!-- Quick actions -->
<div class="grid grid-cols-2 md:grid-cols-4 gap-unit-md mb-unit-lg">
    <a href="/Patient/Book" class="patient-action">
        <span class="material-symbols-outlined patient-action-icon">event_upcoming</span>
        <strong class="patient-action-title">Đặt lịch hẹn</strong>
        <span class="patient-action-sub">Chọn bác sĩ &amp; giờ khám</span>
    </a>
    <a href="/Patient/Record" class="patient-action">
        <span class="material-symbols-outlined patient-action-icon">clinical_notes</span>
        <strong class="patient-action-title">Đơn thuốc &amp; bệnh án</strong>
        <span class="patient-action-sub">Tra cứu lịch sử điều trị</span>
    </a>
    <a href="/Patient/Payment" class="patient-action">
        <span class="material-symbols-outlined patient-action-icon">payments</span>
        <strong class="patient-action-title">Thanh toán hóa đơn</strong>
        <span class="patient-action-sub">Trực tuyến 24/7</span>
    </a>
    <a href="/Patient/Record/Health" class="patient-action">
        <span class="material-symbols-outlined patient-action-icon">monitoring</span>
        <strong class="patient-action-title">Sổ sức khỏe</strong>
        <span class="patient-action-sub">Theo dõi chỉ số sinh tồn</span>
    </a>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-unit-lg">
    <!-- Left: schedule + prescriptions -->
    <div class="lg:col-span-2 space-y-unit-lg">
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm overflow-hidden">
            <div class="flex items-center justify-between p-unit-lg pb-unit-md">
                <h2 class="hms-section-title">
                    <span class="material-symbols-outlined">calendar_month</span> Lịch hẹn khám sắp tới
                </h2>
                <a href="/Patient/Book" class="hms-btn hms-btn-secondary hms-btn-sm">
                    <span class="material-symbols-outlined">add</span> Đặt thêm
                </a>
            </div>

            <div class="px-unit-lg pb-unit-lg space-y-unit-md">
                @if (upcoming.Count == 0)
                {
                    <div class="hms-empty">
                        <div class="hms-empty-icon"><span class="material-symbols-outlined">event_busy</span></div>
                        <p class="hms-empty-title">Chưa có lịch khám sắp diễn ra</p>
                        <p class="hms-empty-text">Đăng ký lịch khám để được ưu tiên chọn bác sĩ và khung giờ mong muốn.</p>
                        <a href="/Patient/Book" class="hms-btn hms-btn-primary mt-2">
                            <span class="material-symbols-outlined">add_circle</span> Đăng ký lịch khám
                        </a>
                    </div>
                }
                else
                {
                    @foreach (var app in upcoming)
                    {
                        <div class="patient-appt">
                            <div class="patient-appt-date">
                                <span class="patient-appt-day">@app.ThoiGian.ToString("dd")</span>
                                <span class="patient-appt-month">Th@(app.ThoiGian.Month)</span>
                            </div>
                            <div class="min-w-0 flex-1">
                                <div class="flex flex-wrap items-center gap-2">
                                    <strong class="text-body-md text-on-surface">@app.ThoiGian.ToString("HH:mm")</strong>
                                    <span class="text-caption text-on-surface-variant">#LK-@app.Id.ToString("D4")</span>
                                    @if (app.TrangThai == "ChoXacNhan")
                                    {
                                        <span class="hms-badge hms-badge-warn"><span class="material-symbols-outlined">schedule</span> Chờ xác nhận</span>
                                    }
                                    else
                                    {
                                        <span class="hms-badge hms-badge-ok"><span class="material-symbols-outlined">check_circle</span> Đã xác nhận</span>
                                    }
                                </div>
                                <p class="text-body-md text-on-surface mt-1 font-medium">
                                    @(app.Doctor != null ? app.Doctor.User.HoTen : "Hệ thống tự động phân công")
                                </p>
                                <p class="text-caption text-on-surface-variant">
                                    @(app.Doctor != null ? app.Doctor.Department.TenKhoa : "Phòng tiếp đón chung")
                                    • @(app.Doctor != null ? app.Doctor.Department.ViTri : "Sảnh chờ tầng 1")
                                </p>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm overflow-hidden">
            <div class="flex items-center justify-between p-unit-lg pb-unit-md">
                <h2 class="hms-section-title">
                    <span class="material-symbols-outlined">medication</span> Đơn thuốc gần đây
                </h2>
                <a href="/Patient/Record" class="hms-btn hms-btn-secondary hms-btn-sm">
                    Xem tất cả <span class="material-symbols-outlined">chevron_right</span>
                </a>
            </div>

            <div class="px-unit-lg pb-unit-lg space-y-unit-sm">
                @if (recentPres.Count == 0)
                {
                    <div class="hms-empty">
                        <div class="hms-empty-icon"><span class="material-symbols-outlined">prescriptions</span></div>
                        <p class="hms-empty-title">Chưa có đơn thuốc nào</p>
                        <p class="hms-empty-text">Đơn thuốc bác sĩ kê sau mỗi lần khám sẽ được lưu tại đây.</p>
                    </div>
                }
                else
                {
                    @foreach (var pres in recentPres)
                    {
                        <a href="/Patient/Record/PrescriptionDetails/@pres.PhieuKhamId" class="patient-pres">
                            <span class="material-symbols-outlined patient-pres-icon">pill</span>
                            <div class="min-w-0 flex-1">
                                <p class="text-body-md font-semibold text-on-surface">@pres.ExaminationRecord.ChanDoan</p>
                                <p class="text-caption text-on-surface-variant">
                                    @pres.NgayKe.ToString("dd/MM/yyyy")
                                    @if (pres.ExaminationRecord.Appointment.Doctor != null)
                                    {
                                        <span> • BS @pres.ExaminationRecord.Appointment.Doctor.User.HoTen</span>
                                    }
                                </p>
                            </div>
                            <span class="material-symbols-outlined text-outline">chevron_right</span>
                        </a>
                    }
                }
            </div>
        </div>
    </div>

    <!-- Right: health profile + notifications -->
    <div class="space-y-unit-lg">
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-unit-lg shadow-sm">
            <h2 class="hms-section-title mb-unit-md">
                <span class="material-symbols-outlined">health_and_safety</span> Hồ sơ sức khỏe
            </h2>

            <dl class="space-y-3">
                <div class="patient-field">
                    <dt>Thẻ BHYT</dt>
                    <dd>
                        @if (string.IsNullOrWhiteSpace(patient?.SoBHYT))
                        {
                            <span class="hms-badge hms-badge-neutral">Chưa cập nhật</span>
                        }
                        else
                        {
                            <span class="font-mono font-semibold">@patient.SoBHYT</span>
                        }
                    </dd>
                </div>
                <div class="patient-field">
                    <dt>Ngày sinh</dt>
                    <dd>@patient?.NgaySinh.ToString("dd/MM/yyyy") • @patient?.GioiTinh</dd>
                </div>
                <div class="patient-field">
                    <dt>Dị ứng</dt>
                    <dd>
                        @if (string.IsNullOrWhiteSpace(patient?.DiUng))
                        {
                            <span class="text-on-surface-variant">Không ghi nhận</span>
                        }
                        else
                        {
                            <span class="hms-badge hms-badge-danger">
                                <span class="material-symbols-outlined">warning</span> @patient.DiUng
                            </span>
                        }
                    </dd>
                </div>
                <div class="patient-field">
                    <dt>Tiền sử bệnh</dt>
                    <dd>@(string.IsNullOrWhiteSpace(patient?.TienSuBenh) ? "Không ghi nhận" : patient.TienSuBenh)</dd>
                </div>
            </dl>

            @if (vitals != null)
            {
                <p class="text-label-md text-on-surface-variant uppercase tracking-wider mt-unit-lg mb-2">
                    Chỉ số gần nhất — @vitals.NgayKham.ToString("dd/MM/yyyy")
                </p>
                <div class="grid grid-cols-2 gap-2">
                    @if (vitals.CanNang.HasValue)
                    {
                        <div class="patient-vital">
                            <span class="patient-vital-label">Cân nặng</span>
                            <span class="patient-vital-value">@vitals.CanNang.Value.ToString("0.#") kg</span>
                        </div>
                    }
                    @if (vitals.ChieuCao.HasValue)
                    {
                        <div class="patient-vital">
                            <span class="patient-vital-label">Chiều cao</span>
                            <span class="patient-vital-value">@vitals.ChieuCao.Value.ToString("0.#") cm</span>
                        </div>
                    }
                    @if (vitals.BMI.HasValue)
                    {
                        <div class="patient-vital">
                            <span class="patient-vital-label">BMI</span>
                            <span class="patient-vital-value">@vitals.BMI.Value.ToString("0.#")</span>
                        </div>
                    }
                    @if (vitals.NhietDo.HasValue)
                    {
                        <div class="patient-vital">
                            <span class="patient-vital-label">Nhiệt độ</span>
                            <span class="patient-vital-value">@vitals.NhietDo.Value.ToString("0.#") °C</span>
                        </div>
                    }
                </div>
            }

            <a href="/Patient/Record/Health" class="hms-btn hms-btn-secondary w-full mt-unit-md">
                <span class="material-symbols-outlined">monitoring</span> Mở sổ sức khỏe
            </a>
        </div>

        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-unit-lg shadow-sm">
            <div class="flex items-center justify-between mb-unit-md">
                <h2 class="hms-section-title">
                    <span class="material-symbols-outlined">notifications</span> Thông báo
                </h2>
                @if (unread > 0)
                {
                    <span class="hms-badge hms-badge-danger">@unread mới</span>
                }
            </div>

            @if (notifications.Count == 0)
            {
                <p class="text-body-md text-on-surface-variant text-center py-4">Chưa có thông báo nào.</p>
            }
            else
            {
                <div class="space-y-2">
                    @foreach (var note in notifications)
                    {
                        var parsed = SplitNotification(note.NoiDung);
                        <a href="/Patient/Notification" class="patient-note @(note.DaDoc ? "" : "patient-note-unread")">
                            <div class="min-w-0">
                                <p class="text-body-md font-semibold text-on-surface">@parsed.title</p>
                                @if (!string.IsNullOrEmpty(parsed.body))
                                {
                                    <p class="text-caption text-on-surface-variant line-clamp-2">@parsed.body</p>
                                }
                                <p class="text-[11px] text-outline mt-0.5">@note.NgayGui.ToString("HH:mm dd/MM/yyyy")</p>
                            </div>
                        </a>
                    }
                </div>

                <a href="/Patient/Notification" class="hms-btn hms-btn-secondary w-full mt-unit-md">
                    Xem tất cả thông báo <span class="material-symbols-outlined">chevron_right</span>
                </a>
            }
        </div>
    </div>
</div>
