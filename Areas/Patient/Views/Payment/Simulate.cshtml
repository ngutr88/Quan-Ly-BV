@model QuanLyBenhVien.Models.Invoice

@{
    Layout = "_Layout";
    ViewData["Title"] = "Mô phỏng Cổng thanh toán trực tuyến";
}

<body class="bg-[#f3f4f6] min-h-screen flex flex-col items-center justify-center p-margin-mobile">
    <main class="w-full max-w-md bg-white rounded-2xl shadow-2xl overflow-hidden border border-slate-200">
        <!-- Gateway Header banner -->
        <div class="bg-gradient-to-r from-blue-700 to-indigo-800 p-unit-md text-white text-center">
            <h1 class="font-headline-md font-bold flex items-center justify-center gap-1">
                <span class="material-symbols-outlined text-[28px]">shield_lock</span>
                MediPay Gateway
            </h1>
            <p class="text-caption text-blue-200 mt-1">Cổng thanh toán điện tử mô phỏng an toàn</p>
        </div>

        <div class="p-unit-lg space-y-unit-lg">
            <!-- Payment overview -->
            <div class="text-center space-y-unit-xs">
                <span class="text-caption text-on-surface-variant uppercase tracking-wider block">Số tiền cần thanh toán</span>
                <strong class="text-[32px] font-black text-blue-800">@Model.TongTien.ToString("N0") VND</strong>
                <span class="text-caption text-on-surface-variant block mt-1">Hóa đơn: <strong>#HD-@Model.Id.ToString("D5")</strong></span>
            </div>

            <!-- Mock QR code scanner -->
            <div class="flex flex-col items-center p-unit-md bg-slate-50 rounded-xl border border-slate-200/60">
                <div class="w-44 h-44 bg-white border border-slate-300 p-2 rounded-lg flex items-center justify-center relative shadow-inner">
                    <!-- QR Mockup graphics -->
                    <span class="material-symbols-outlined text-[100px] text-slate-300 animate-pulse">qr_code_2</span>
                    <!-- Border brackets -->
                    <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-blue-600 rounded-tl"></div>
                    <div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-blue-600 rounded-tr"></div>
                    <div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-blue-600 rounded-bl"></div>
                    <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-blue-600 rounded-br"></div>
                </div>
                <span class="text-[11px] text-on-surface-variant mt-unit-sm text-center">Quét mã QR bằng ứng dụng ngân hàng hoặc ví VNPay/Momo để thanh toán nhanh</span>
            </div>

            <!-- Submit Callback Actions -->
            <form action="/Patient/Payment/PaymentCallback/@Model.Id" method="POST" class="space-y-unit-sm">
                @Html.AntiForgeryToken()
                
                <button type="submit" class="w-full bg-blue-700 hover:bg-blue-800 text-white font-body-lg font-semibold py-3 rounded-lg transition-all active:scale-[0.98] flex items-center justify-center gap-1 shadow">
                    <span class="material-symbols-outlined">check_circle</span>
                    Xác nhận chuyển khoản thành công
                </button>
                
                <a href="/Patient/Payment/Details/@Model.Id" class="w-full border border-slate-300 text-on-surface font-body-md font-semibold py-3.5 rounded-lg hover:bg-slate-50 transition-all text-center block">
                    Hủy giao dịch
                </a>
            </form>
        </div>

        <div class="bg-slate-50 p-unit-sm border-t border-slate-100 text-center text-caption text-outline">
            Dành riêng cho mục đích trải nghiệm và demo luồng hóa đơn.
        </div>
    </main>
</body>
