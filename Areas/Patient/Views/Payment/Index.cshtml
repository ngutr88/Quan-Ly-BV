@model IEnumerable<QuanLyBenhVien.Models.Invoice>
@using System.Text.Json

@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "Hóa đơn & Thanh toán";

    var allInvoices = Model.ToList();
    
    // Financial metrics
    var unpaidStatuses = new[] { "ChuaThanhToan", "QuaHan", "ThanhToanThatBai" };
    var unpaidInvoices = allInvoices.Where(i => unpaidStatuses.Contains(i.TrangThaiThanhToan)).ToList();
    var totalDebt = unpaidInvoices.Sum(i => i.TongTien);
    var totalPaid = allInvoices.Where(i => i.TrangThaiThanhToan == "DaThanhToan").Sum(i => i.TongTien);
    var unpaidCount = unpaidInvoices.Count;
    var overdueCount = allInvoices.Count(i => i.TrangThaiThanhToan == "QuaHan");
    var hasOverdue = overdueCount > 0;
}

<!-- html2pdf dependency for client-side PDF download -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>

<div class="flex flex-col gap-unit-lg w-full animate-fade-in">
    @Html.AntiForgeryToken()
    @if (hasOverdue)
    {
        <!-- Warning Banner -->
        <div class="bg-error-container text-on-error-container p-unit-md rounded-2xl flex items-center gap-3 border border-error/20 shadow-md">
            <span class="material-symbols-outlined text-[24px] text-error animate-bounce">warning</span>
            <div>
                <p class="text-body-md font-bold">Cảnh báo hóa đơn quá hạn!</p>
                <p class="text-caption text-on-error-container/85">Bạn đang có @overdueCount hóa đơn quá hạn thanh toán. Vui lòng thanh toán sớm để đảm bảo quyền lợi khám chữa bệnh liên tục.</p>
            </div>
        </div>
    }

    <!-- Page Header & Financial Dashboard -->
    <div class="flex flex-col gap-unit-md">
        <div>
            <h2 class="font-headline-lg text-headline-lg text-on-background mb-1">Hóa đơn &amp; Thanh toán</h2>
            <p class="text-body-md text-on-surface-variant">Quản lý viện phí, xem lịch sử giao dịch và thực hiện thanh toán trực tuyến bảo mật.</p>
        </div>

        <!-- Dashboard Bento Grid -->
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-unit-md mt-unit-sm">
            <!-- 1. Total Debt -->
            <div class="bg-white border border-outline-variant rounded-2xl p-5 flex flex-col justify-between shadow-sm relative overflow-hidden group hover:shadow-md transition-all">
                <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-[72px] text-primary">account_balance_wallet</span>
                </div>
                <div>
                    <p class="text-caption font-bold text-outline uppercase tracking-wider">Tổng nợ hiện tại</p>
                    <h3 class="text-headline-md font-black text-primary mt-2">@totalDebt.ToString("N0") <span class="text-body-md font-normal text-on-surface-variant">đ</span></h3>
                </div>
                <div class="mt-4 flex items-center gap-1.5 text-caption font-medium @(totalDebt > 0 ? "text-error" : "text-secondary")">
                    <span class="material-symbols-outlined text-[16px]">@(totalDebt > 0 ? "error" : "check_circle")</span>
                    <span>@(totalDebt > 0 ? "Yêu cầu thanh toán" : "Đã thanh toán đủ")</span>
                </div>
            </div>

            <!-- 2. Total Paid -->
            <div class="bg-white border border-outline-variant rounded-2xl p-5 flex flex-col justify-between shadow-sm relative overflow-hidden group hover:shadow-md transition-all">
                <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-[72px] text-secondary">payments</span>
                </div>
                <div>
                    <p class="text-caption font-bold text-outline uppercase tracking-wider">Tổng đã thanh toán</p>
                    <h3 class="text-headline-md font-black text-secondary mt-2">@totalPaid.ToString("N0") <span class="text-body-md font-normal text-on-surface-variant">đ</span></h3>
                </div>
                <div class="mt-4 flex items-center gap-1.5 text-secondary text-caption font-medium">
                    <span class="material-symbols-outlined text-[16px]">check_circle</span>
                    <span>Hoàn thành thanh toán</span>
                </div>
            </div>

            <!-- 3. Unpaid Count -->
            <div class="bg-white border border-outline-variant rounded-2xl p-5 flex flex-col justify-between shadow-sm relative overflow-hidden group hover:shadow-md transition-all">
                <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-[72px] text-tertiary">receipt</span>
                </div>
                <div>
                    <p class="text-caption font-bold text-outline uppercase tracking-wider">Hóa đơn cần thanh toán</p>
                    <h3 class="text-headline-md font-black text-tertiary mt-2">@unpaidCount <span class="text-body-md font-normal text-on-surface-variant">hóa đơn</span></h3>
                </div>
                <div class="mt-4 flex items-center gap-1.5 text-caption font-medium @(unpaidCount > 0 ? "text-tertiary-container" : "text-secondary")">
                    <span class="material-symbols-outlined text-[16px]">@(unpaidCount > 0 ? "hourglass_empty" : "done_all")</span>
                    <span>@(unpaidCount > 0 ? "Chờ xử lý thanh toán" : "Không có hóa đơn nợ")</span>
                </div>
            </div>

            <!-- 4. Overdue Count -->
            <div class="bg-white border border-outline-variant rounded-2xl p-5 flex flex-col justify-between shadow-sm relative overflow-hidden group hover:shadow-md transition-all">
                <div class="absolute top-0 right-0 p-4 opacity-5 group-hover:scale-110 transition-transform">
                    <span class="material-symbols-outlined text-[72px] text-error">gavel</span>
                </div>
                <div>
                    <p class="text-caption font-bold text-outline uppercase tracking-wider">Hóa đơn quá hạn</p>
                    <h3 class="text-headline-md font-black text-error mt-2">@overdueCount <span class="text-body-md font-normal text-on-surface-variant">hóa đơn</span></h3>
                </div>
                <div class="mt-4 flex items-center gap-1.5 text-caption font-medium @(overdueCount > 0 ? "text-error font-bold animate-pulse" : "text-secondary")">
                    <span class="material-symbols-outlined text-[16px]">@(overdueCount > 0 ? "running_with_errors" : "verified")</span>
                    <span>@(overdueCount > 0 ? "Cần giải quyết ngay" : "Không có hóa đơn trễ hạn")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Interactive Filters Bento -->
    <div class="bg-white border border-outline-variant rounded-2xl p-4 shadow-sm flex flex-col gap-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3">
            <!-- Search by Invoice ID -->
            <div class="flex flex-col gap-1.5">
                <label class="text-[11px] font-bold text-on-surface-variant uppercase">Tìm mã hóa đơn</label>
                <div class="relative">
                    <span class="material-symbols-outlined absolute left-3 top-2.5 text-outline text-[20px]">search</span>
                    <input type="text" id="filter-search" placeholder="Ví dụ: HD-00001" class="w-full pl-9 pr-3 py-2 border border-outline-variant rounded-xl text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all"/>
                </div>
            </div>

            <!-- Date Start -->
            <div class="flex flex-col gap-1.5">
                <label class="text-[11px] font-bold text-on-surface-variant uppercase">Từ ngày</label>
                <input type="date" id="filter-date-start" class="w-full px-3 py-2 border border-outline-variant rounded-xl text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all"/>
            </div>

            <!-- Date End -->
            <div class="flex flex-col gap-1.5">
                <label class="text-[11px] font-bold text-on-surface-variant uppercase">Đến ngày</label>
                <input type="date" id="filter-date-end" class="w-full px-3 py-2 border border-outline-variant rounded-xl text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none transition-all"/>
            </div>

            <!-- Status Select -->
            <div class="flex flex-col gap-1.5">
                <label class="text-[11px] font-bold text-on-surface-variant uppercase">Trạng thái thanh toán</label>
                <select id="filter-status" class="w-full px-3 py-2 border border-outline-variant rounded-xl text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-white transition-all">
                    <option value="">Tất cả trạng thái</option>
                    <option value="ChuaThanhToan">Chưa thanh toán</option>
                    <option value="DaThanhToan">Đã thanh toán</option>
                    <option value="QuaHan">Quá hạn</option>
                    <option value="ThanhToanThatBai">Thanh toán thất bại</option>
                    <option value="DangXuLy">Đang xử lý</option>
                    <option value="DaHuy">Đã hủy</option>
                </select>
            </div>

            <!-- Payment Method Select -->
            <div class="flex flex-col gap-1.5">
                <label class="text-[11px] font-bold text-on-surface-variant uppercase">Phương thức thanh toán</label>
                <select id="filter-method" class="w-full px-3 py-2 border border-outline-variant rounded-xl text-body-md focus:border-primary focus:ring-1 focus:ring-primary outline-none bg-white transition-all">
                    <option value="">Tất cả phương thức</option>
                    <option value="Online (VNPay)">VNPay</option>
                    <option value="Online (MoMo)">MoMo</option>
                    <option value="Online (ZaloPay)">ZaloPay</option>
                    <option value="ChuyenKhoan">Chuyển khoản</option>
                    <option value="Thanh toán tại quầy">Thanh toán tại quầy</option>
                </select>
            </div>
        </div>

        <div class="flex justify-between items-center border-t border-outline-variant/30 pt-3">
            <span class="text-caption text-outline font-medium" id="filter-summary">Hiển thị toàn bộ hóa đơn</span>
            <button onclick="resetFilters()" class="text-primary hover:text-primary-container font-semibold text-caption flex items-center gap-1">
                <span class="material-symbols-outlined text-[16px]">restart_alt</span>
                Reset bộ lọc
            </button>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-unit-lg items-start">
        
        <!-- Left Column: Invoices & Transactions -->
        <div class="lg:col-span-8 flex flex-col gap-unit-lg">
            
            <!-- Invoices Table Section -->
            <div class="bg-white border border-outline-variant rounded-2xl overflow-hidden shadow-sm">
                <div class="p-unit-md border-b border-outline-variant/60 bg-surface-container-lowest flex justify-between items-center">
                    <h3 class="font-title-lg font-bold text-on-surface flex items-center gap-2">
                        <span class="material-symbols-outlined text-primary">receipt_long</span>
                        Danh sách hóa đơn viện phí
                    </h3>
                </div>

                <div class="invoice-table-scroll overflow-x-auto" aria-label="Vùng cuộn danh sách hóa đơn">
                    <table class="w-full text-left border-collapse" id="invoices-table">
                        <thead>
                            <tr class="bg-surface-container-low border-b border-outline-variant">
                                <th class="px-6 py-4 text-caption font-bold text-on-surface-variant uppercase tracking-wider">Mã hóa đơn</th>
                                <th class="px-6 py-4 text-caption font-bold text-on-surface-variant uppercase tracking-wider">Ngày tạo</th>
                                <th class="px-6 py-4 text-caption font-bold text-on-surface-variant uppercase tracking-wider">Bác sĩ khám</th>
                                <th class="px-6 py-4 text-caption font-bold text-on-surface-variant uppercase tracking-wider">Tổng tiền</th>
                                <th class="px-6 py-4 text-caption font-bold text-on-surface-variant uppercase tracking-wider">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/50">
                            <!-- Injected by JS -->
                        </tbody>
                    </table>
                </div>

                <!-- Empty State (Table) -->
                <div id="invoices-empty" class="hidden p-unit-xl text-center flex flex-col items-center gap-unit-md">
                    <div class="w-20 h-20 bg-surface-container rounded-full flex items-center justify-center border border-dashed border-outline-variant">
                        <span class="material-symbols-outlined text-[42px] text-outline">receipt</span>
                    </div>
                    <div>
                        <h4 class="font-title-lg text-on-surface font-bold" id="empty-title">Bạn chưa có hóa đơn nào</h4>
                        <p class="text-caption text-on-surface-variant max-w-sm mt-1" id="empty-desc">Không có dữ liệu hóa đơn nào khớp với bộ lọc hiện tại của bạn.</p>
                    </div>
                    <a href="/Patient/Book" id="empty-cta" class="bg-primary text-white font-semibold text-caption px-6 py-2.5 rounded-xl hover:bg-primary-container shadow-sm transition-all active:scale-[0.98]">
                        Đặt lịch khám ngay
                    </a>
                </div>
            </div>

            <!-- Transaction History Section -->
            <div class="bg-white border border-outline-variant rounded-2xl overflow-hidden shadow-sm">
                <div class="p-unit-md border-b border-outline-variant/60 bg-surface-container-lowest">
                    <h3 class="font-title-lg font-bold text-on-surface flex items-center gap-2">
                        <span class="material-symbols-outlined text-secondary">history</span>
                        Lịch sử giao dịch trực tuyến
                    </h3>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse" id="transactions-table">
                        <thead>
                            <tr class="bg-surface-container-low border-b border-outline-variant">
                                <th class="px-6 py-4 text-caption font-bold text-on-surface-variant uppercase tracking-wider">Ngày giao dịch</th>
                                <th class="px-6 py-4 text-caption font-bold text-on-surface-variant uppercase tracking-wider">Mã giao dịch</th>
                                <th class="px-6 py-4 text-caption font-bold text-on-surface-variant uppercase tracking-wider">Phương thức</th>
                                <th class="px-6 py-4 text-caption font-bold text-on-surface-variant uppercase tracking-wider">Số tiền</th>
                                <th class="px-6 py-4 text-caption font-bold text-on-surface-variant uppercase tracking-wider">Trạng thái</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-outline-variant/50">
                            <!-- Injected by JS -->
                        </tbody>
                    </table>
                </div>

                <!-- Empty State (Transactions) -->
                <div id="transactions-empty" class="hidden p-unit-lg text-center flex flex-col items-center gap-2 py-8">
                    <span class="material-symbols-outlined text-[36px] text-outline-variant">payments</span>
                    <p class="text-caption text-on-surface-variant font-medium">Chưa có giao dịch thanh toán trực tuyến nào được thực hiện.</p>
                </div>
            </div>
        </div>

        <!-- Right Column: Details & Operations -->
        <div class="lg:col-span-4 flex flex-col gap-unit-lg sticky top-20" id="detail-pane">
            <!-- Details Section -->
            <section class="bg-white border border-outline-variant rounded-2xl overflow-hidden shadow-sm relative transition-all" id="detail-section">
                <!-- Watermark for Status -->
                <div id="status-watermark" class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 font-black text-[50px] uppercase select-none opacity-5 rotate-12 z-0 pointer-events-none">
                    DRAFT
                </div>

                <div class="p-unit-md border-b border-outline-variant/60 bg-surface-container-lowest flex justify-between items-center z-10 relative">
                    <h3 class="font-title-lg font-bold text-primary flex items-center gap-1">
                        <span class="material-symbols-outlined">receipt_long</span>
                        Chi tiết hóa đơn
                    </h3>
                    <span class="text-caption font-mono bg-surface border border-outline-variant px-2 py-0.5 rounded font-bold" id="detail-code">#HD-00000</span>
                </div>

                <div class="p-unit-md flex flex-col gap-4 z-10 relative">
                    <!-- General Details Grid -->
                    <div class="grid grid-cols-2 gap-x-2 gap-y-3 text-caption border-b border-outline-variant/40 pb-4">
                        <div>
                            <span class="text-outline block">Khoa khám</span>
                            <strong class="text-on-surface block font-semibold truncate" id="detail-dept">Khoa Tim mạch</strong>
                        </div>
                        <div>
                            <span class="text-outline block">Bác sĩ khám</span>
                            <strong class="text-on-surface block font-semibold truncate" id="detail-doctor">BS. Nguyễn Văn Trung</strong>
                        </div>
                        <div>
                            <span class="text-outline block">Ngày khám</span>
                            <strong class="text-on-surface block font-semibold" id="detail-date-exam">N/A</strong>
                        </div>
                        <div>
                            <span class="text-outline block">Mã lịch khám</span>
                            <strong class="text-on-surface block font-semibold" id="detail-app-code">N/A</strong>
                        </div>
                        <div>
                            <span class="text-outline block">Phương thức</span>
                            <strong class="text-on-surface block font-semibold truncate" id="detail-method">N/A</strong>
                        </div>
                        <div>
                            <span class="text-outline block">Mã giao dịch</span>
                            <strong class="text-on-surface block font-semibold font-mono truncate text-[11px]" id="detail-transaction">N/A</strong>
                        </div>
                    </div>

                    <!-- Items List -->
                    <div>
                        <h4 class="text-caption font-bold text-outline uppercase tracking-wider mb-2">Chi tiết viện phí</h4>
                        <div id="detail-list" class="flex flex-col gap-2 max-h-60 overflow-y-auto">
                            <!-- Items Injected here -->
                        </div>
                    </div>

                    <!-- Total Block -->
                    <div class="mt-2 p-4 bg-primary-fixed text-on-primary-fixed rounded-2xl flex justify-between items-center shadow-sm">
                        <span class="font-bold text-caption uppercase tracking-wider">Tổng viện phí</span>
                        <span class="font-headline-md font-black text-primary text-headline-sm" id="detail-total">0 đ</span>
                    </div>

                    <!-- Operations (Always Visible when invoice selected) -->
                    <div class="grid grid-cols-3 gap-2 border-t border-outline-variant/30 pt-4 mt-2">
                        <button onclick="printInvoice()" class="flex flex-col items-center justify-center gap-1.5 p-2 bg-surface hover:bg-surface-container-high border border-outline-variant/60 rounded-xl text-caption text-on-surface transition-all active:scale-95" title="In biên lai">
                            <span class="material-symbols-outlined text-[20px] text-primary">print</span>
                            <span class="font-semibold">In hóa đơn</span>
                        </button>
                        <button onclick="downloadPdf()" class="flex flex-col items-center justify-center gap-1.5 p-2 bg-surface hover:bg-surface-container-high border border-outline-variant/60 rounded-xl text-caption text-on-surface transition-all active:scale-95" title="Tải PDF">
                            <span class="material-symbols-outlined text-[20px] text-secondary">picture_as_pdf</span>
                            <span class="font-semibold">Tải PDF</span>
                        </button>
                        <button onclick="sendEmailReceipt(event)" class="flex flex-col items-center justify-center gap-1.5 p-2 bg-surface hover:bg-surface-container-high border border-outline-variant/60 rounded-xl text-caption text-on-surface transition-all active:scale-95" title="Gửi biên lai qua Email">
                            <span class="material-symbols-outlined text-[20px] text-tertiary">email</span>
                            <span class="font-semibold">Gửi Email</span>
                        </button>
                    </div>
                </div>
            </section>

            <!-- Payment Options Section (For Unpaid/Failed/Overdue Invoices) -->
            <section class="bg-white border border-outline-variant rounded-2xl p-5 shadow-sm transition-all" id="payment-section">
                <h3 class="font-title-lg font-bold text-on-background mb-3 flex items-center gap-1">
                    <span class="material-symbols-outlined text-primary">credit_card</span>
                    Thanh toán trực tuyến
                </h3>
                <p class="text-caption text-on-surface-variant mb-4">Vui lòng lựa chọn phương thức thanh toán bảo mật bên dưới:</p>
                
                <div class="flex flex-col gap-2.5 mb-6">
                    <!-- VNPay -->
                    <label class="relative flex items-center gap-3 p-3 border border-outline-variant rounded-xl cursor-pointer hover:bg-surface-container-low transition-all group has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                        <input checked="" class="accent-primary w-4 h-4" name="paymentMethod" type="radio" value="vnpay"/>
                        <img class="w-8 h-8 object-contain" src="https://lh3.googleusercontent.com/aida-public/AB6AXuD0y0s8Y8k7DVQXcDdFl-uUOeBJnD3Vn9lYucgaViDlj7dgf22d9ODHoaxZ8-4L1hywHZuBLo84Vz5FASVtv8jKO1HveIPsRw_HXtAod6c6lAUKRGvRU58O-xXX2KZp8qPFWegYFnJF-g2Yrab4zsOXjImS59w8ioHalFuqS_JAEUO8QmNxwonTZKBWIa3C7H_sg33u8t7gmXqwRbmiBy6zpRANKLQZKTcl6W6mRqn9e3J5CTEV6lO7BTb3biak3qlLaY9-6n-Si8c"/>
                        <div class="flex flex-col">
                            <span class="text-caption font-bold">Cổng thanh toán VNPay</span>
                            <span class="text-[10px] text-outline">Thanh toán qua ví VNPay hoặc Mobile Banking</span>
                        </div>
                    </label>

                    <!-- MoMo -->
                    <label class="relative flex items-center gap-3 p-3 border border-outline-variant rounded-xl cursor-pointer hover:bg-surface-container-low transition-all group has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                        <input class="accent-primary w-4 h-4" name="paymentMethod" type="radio" value="momo"/>
                        <img class="w-8 h-8 object-contain" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBvKWGBnJMWWOFYp3nk2-UJpu5CJejqhDIOenoH6gKeoiT3kEy59xtSIeUN5djbUBzUkLpqhDoJnajayAy9SiQ3qFWJZpVMMXBwO2IgaJC8DsdyWZ89np7dRWPIydFrZYl4bc2Vru6GIqNJzzTLKpn7Qme6r03kpDyN3Hy7BlZ9BAvxbZJ84hB5FEKCCIpsU_JW7wo9XVLg77E6q4WDmNLZjgN-YOPirmabVGsc9tj8YrW8X592ZIU1Z2RBhZYf2GnijDkca13OnU4"/>
                        <div class="flex flex-col">
                            <span class="text-caption font-bold">Ví điện tử MoMo</span>
                            <span class="text-[10px] text-outline">Thanh toán tức thời qua ứng dụng ví MoMo</span>
                        </div>
                    </label>

                    <!-- ZaloPay -->
                    <label class="relative flex items-center gap-3 p-3 border border-outline-variant rounded-xl cursor-pointer hover:bg-surface-container-low transition-all group has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                        <input class="accent-primary w-4 h-4" name="paymentMethod" type="radio" value="zalopay"/>
                        <span class="w-8 h-8 bg-[#002f87] text-white flex items-center justify-center font-black rounded-lg text-[9px] uppercase">Zalo</span>
                        <div class="flex flex-col">
                            <span class="text-caption font-bold">Ví điện tử ZaloPay</span>
                            <span class="text-[10px] text-outline">Quét mã QR thanh toán nhanh qua ZaloPay</span>
                        </div>
                    </label>

                    <!-- Bank Transfer (ChuyenKhoan) -->
                    <label class="relative flex items-center gap-3 p-3 border border-outline-variant rounded-xl cursor-pointer hover:bg-surface-container-low transition-all group has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                        <input class="accent-primary w-4 h-4" name="paymentMethod" type="radio" value="chuyenkhoan"/>
                        <span class="w-8 h-8 bg-surface-container flex items-center justify-center rounded-lg text-primary"><span class="material-symbols-outlined text-[20px]">account_balance</span></span>
                        <div class="flex flex-col">
                            <span class="text-caption font-bold">Chuyển khoản Ngân hàng</span>
                            <span class="text-[10px] text-outline">Mô phỏng chuyển khoản Napas247</span>
                        </div>
                    </label>

                    <!-- Over the Counter (Tại quầy) -->
                    <label class="relative flex items-center gap-3 p-3 border border-outline-variant rounded-xl cursor-pointer hover:bg-surface-container-low transition-all group has-[:checked]:border-primary has-[:checked]:bg-primary/5">
                        <input class="accent-primary w-4 h-4" name="paymentMethod" type="radio" value="tai_quay"/>
                        <span class="w-8 h-8 bg-surface-container flex items-center justify-center rounded-lg text-secondary"><span class="material-symbols-outlined text-[20px]">store</span></span>
                        <div class="flex flex-col">
                            <span class="text-caption font-bold">Thanh toán tại quầy</span>
                            <span class="text-[10px] text-outline">Yêu cầu thanh toán tiền mặt/quẹt thẻ tại bệnh viện</span>
                        </div>
                    </label>
                </div>
                
                <form id="paymentForm" action="" method="GET">
                    <button id="payButton" type="submit" class="w-full bg-primary text-white py-3.5 rounded-2xl font-bold text-caption flex items-center justify-center gap-2 hover:bg-primary-container shadow-md shadow-primary/10 transition-all active:scale-[0.98]">
                        <span class="material-symbols-outlined text-[20px]">lock</span>
                        <span id="pay-button-text">Tiến hành thanh toán</span>
                    </button>
                </form>
            </section>
        </div>
    </div>
</div>

