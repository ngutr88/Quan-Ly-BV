@section Scripts {
    <script>
        // Invoices data serialized from C# Backend Model
        const invoicesData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Select(i => new {
            id = i.Id,
            code = "HD-" + i.Id.ToString("D5"),
            total = i.TongTien,
            formattedTotal = i.TongTien.ToString("N0") + " đ",
            status = i.TrangThaiThanhToan,
            method = i.PhuongThuc == "ChuaThanhToan" ? "Chưa thanh toán" : i.PhuongThuc,
            dateCreated = i.NgayTao.ToString("yyyy-MM-ddTHH:mm:ss"),
            dateCreatedFormatted = i.NgayTao.ToString("dd/MM/yyyy HH:mm"),
            datePaidFormatted = i.NgayThanhToan.HasValue ? i.NgayThanhToan.Value.ToString("dd/MM/yyyy HH:mm") : "N/A",
            transactionId = i.MaGiaoDich ?? "N/A",
            doctorName = i.ExaminationRecord?.Appointment?.Doctor?.User?.HoTen ?? "N/A",
            departmentName = i.ExaminationRecord?.Appointment?.Doctor?.Department?.TenKhoa ?? "N/A",
            examDateFormatted = i.ExaminationRecord?.NgayKham.ToString("dd/MM/yyyy") ?? "N/A",
            appointmentCode = "LK-" + (i.ExaminationRecord?.LichKhamId.ToString("D5") ?? "00000"),
            details = i.InvoiceDetails.Select(d => new {
                name = d.LoaiPhi,
                amount = d.SoTien.ToString("N0") + " đ"
            }).ToList()
        })));

        let activeInvoiceId = null;

        // Initialize and setup event listeners
        document.addEventListener("DOMContentLoaded", () => {
            // Register filter change events
            document.getElementById("filter-search").addEventListener("input", filterData);
            document.getElementById("filter-date-start").addEventListener("change", filterData);
            document.getElementById("filter-date-end").addEventListener("change", filterData);
            document.getElementById("filter-status").addEventListener("change", filterData);
            document.getElementById("filter-method").addEventListener("change", filterData);

            // Render first invoice or display empty states
            filterData();
        });

        // Main filter execution logic (Client-side)
        function filterData() {
            const query = document.getElementById("filter-search").value.toLowerCase().trim();
            const dateStart = document.getElementById("filter-date-start").value;
            const dateEnd = document.getElementById("filter-date-end").value;
            const statusFilter = document.getElementById("filter-status").value;
            const methodFilter = document.getElementById("filter-method").value;

            // Filter invoices
            const filteredInvoices = invoicesData.filter(i => {
                // Search query matching Invoice ID, Doctor Name, Department Name
                const matchQuery = !query || 
                                   i.code.toLowerCase().includes(query) || 
                                   i.doctorName.toLowerCase().includes(query) || 
                                   i.departmentName.toLowerCase().includes(query);

                // Date filtering (using dateCreated)
                const createdDateOnly = i.dateCreated.split("T")[0];
                const matchDateStart = !dateStart || createdDateOnly >= dateStart;
                const matchDateEnd = !dateEnd || createdDateOnly <= dateEnd;

                // Status filtering
                const matchStatus = !statusFilter || i.status === statusFilter;

                // Method filtering
                const matchMethod = !methodFilter || i.method.toLowerCase().includes(methodFilter.toLowerCase());

                return matchQuery && matchDateStart && matchDateEnd && matchStatus && matchMethod;
            });

            // Populate Invoices table
            const invoiceTableBody = document.querySelector("#invoices-table tbody");
            invoiceTableBody.innerHTML = "";

            if (filteredInvoices.length === 0) {
                document.getElementById("invoices-table").classList.add("hidden");
                document.getElementById("invoices-empty").classList.remove("hidden");
                
                // Adjust empty state details if filtered vs total
                if (invoicesData.length === 0) {
                    document.getElementById("empty-title").innerText = "Bạn chưa có hóa đơn nào";
                    document.getElementById("empty-desc").innerText = "Hiện tại tài khoản của bạn chưa phát sinh hóa đơn viện phí nào.";
                    document.getElementById("empty-cta").classList.remove("hidden");
                } else {
                    document.getElementById("empty-title").innerText = "Không tìm thấy hóa đơn";
                    document.getElementById("empty-desc").innerText = "Không có hóa đơn nào khớp với các bộ lọc tìm kiếm đã chọn.";
                    document.getElementById("empty-cta").classList.add("hidden");
                }
            } else {
                document.getElementById("invoices-table").classList.remove("hidden");
                document.getElementById("invoices-empty").classList.add("hidden");

                filteredInvoices.forEach(inv => {
                    const tr = document.createElement("tr");
                    tr.className = `hover:bg-surface-container/60 transition-colors cursor-pointer invoice-row border-b border-outline-variant/30 ${inv.id === activeInvoiceId ? "bg-surface-container font-medium border-l-4 border-primary" : ""}`;
                    tr.setAttribute("onclick", `selectInvoice(${inv.id}, this)`);

                    // Map badge status classes
                    let statusBadge = "";
                    if (inv.status === "DaThanhToan") {
                        statusBadge = `<span class="px-2.5 py-0.5 bg-secondary-container/20 text-secondary text-[11px] font-bold rounded-full border border-secondary/20 flex items-center w-fit gap-1">
                                           <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span> Đã thanh toán
                                       </span>`;
                    } else if (inv.status === "ChuaThanhToan") {
                        statusBadge = `<span class="px-2.5 py-0.5 bg-error-container/20 text-error text-[11px] font-bold rounded-full border border-error/20 flex items-center w-fit gap-1 animate-pulse">
                                           <span class="w-1.5 h-1.5 rounded-full bg-error animate-pulse"></span> Chưa thanh toán
                                       </span>`;
                    } else if (inv.status === "QuaHan") {
                        statusBadge = `<span class="px-2.5 py-0.5 bg-error text-white text-[11px] font-bold rounded-full border border-error flex items-center w-fit gap-1">
                                           <span class="w-1.5 h-1.5 rounded-full bg-white"></span> Quá hạn
                                       </span>`;
                    } else if (inv.status === "ThanhToanThatBai") {
                        statusBadge = `<span class="px-2.5 py-0.5 bg-error/10 text-error text-[11px] font-bold rounded-full border border-error/30 flex items-center w-fit gap-1">
                                           <span class="w-1.5 h-1.5 rounded-full bg-error"></span> Thất bại
                                       </span>`;
                    } else if (inv.status === "DangXuLy") {
                        statusBadge = `<span class="px-2.5 py-0.5 bg-primary-fixed/30 text-on-primary-fixed-variant text-[11px] font-bold rounded-full border border-primary-fixed-dim flex items-center w-fit gap-1">
                                           <span class="w-1.5 h-1.5 rounded-full bg-primary-fixed-dim"></span> Đang xử lý
                                       </span>`;
                    } else { // DaHuy
                        statusBadge = `<span class="px-2.5 py-0.5 bg-outline-variant/20 text-outline text-[11px] font-bold rounded-full border border-outline-variant flex items-center w-fit gap-1">
                                           <span class="w-1.5 h-1.5 rounded-full bg-outline"></span> Đã hủy
                                       </span>`;
                    }

                    tr.innerHTML = `
                        <td class="px-6 py-4.5 font-mono text-body-md text-primary font-bold">${inv.code}</td>
                        <td class="px-6 py-4.5 text-caption text-on-surface-variant">${inv.dateCreatedFormatted}</td>
                        <td class="px-6 py-4.5 text-caption font-semibold text-on-surface">${inv.doctorName} <span class="text-[10px] font-normal text-outline block">${inv.departmentName}</span></td>
                        <td class="px-6 py-4.5 text-body-md font-bold text-on-surface">${inv.formattedTotal}</td>
                        <td class="px-6 py-4.5">${statusBadge}</td>
                    `;
                    invoiceTableBody.appendChild(tr);
                });
            }

            // Populate Transactions History table (Completed, Processing, or Failed attempts)
            const transactionTableBody = document.querySelector("#transactions-table tbody");
            transactionTableBody.innerHTML = "";

            const transactionInvoices = invoicesData.filter(i => i.status === "DaThanhToan" || i.status === "DangXuLy" || i.status === "ThanhToanThatBai");
            
            if (transactionInvoices.length === 0) {
                document.getElementById("transactions-table").classList.add("hidden");
                document.getElementById("transactions-empty").classList.remove("hidden");
            } else {
                document.getElementById("transactions-table").classList.remove("hidden");
                document.getElementById("transactions-empty").classList.add("hidden");

                transactionInvoices.forEach(inv => {
                    const tr = document.createElement("tr");
                    tr.className = "border-b border-outline-variant/30 text-caption hover:bg-surface-container-lowest transition-colors";
                    
                    let statusBadge = "";
                    if (inv.status === "DaThanhToan") {
                        statusBadge = `<span class="px-2 py-0.5 bg-secondary-container/20 text-secondary text-[10px] font-bold rounded-full border border-secondary/20">Thành công</span>`;
                    } else if (inv.status === "DangXuLy") {
                        statusBadge = `<span class="px-2 py-0.5 bg-primary-fixed/30 text-on-primary-fixed-variant text-[10px] font-bold rounded-full border border-primary-fixed-dim">Đang xử lý</span>`;
                    } else {
                        statusBadge = `<span class="px-2 py-0.5 bg-error-container/20 text-error text-[10px] font-bold rounded-full border border-error/20">Thất bại</span>`;
                    }

                    tr.innerHTML = `
                        <td class="px-6 py-4 font-mono text-outline">${inv.datePaidFormatted !== "N/A" ? inv.datePaidFormatted : inv.dateCreatedFormatted}</td>
                        <td class="px-6 py-4 font-mono text-on-surface font-semibold">${inv.transactionId}</td>
                        <td class="px-6 py-4 text-on-surface-variant font-medium">${inv.method}</td>
                        <td class="px-6 py-4 font-bold text-on-surface">${inv.formattedTotal}</td>
                        <td class="px-6 py-4">${statusBadge}</td>
                    `;
                    transactionTableBody.appendChild(tr);
                });
            }

            // Update filters summary label
            document.getElementById("filter-summary").innerText = `Đang hiển thị ${filteredInvoices.length} trên tổng số ${invoicesData.length} hóa đơn.`;

            // Keep selected invoice active or select first if not selected
            if (filteredInvoices.length > 0) {
                document.getElementById("detail-pane").style.display = "flex";
                const stillExists = filteredInvoices.find(i => i.id === activeInvoiceId);
                if (stillExists) {
                    const activeRow = Array.from(document.querySelectorAll(".invoice-row")).find((tr, idx) => filteredInvoices[idx].id === activeInvoiceId);
                    if (activeRow) selectInvoice(activeInvoiceId, activeRow);
                } else {
                    const firstRow = document.querySelector(".invoice-row");
                    if (firstRow) selectInvoice(filteredInvoices[0].id, firstRow);
                }
            } else {
                document.getElementById("detail-pane").style.display = "none";
                activeInvoiceId = null;
            }
        }

        // Action when an invoice is clicked / selected
        function selectInvoice(id, rowElement) {
            activeInvoiceId = id;

            // Highlight row
            document.querySelectorAll(".invoice-row").forEach(r => {
                r.classList.remove("bg-surface-container", "font-medium", "border-l-4", "border-primary");
            });
            rowElement.classList.add("bg-surface-container", "font-medium", "border-l-4", "border-primary");

            // Load data
            const inv = invoicesData.find(i => i.id === id);
            if (!inv) return;

            // Update watermark
            const watermark = document.getElementById("status-watermark");
            watermark.innerText = inv.status === "DaThanhToan" ? "PAID" : 
                                  inv.status === "ChuaThanhToan" ? "UNPAID" : 
                                  inv.status === "QuaHan" ? "OVERDUE" : 
                                  inv.status === "ThanhToanThatBai" ? "FAILED" : 
                                  inv.status === "DangXuLy" ? "PENDING" : "CANCELLED";
            watermark.className = `absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 font-black text-[52px] uppercase select-none opacity-[0.06] rotate-12 z-0 pointer-events-none ${
                inv.status === "DaThanhToan" ? "text-secondary" : 
                inv.status === "ChuaThanhToan" || inv.status === "QuaHan" || inv.status === "ThanhToanThatBai" ? "text-error" : 
                inv.status === "DangXuLy" ? "text-primary" : "text-outline"
            }`;

            // Update details texts
            document.getElementById("detail-code").innerText = "#" + inv.code;
            document.getElementById("detail-dept").innerText = inv.departmentName;
            document.getElementById("detail-doctor").innerText = inv.doctorName;
            document.getElementById("detail-date-exam").innerText = inv.examDateFormatted;
            document.getElementById("detail-app-code").innerText = inv.appointmentCode;
            document.getElementById("detail-method").innerText = inv.method;
            document.getElementById("detail-transaction").innerText = inv.transactionId;
            document.getElementById("detail-total").innerText = inv.formattedTotal;

            // Populate Breakdown List
            const listContainer = document.getElementById("detail-list");
            listContainer.innerHTML = "";

            inv.details.forEach(d => {
                const div = document.createElement("div");
                div.className = "flex justify-between items-center py-2 border-b border-dashed border-outline-variant/40 last:border-0 text-caption";
                div.innerHTML = `
                    <span class="text-on-surface-variant font-medium">${d.name}</span>
                    <span class="font-semibold text-on-surface">${d.amount}</span>
                `;
                listContainer.appendChild(div);
            });

            // Update Payments Forms Section
            const paymentPanel = document.getElementById("payment-section");
            const form = document.getElementById("paymentForm");
            const canPay = inv.status === "ChuaThanhToan" || inv.status === "QuaHan" || inv.status === "ThanhToanThatBai";

            if (canPay) {
                paymentPanel.style.display = "block";
                document.getElementById("pay-button-text").innerText = inv.status === "ThanhToanThatBai" ? "Thanh toán lại" : "Tiến hành thanh toán";
                form.action = `/Patient/Payment/Simulate/${inv.id}`;
            } else {
                paymentPanel.style.display = "none";
            }

            // Populate clean print area for layout rendering
            populatePrintArea(inv);
        }

        // Setup print layout variables
        function populatePrintArea(inv) {
            document.getElementById("print-receipt-code").innerText = "#" + inv.code;
            document.getElementById("print-bill-no").innerText = "INV-" + String(inv.id).padStart(5, '0');
            document.getElementById("print-date-created").innerText = inv.dateCreatedFormatted;
            document.getElementById("print-dept").innerText = inv.departmentName;
            document.getElementById("print-doctor").innerText = inv.doctorName;
            document.getElementById("print-app-code").innerText = inv.appointmentCode;
            document.getElementById("print-date-paid").innerText = inv.datePaidFormatted;
            document.getElementById("print-method").innerText = inv.method;
            document.getElementById("print-transaction").innerText = inv.transactionId;
            document.getElementById("print-total-cost").innerText = inv.formattedTotal;

            const printTableBody = document.getElementById("print-items-body");
            printTableBody.innerHTML = "";
            inv.details.forEach(d => {
                const tr = document.createElement("tr");
                tr.innerHTML = `
                    <td style="padding: 10px 8px; border-bottom: 1px solid #e2e8f0; text-align: left;">${d.name}</td>
                    <td style="padding: 10px 8px; border-bottom: 1px solid #e2e8f0; text-align: right; font-weight: bold;">${d.amount}</td>
                `;
                printTableBody.appendChild(tr);
            });

            // Watermark text in PDF
            const pdfWatermark = document.getElementById("print-watermark-status");
            if (inv.status === "DaThanhToan") {
                pdfWatermark.innerText = "ĐÃ THANH TOÁN THÀNH CÔNG";
                pdfWatermark.style.color = "#006c49";
                pdfWatermark.style.borderColor = "#006c49";
                pdfWatermark.style.backgroundColor = "#e6f7f0";
            } else if (inv.status === "ChuaThanhToan") {
                pdfWatermark.innerText = "HÓA ĐƠN CHƯA THANH TOÁN";
                pdfWatermark.style.color = "#ba1a1a";
                pdfWatermark.style.borderColor = "#ba1a1a";
                pdfWatermark.style.backgroundColor = "#ffdad6";
            } else if (inv.status === "QuaHan") {
                pdfWatermark.innerText = "CẢNH BÁO: HÓA ĐƠN QUÁ HẠN";
                pdfWatermark.style.color = "#ba1a1a";
                pdfWatermark.style.borderColor = "#ba1a1a";
                pdfWatermark.style.backgroundColor = "#ffdad6";
            } else if (inv.status === "DangXuLy") {
                pdfWatermark.innerText = "GIAO DỊCH ĐANG CHỜ XỬ LÝ";
                pdfWatermark.style.color = "#003f87";
                pdfWatermark.style.borderColor = "#003f87";
                pdfWatermark.style.backgroundColor = "#d7e2ff";
            } else if (inv.status === "ThanhToanThatBai") {
                pdfWatermark.innerText = "GIAO DỊCH THANH TOÁN THẤT BẠI";
                pdfWatermark.style.color = "#ba1a1a";
                pdfWatermark.style.borderColor = "#ba1a1a";
                pdfWatermark.style.backgroundColor = "#ffdad6";
            } else {
                pdfWatermark.innerText = "HÓA ĐƠN ĐÃ HỦY BỎ";
                pdfWatermark.style.color = "#727784";
                pdfWatermark.style.borderColor = "#727784";
                pdfWatermark.style.backgroundColor = "#f1f5f9";
            }
        }

        // Send Email Receipt
        function sendEmailReceipt(event) {
            if (!activeInvoiceId) return;

            const button = event.currentTarget;
            button.disabled = true;
            const originalHtml = button.innerHTML;
            button.innerHTML = `<span class="material-symbols-outlined text-[20px] text-tertiary animate-spin">sync</span> <span class="font-semibold">Đang gửi...</span>`;

            fetch(`/Patient/Payment/SendEmailReceipt/${activeInvoiceId}`, {
                method: "POST",
                headers: {
                    "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]').value
                }
            })
            .then(res => res.json())
            .then(data => {
                button.disabled = false;
                button.innerHTML = originalHtml;

                if (data.success) {
                    showGlobalToast("Thành công", data.message, "success");
                } else {
                    showGlobalToast("Thất bại", data.message, "error");
                }
            })
            .catch(err => {
                button.disabled = false;
                button.innerHTML = originalHtml;
                showGlobalToast("Thất bại", "Không thể gửi email biên lai lúc này. Vui lòng thử lại sau.", "error");
            });
        }

        // Print Invoice receipt
        function printInvoice() {
            if (!activeInvoiceId) return;

            const printContents = document.getElementById("receipt-print-area").innerHTML;
            const printWindow = window.open("", "_blank");
            printWindow.document.write(`
                <html>
                <head>
                    <title>In biên lai hóa đơn #${activeInvoiceId}</title>
                    <style>
                        body { font-family: sans-serif; padding: 20px; }
                        table { border-collapse: collapse; }
                        @@media print {
                            body { padding: 0; }
                            .no-print { display: none; }
                        }
                    </style>
                </head>
                <body>
                    ${printContents}
                    <script>
                        window.onload = function() {
                            window.print();
                            setTimeout(function() { window.close(); }, 500);
                        };
                    <\/script>
                </body>
                </html>
            `);
            printWindow.document.close();
        }

        // Client-side PDF Generation with html2pdf
        function downloadPdf() {
            if (!activeInvoiceId) return;

            const element = document.getElementById("receipt-print-area");
            
            // Temporary reveal element for capture, clean print style
            element.classList.remove("hidden");
            
            const opt = {
                margin:       10,
                filename:     `Bien_lai_vien_phi_HD-${String(activeInvoiceId).padStart(5, '0')}.pdf`,
                image:        { type: 'jpeg', quality: 0.98 },
                html2canvas:  { scale: 2.5, useCORS: true, logging: false },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            html2pdf().set(opt).from(element).save().then(() => {
                element.classList.add("hidden");
                showGlobalToast("Tải PDF thành công", "Biên lai hóa đơn đã được tải xuống dưới dạng PDF.", "success");
            }).catch(err => {
                element.classList.add("hidden");
                showGlobalToast("Lỗi", "Không thể tạo PDF biên lai.", "error");
            });
        }

        // Reset all filters in UI
        function resetFilters() {
            document.getElementById("filter-search").value = "";
            document.getElementById("filter-date-start").value = "";
            document.getElementById("filter-date-end").value = "";
            document.getElementById("filter-status").value = "";
            document.getElementById("filter-method").value = "";
            filterData();
        }

        // Intercept form submit to append checked radio method
        document.getElementById("paymentForm").addEventListener("submit", (e) => {
            const checkedRadio = document.querySelector('input[name="paymentMethod"]:checked');
            if (checkedRadio) {
                const method = checkedRadio.value;
                const form = document.getElementById("paymentForm");
                form.action = `/Patient/Payment/Simulate/${activeInvoiceId}?paymentMethod=${method}`;
            }
        });
    </script>
}
