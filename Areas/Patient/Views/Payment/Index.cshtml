@model IEnumerable<QuanLyBenhVien.Models.Invoice>

@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "Hóa đơn thanh toán";
}

<div class="mb-unit-lg">
    <h2 class="font-headline-lg text-headline-lg text-on-surface">Hóa đơn thanh toán</h2>
    <p class="text-body-md text-on-surface-variant">Danh sách hóa đơn phí dịch vụ khám bệnh và đơn thuốc của bạn.</p>
</div>

<div class="bg-white border border-outline-variant rounded-xl overflow-hidden shadow-sm">
    <div class="overflow-x-auto">
        <table class="w-full text-left text-body-md">
            <thead>
                <tr class="bg-surface-container-low text-on-surface-variant font-label-md text-[12px] uppercase border-b border-outline-variant">
                    <th class="px-unit-md py-3">Số Hóa đơn</th>
                    <th class="px-unit-md py-3">Ngày phát sinh</th>
                    <th class="px-unit-md py-3">Bác sĩ khám</th>
                    <th class="px-unit-md py-3">Tổng số tiền</th>
                    <th class="px-unit-md py-3">Trạng thái</th>
                    <th class="px-unit-md py-3 text-right">Hành động</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-outline-variant">
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="px-unit-md py-8 text-center text-on-surface-variant italic">Bạn không có hóa đơn nào trên hệ thống.</td>
                    </tr>
                }
                else
                {
                    @foreach (var inv in Model)
                    {
                        <tr class="hover:bg-surface-container-low transition-colors">
                            <td class="px-unit-md py-4 font-mono font-bold text-primary">#HD-@inv.Id.ToString("D5")</td>
                            <td class="px-unit-md py-4">@inv.NgayTao.ToString("dd/MM/yyyy HH:mm")</td>
                            <td class="px-unit-md py-4 text-on-surface-variant">@inv.ExaminationRecord.Appointment.Doctor?.User.HoTen</td>
                            <td class="px-unit-md py-4 font-bold">@inv.TongTien.ToString("N0") đ</td>
                            <td class="px-unit-md py-4">
                                @if (inv.TrangThaiThanhToan == "DaThanhToan")
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-secondary/15 text-secondary text-[11px] font-bold">Đã thanh toán</span>
                                }
                                else if (inv.TrangThaiThanhToan == "ChuaThanhToan")
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-error-container text-error text-[11px] font-bold animate-pulse">Chưa trả</span>
                                }
                                else
                                {
                                    <span class="px-2.5 py-0.5 rounded-full bg-surface-container-high text-on-surface-variant text-[11px] font-bold">Đã hủy</span>
                                }
                            </td>
                            <td class="px-unit-md py-4 text-right">
                                <a href="/Patient/Payment/Details/@inv.Id" class="inline-flex items-center gap-0.5 bg-surface-container hover:bg-surface-container-high px-3 py-1.5 rounded-lg text-label-md transition-colors text-primary font-semibold border border-outline-variant/30">
                                    Chi tiết <span class="material-symbols-outlined text-[16px]">chevron_right</span>
                                </a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
