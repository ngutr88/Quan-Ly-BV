@model IEnumerable<QuanLyBenhVien.Models.ExaminationRecord>

@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    var patientDocuments = ViewBag.PatientDocuments as List<QuanLyBenhVien.Models.PatientDocument> ?? new List<QuanLyBenhVien.Models.PatientDocument>();
    ViewData["Title"] = "Đơn thuốc & Bệnh án";
}

@section Styles {
<style>
    .record-card {
        transition: all 0.22s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .record-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0, 63, 135, 0.08);
    }
    .doc-avatar {
        background: linear-gradient(135deg, #e0f2fe 0%, #bae6fd 100%);
    }
    .prescription-btn {
        background-color: rgba(16, 185, 129, 0.08);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: #047857;
    }
    .prescription-btn:hover {
        background-color: #10b981;
        color: #ffffff;
    }
    .review-btn {
        background-color: rgba(0, 63, 135, 0.04);
        border: 1px solid rgba(0, 63, 135, 0.12);
        color: #003f87;
    }
    .review-btn:hover {
        background-color: #003f87;
        color: #ffffff;
    }
</style>
}

<div class="w-full max-w-5xl mx-auto animate-fadein pb-12">
    <!-- Header -->
    <div class="border-b border-outline-variant/60 pb-4 mb-6">
        <h2 class="font-headline-lg text-2xl md:text-3xl font-bold text-on-surface">Lịch sử điều trị &amp; Đơn thuốc</h2>
        <p class="text-body-md text-on-surface-variant mt-1">Tra cứu chẩn đoán y khoa, lời dặn của bác sĩ điều trị và xem đơn thuốc điện tử.</p>
    </div>

    <section class="mb-6 bg-surface-container-lowest border border-outline-variant rounded-2xl p-5 shadow-sm">
        <div class="flex flex-col md:flex-row md:items-center justify-between gap-3 mb-4">
            <div>
                <h3 class="text-title-lg font-bold text-on-surface flex items-center gap-2"><span class="material-symbols-outlined text-primary">folder_shared</span> Sổ khám & giấy tờ khám trước</h3>
                <p class="text-body-md text-on-surface-variant mt-1">Bác sĩ phụ trách lịch hẹn có thể xem các tài liệu này trước khi khám.</p>
            </div>
            <form method="post" action="/Patient/Record/UploadDocument" enctype="multipart/form-data" class="flex flex-wrap items-center gap-2">
                @Html.AntiForgeryToken()
                <input type="text" name="tenTaiLieu" placeholder="Tên tài liệu" class="border border-outline-variant rounded-lg px-3 py-2 text-sm" />
                <input type="file" name="file" accept=".pdf,.jpg,.jpeg,.png" required class="max-w-[220px] text-sm" />
                <button type="submit" class="px-4 py-2 bg-primary text-white rounded-lg font-semibold hover:bg-primary-container">Tải lên</button>
            </form>
        </div>
        @if (patientDocuments.Any())
        {
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                @foreach (var document in patientDocuments)
                {
                    <div class="flex items-center justify-between gap-3 border border-outline-variant rounded-xl p-3">
                        <div class="min-w-0"><p class="font-semibold truncate">@document.TenTaiLieu</p><p class="text-xs text-on-surface-variant">@document.NgayTaiLen.ToString("dd/MM/yyyy HH:mm") · @(document.KichThuoc / 1024) KB</p></div>
                        <div class="flex items-center gap-1 shrink-0"><a href="/Patient/Record/DownloadDocument/@document.Id" target="_blank" class="p-2 text-primary hover:bg-primary/10 rounded-lg" title="Xem tài liệu"><span class="material-symbols-outlined">visibility</span></a><form method="post" action="/Patient/Record/DeleteDocument/@document.Id">@Html.AntiForgeryToken()<button class="p-2 text-error hover:bg-error/10 rounded-lg" title="Xóa tài liệu"><span class="material-symbols-outlined">delete</span></button></form></div>
                    </div>
                }
            </div>
        }
        else
        {
            <p class="text-body-md text-on-surface-variant italic">Chưa có giấy tờ khám trước được tải lên.</p>
        }
    </section>

    <!-- Cards Grid -->
    <div class="space-y-4">
        @if (!Model.Any())
        {
            <div class="bg-surface-container-lowest border border-outline-variant rounded-2xl p-12 text-center shadow-sm">
                <span class="material-symbols-outlined text-[64px] text-on-surface-variant/40 mb-3">clinical_notes</span>
                <p class="text-body-lg font-bold text-on-surface">Không tìm thấy bệnh án</p>
                <p class="text-body-md text-on-surface-variant mt-1">Bạn chưa thực hiện bất kỳ ca khám bệnh nào tại bệnh viện HMS.</p>
                <a href="/Patient/Book" class="mt-4 inline-flex items-center gap-1 bg-primary text-on-primary px-5 py-2.5 rounded-xl font-bold hover:bg-primary/95 transition-all shadow-md">
                    Đặt lịch khám ngay
                </a>
            </div>
        }
        else
        {
            @foreach (var record in Model)
            {
                var hasPrescription = ViewBag.RecordsWithPrescriptions != null && ((List<int>)ViewBag.RecordsWithPrescriptions).Contains(record.Id);

                <div class="record-card bg-surface-container-lowest border border-outline-variant rounded-2xl p-5 md:p-6 shadow-sm flex flex-col md:flex-row md:items-center justify-between gap-6">
                    <!-- Left: Medical Info -->
                    <div class="flex items-start gap-4 min-w-0 flex-grow">
                        <!-- Date Badge & Initial -->
                        <div class="w-12 h-12 rounded-2xl doc-avatar flex items-center justify-center shrink-0 text-primary font-bold text-lg border border-sky-100">
                            @(record.Appointment.Doctor != null ? record.Appointment.Doctor.User.HoTen[0].ToString().ToUpper() : "BS")
                        </div>
                        <!-- Diagnosis & Details -->
                        <div class="min-w-0 flex-grow space-y-1">
                            <div class="flex flex-wrap items-center gap-2">
                                <span class="text-caption text-primary font-bold bg-primary-container/20 border border-primary/10 px-2.5 py-0.5 rounded-full text-[11px]">
                                    @record.NgayKham.ToString("dd/MM/yyyy")
                                </span>
                                <span class="text-caption text-on-surface-variant font-semibold bg-surface-container border border-outline-variant px-2.5 py-0.5 rounded-full text-[11px]">
                                    @(record.Appointment.Doctor != null ? record.Appointment.Doctor.Department.TenKhoa : "N/A")
                                </span>
                            </div>
                            <h3 class="font-bold text-on-surface text-base md:text-lg mt-1 truncate">
                                @record.ChanDoan
                            </h3>
                            <p class="text-caption text-on-surface-variant leading-relaxed">
                                <strong class="font-semibold text-on-surface-variant">Bác sĩ:</strong> @(record.Appointment.Doctor != null ? record.Appointment.Doctor.User.HoTen : "N/A")
                            </p>
                            @if (!string.IsNullOrEmpty(record.TrieuChung))
                            {
                                <p class="text-caption text-on-surface-variant/90 leading-relaxed italic">
                                    "Triệu chứng: @record.TrieuChung"
                                </p>
                            }
                        </div>
                    </div>

                    <!-- Right: Actions & Prescription Link -->
                    <div class="flex flex-col sm:flex-row md:flex-col lg:flex-row items-stretch sm:items-center md:items-stretch lg:items-center gap-2.5 shrink-0">
                        <!-- Rating Button -->
                        @if (record.Appointment.Doctor != null)
                        {
                            <button type="button" onclick="openReviewModal(@record.Appointment.Doctor.Id, '@record.Appointment.Doctor.User.HoTen')" class="review-btn inline-flex items-center justify-center gap-1.5 px-4.5 py-2.5 rounded-xl text-sm font-bold transition-all active:scale-[0.98] cursor-pointer">
                                <span class="material-symbols-outlined text-[18px]">star</span> Đánh giá BS
                            </button>
                        }

                        <!-- Prescription Button / No Prescription Indicator -->
                        @if (hasPrescription)
                        {
                            <a href="/Patient/Record/PrescriptionDetails/@record.Id" class="prescription-btn inline-flex items-center justify-center gap-1.5 px-4.5 py-2.5 rounded-xl text-sm font-bold transition-all active:scale-[0.98]">
                                <span class="material-symbols-outlined text-[18px]">receipt_long</span> Đơn thuốc
                            </a>
                        }
                        else
                        {
                            <span class="inline-flex items-center justify-center gap-1.5 px-4.5 py-2.5 border border-dashed border-outline-variant/60 text-on-surface-variant/60 rounded-xl text-sm font-semibold select-none bg-surface-container-low/20">
                                <span class="material-symbols-outlined text-[18px]">healing</span> Không kê đơn
                            </span>
                        }
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Review Modal -->
<div id="reviewModal" class="fixed inset-0 bg-on-background/40 z-[100] hidden items-center justify-center p-4">
    <div class="bg-surface-container-lowest border border-outline-variant rounded-2xl w-full max-w-md shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300">
        <div class="px-6 py-4 border-b border-outline-variant bg-surface flex justify-between items-center">
            <h3 class="font-bold text-title-lg text-on-surface">Đánh giá Bác sĩ</h3>
            <button type="button" onclick="closeReviewModal()" class="p-2 hover:bg-surface-container-high rounded-full cursor-pointer text-on-surface-variant">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form id="reviewForm" onsubmit="submitReview(event)">
            @Html.AntiForgeryToken()
            <input type="hidden" id="reviewDoctorId" name="doctorId" />
            <div class="p-6 space-y-4">
                <div class="text-center">
                    <p class="text-body-md text-on-surface-variant">Bạn đang đánh giá bác sĩ:</p>
                    <strong class="text-title-lg text-primary block mt-1" id="reviewDoctorName">BS. Nguyễn Văn A</strong>
                </div>
                
                <!-- Star Rating -->
                <div class="flex flex-col items-center gap-2">
                    <label class="block font-label-md text-label-md text-on-surface-variant">Chọn mức độ hài lòng (1-5 sao) <span class="text-error">*</span></label>
                    <div class="flex gap-1 text-[32px] text-outline cursor-pointer" id="starContainer">
                        <span class="material-symbols-outlined star-icon hover:scale-110 transition-transform" data-value="1">star</span>
                        <span class="material-symbols-outlined star-icon hover:scale-110 transition-transform" data-value="2">star</span>
                        <span class="material-symbols-outlined star-icon hover:scale-110 transition-transform" data-value="3">star</span>
                        <span class="material-symbols-outlined star-icon hover:scale-110 transition-transform" data-value="4">star</span>
                        <span class="material-symbols-outlined star-icon hover:scale-110 transition-transform" data-value="5">star</span>
                    </div>
                    <input type="hidden" id="selectedRating" name="rating" required />
                </div>

                <div>
                    <label class="block font-label-md text-label-md text-on-surface-variant mb-1" for="reviewComment">Nhận xét của bạn</label>
                    <textarea id="reviewComment" name="comment" rows="4" 
                              class="w-full border border-outline-variant rounded-lg text-body-md focus:border-primary focus:ring-0 px-3 py-2 bg-surface" 
                              placeholder="Hãy chia sẻ cảm nhận của bạn về sự tận tâm, chuyên môn và thái độ của bác sĩ..."></textarea>
                </div>
            </div>
            <div class="px-6 py-4 bg-surface-container-low border-t border-outline-variant flex gap-unit-md justify-end">
                <button type="button" onclick="closeReviewModal()" class="px-4 py-2 border border-outline text-on-surface-variant font-semibold rounded-lg hover:bg-surface-container-high cursor-pointer">Hủy</button>
                <button type="submit" class="px-6 py-2 bg-primary text-white font-semibold rounded-lg hover:bg-primary-container shadow-md cursor-pointer">Gửi đánh giá</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        let currentSelectedRating = 0;

        document.querySelectorAll('.star-icon').forEach(star => {
            star.addEventListener('mouseenter', () => {
                const val = parseInt(star.getAttribute('data-value'));
                highlightStars(val);
            });

            star.addEventListener('mouseleave', () => {
                highlightStars(currentSelectedRating);
            });

            star.addEventListener('click', () => {
                currentSelectedRating = parseInt(star.getAttribute('data-value'));
                document.getElementById('selectedRating').value = currentSelectedRating;
                highlightStars(currentSelectedRating);
            });
        });

        function highlightStars(count) {
            document.querySelectorAll('.star-icon').forEach(star => {
                const val = parseInt(star.getAttribute('data-value'));
                if (val <= count) {
                    star.classList.remove('text-outline');
                    star.classList.add('text-primary');
                    star.style.fontVariationSettings = "'FILL' 1";
                } else {
                    star.classList.remove('text-primary');
                    star.classList.add('text-outline');
                    star.style.fontVariationSettings = "'FILL' 0";
                }
            });
        }

        async function openReviewModal(doctorId, doctorName) {
            document.getElementById('reviewDoctorId').value = doctorId;
            document.getElementById('reviewDoctorName').innerText = doctorName;
            
            // Reset modal inputs
            currentSelectedRating = 0;
            document.getElementById('selectedRating').value = "";
            document.getElementById('reviewComment').value = "";
            highlightStars(0);

            try {
                // Fetch previous review if exists
                const response = await fetch(`/Patient/Record/GetReview?doctorId=${doctorId}`);
                const result = await response.json();
                
                if (result.exists) {
                    currentSelectedRating = result.rating;
                    document.getElementById('selectedRating').value = result.rating;
                    document.getElementById('reviewComment').value = result.comment;
                    highlightStars(result.rating);
                }
            } catch (err) {
                console.error("Error fetching review:", err);
            }

            const modal = document.getElementById('reviewModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            setTimeout(() => {
                modal.firstElementChild.classList.remove('scale-95');
                modal.firstElementChild.classList.add('scale-100');
            }, 10);
        }

        function closeReviewModal() {
            const modal = document.getElementById('reviewModal');
            modal.firstElementChild.classList.remove('scale-100');
            modal.firstElementChild.classList.add('scale-95');
            setTimeout(() => {
                modal.classList.add('hidden');
                modal.classList.remove('flex');
            }, 150);
        }

        async function submitReview(e) {
            e.preventDefault();
            const doctorId = document.getElementById('reviewDoctorId').value;
            const rating = document.getElementById('selectedRating').value;
            const comment = document.getElementById('reviewComment').value;
            const token = document.querySelector('input[name="__RequestVerificationToken"]').value;

            if (!rating) {
                alert("Vui lòng chọn số sao đánh giá.");
                return;
            }

            const formData = new FormData();
            formData.append("doctorId", doctorId);
            formData.append("rating", rating);
            formData.append("comment", comment);
            formData.append("__RequestVerificationToken", token);

            try {
                const response = await fetch('/Patient/Record/SubmitReview', {
                    method: 'POST',
                    body: formData
                });

                const result = await response.json();
                if (result.success) {
                    closeReviewModal();
                    showGlobalToast("Thành công", "Đánh giá của bạn đã được gửi thành công.", "success");
                } else {
                    alert("Lỗi khi gửi đánh giá: " + result.message);
                }
            } catch (err) {
                alert("Lỗi kết nối khi gửi đánh giá.");
            }
        }

        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeReviewModal();
        });
    </script>
}
