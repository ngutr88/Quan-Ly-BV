@model IEnumerable<QuanLyBenhVien.Models.Dependent>
@{
    Layout = "~/Views/Shared/_PatientLayout.cshtml";
    ViewData["Title"] = "Hồ sơ người thân";
    var patient = ViewBag.Patient as QuanLyBenhVien.Models.Patient;
}

<!-- Alert Messages -->
<div id="alertContainer"></div>

<div class="mb-unit-lg flex flex-col md:flex-row md:items-end justify-between gap-unit-md">
    <div>
        <nav class="flex items-center gap-2 text-label-md font-label-md text-on-surface-variant mb-2">
            <a href="/Patient/Dashboard" class="hover:text-primary">Trang chủ</a>
            <span class="material-symbols-outlined text-[14px]">chevron_right</span>
            <span class="text-primary font-bold">Hồ sơ người thân</span>
        </nav>
        <h1 class="hms-page-title">Người thân của tôi</h1>
        <p class="hms-page-subtitle">Quản lý danh sách hồ sơ người thân để tiện đặt lịch khám bệnh hộ hoặc theo dõi sức khỏe.</p>
    </div>
    <div>
        <button onclick="openAddModal()"
            class="hms-btn hms-btn-primary">
            <span class="material-symbols-outlined">person_add</span> Thêm người thân
        </button>
    </div>
</div>

<!-- Dependents Grid -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-unit-lg" id="dependentsGrid">
    @if (Model == null || !Model.Any())
    {
        @* Sized to fill the canvas: a short empty-state card left a large dead
           band underneath it. Only the empty state stretches — a populated grid
           keeps its cards at their natural height. *@
        <div class="md:col-span-2 bg-white border border-outline-variant p-unit-xl rounded-xl text-center shadow-sm py-12 flex flex-col items-center justify-center min-h-[520px]" id="emptyDependents">
            <span class="material-symbols-outlined text-[48px] text-outline mb-2">group</span>
            <p class="text-body-lg font-semibold text-on-surface-variant">Chưa có hồ sơ người thân nào</p>
            <p class="text-caption text-outline">Vui lòng thêm người thân để đăng ký khám bệnh hộ hoặc theo dõi sức khỏe.</p>
        </div>
    }
    else
    {
        @foreach (var dep in Model)
        {
            var initials = string.IsNullOrWhiteSpace(dep.HoTen) ? "NT" : dep.HoTen.Trim().Split(' ').Last().Substring(0, 1).ToUpper();
            var age = DateTime.Today.Year - dep.NamSinh;
            <div class="bg-white border border-outline-variant rounded-2xl p-unit-lg shadow-sm flex flex-col justify-between group hover:border-primary transition-all relative">
                <span class="absolute top-4 right-4 bg-primary/10 text-primary text-[10px] px-2 py-0.5 rounded font-bold uppercase">@dep.QuanHe</span>
                <div class="flex items-start gap-4">
                    <div class="w-14 h-14 rounded-full bg-primary-fixed flex items-center justify-center text-primary font-bold text-xl uppercase">
                        @initials
                    </div>
                    <div>
                        <h3 class="text-title-lg font-bold text-on-surface group-hover:text-primary transition-colors">@dep.HoTen</h3>
                        <p class="text-body-md text-on-surface-variant mt-0.5">@age tuổi (@dep.NamSinh) • @dep.GioiTinh</p>
                        <div class="mt-3 space-y-1 text-caption text-on-surface-variant">
                            <p class="flex items-center gap-1"><span class="font-semibold text-on-surface">Mã số thẻ BHYT:</span> @(string.IsNullOrEmpty(dep.SoBHYT) ? "Không có" : dep.SoBHYT)</p>
                            <p class="flex items-center gap-1"><span class="font-semibold text-on-surface">Nhóm máu:</span> @dep.NhomMau</p>
                            <p class="flex items-center gap-1"><span class="font-semibold text-on-surface">Tiền sử bệnh lý:</span> @(string.IsNullOrEmpty(dep.TienSuBenhLy) ? "Không" : dep.TienSuBenhLy)</p>
                        </div>
                    </div>
                </div>
                <div class="mt-6 pt-4 border-t border-outline-variant/60 flex gap-unit-md">
                    <a href="/Patient/Book?dependent=@Uri.EscapeDataString(dep.HoTen)"
                        class="flex-1 text-center bg-secondary text-white hover:bg-on-secondary-container py-2 rounded-lg font-semibold text-body-md transition-colors shadow-sm">
                        Đặt lịch khám hộ
                    </a>
                    <button onclick="alert('Đang hiển thị lịch sử khám của @dep.HoTen (tính năng demo)')"
                        class="flex-1 text-center border border-outline text-on-surface-variant hover:bg-surface-container-low py-2 rounded-lg font-semibold text-body-md transition-all cursor-pointer">
                        Lịch sử khám
                    </button>
                </div>
            </div>
        }
    }
</div>

<!-- Add Dependent Modal -->
<div id="addModal" class="fixed inset-0 bg-on-background/40 z-[100] hidden items-center justify-center p-4">
    <div class="bg-surface-container-lowest border border-outline-variant rounded-2xl w-full max-w-md shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300">
        <div class="px-6 py-4 border-b border-outline-variant bg-surface flex justify-between items-center">
            <h3 class="font-bold text-title-lg text-on-surface">Thêm Người Thân Mới</h3>
            <button onclick="closeAddModal()" class="p-2 hover:bg-surface-container-high rounded-full cursor-pointer text-on-surface-variant">
                <span class="material-symbols-outlined">close</span>
            </button>
        </div>
        <form id="addForm" onsubmit="saveDependent(event)">
            @Html.AntiForgeryToken()
            <div class="p-6 space-y-4">
                <div>
                    <label class="block font-label-md text-label-md text-on-surface-variant mb-1">Họ và tên <span class="text-error">*</span></label>
                    <input type="text" id="depName" required
                        class="w-full border border-outline-variant rounded-lg text-body-md focus:border-primary focus:ring-0 px-3 py-2 bg-surface"
                        placeholder="Ví dụ: Nguyễn Văn B" />
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block font-label-md text-label-md text-on-surface-variant mb-1">Mối quan hệ <span class="text-error">*</span></label>
                        <select id="depRelation" required
                            class="w-full border border-outline-variant rounded-lg text-body-md focus:border-primary focus:ring-0 px-3 py-2 bg-surface">
                            <option value="Con trai">Con trai</option>
                            <option value="Con gái">Con gái</option>
                            <option value="Cha ruột">Cha ruột</option>
                            <option value="Mẹ ruột">Mẹ ruột</option>
                            <option value="Vợ/Chồng">Vợ/Chồng</option>
                            <option value="Khác">Khác</option>
                        </select>
                    </div>
                    <div>
                        <label class="block font-label-md text-label-md text-on-surface-variant mb-1">Giới tính <span class="text-error">*</span></label>
                        <select id="depGender" required
                            class="w-full border border-outline-variant rounded-lg text-body-md focus:border-primary focus:ring-0 px-3 py-2 bg-surface">
                            <option value="Nam">Nam</option>
                            <option value="Nữ">Nữ</option>
                        </select>
                    </div>
                </div>
                <div class="grid grid-cols-2 gap-4">
                    <div>
                        <label class="block font-label-md text-label-md text-on-surface-variant mb-1">Năm sinh <span class="text-error">*</span></label>
                        <input type="number" id="depBirthYear" required min="1900" max="2026"
                            class="w-full border border-outline-variant rounded-lg text-body-md focus:border-primary focus:ring-0 px-3 py-2 bg-surface"
                            placeholder="Ví dụ: 2018" />
                    </div>
                    <div>
                        <label class="block font-label-md text-label-md text-on-surface-variant mb-1">Nhóm máu</label>
                        <input type="text" id="depBlood"
                            class="w-full border border-outline-variant rounded-lg text-body-md focus:border-primary focus:ring-0 px-3 py-2 bg-surface"
                            placeholder="Ví dụ: O+" />
                    </div>
                </div>
                <div>
                    <label class="block font-label-md text-label-md text-on-surface-variant mb-1">Số thẻ BHYT</label>
                    <input type="text" id="depBHYT"
                        class="w-full border border-outline-variant rounded-lg text-body-md focus:border-primary focus:ring-0 px-3 py-2 bg-surface"
                        placeholder="Ví dụ: GD4797920102" />
                </div>
                <div>
                    <label class="block font-label-md text-label-md text-on-surface-variant mb-1">Tiền sử bệnh lý</label>
                    <input type="text" id="depHistory"
                        class="w-full border border-outline-variant rounded-lg text-body-md focus:border-primary focus:ring-0 px-3 py-2 bg-surface"
                        placeholder="Tiểu đường, dị ứng thuốc..." />
                </div>
            </div>
            <div class="px-6 py-4 bg-surface-container-low border-t border-outline-variant flex gap-unit-md justify-end">
                <button type="button" onclick="closeAddModal()"
                    class="px-4 py-2 border border-outline text-on-surface-variant font-semibold rounded-lg hover:bg-surface-container-high cursor-pointer">Hủy</button>
                <button type="submit"
                    class="px-6 py-2 bg-primary text-white font-semibold rounded-lg hover:bg-primary-container shadow-md cursor-pointer">Lưu</button>
            </div>
        </form>
    </div>
</div>

<script>
    function openAddModal() {
        const modal = document.getElementById('addModal');
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        setTimeout(() => {
            modal.firstElementChild.classList.remove('scale-95');
            modal.firstElementChild.classList.add('scale-100');
        }, 10);
    }

    function closeAddModal() {
        const modal = document.getElementById('addModal');
        modal.firstElementChild.classList.remove('scale-100');
        modal.firstElementChild.classList.add('scale-95');
        setTimeout(() => {
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }, 150);
    }

    async function saveDependent(e) {
        e.preventDefault();

        const name = document.getElementById('depName').value;
        const relation = document.getElementById('depRelation').value;
        const gender = document.getElementById('depGender').value;
        const birthYear = document.getElementById('depBirthYear').value;
        const blood = document.getElementById('depBlood').value || 'O+';
        const bhyt = document.getElementById('depBHYT').value || '';
        const history = document.getElementById('depHistory').value || '';
        const token = document.querySelector('#addForm input[name="__RequestVerificationToken"]').value;

        const formData = new FormData();
        formData.append("name", name);
        formData.append("relation", relation);
        formData.append("gender", gender);
        formData.append("birthYear", birthYear);
        formData.append("blood", blood);
        formData.append("bhyt", bhyt);
        formData.append("history", history);
        formData.append("__RequestVerificationToken", token);

        try {
            const response = await fetch('/Patient/Record/AddDependent', {
                method: 'POST',
                body: formData
            });

            const result = await response.json();
            if (result.success) {
                closeAddModal();
                document.getElementById('addForm').reset();
                
                // Show success toast or alert
                if (typeof showGlobalToast === 'function') {
                    showGlobalToast('Thành công', `Đã thêm người thân ${result.name} thành công.`, 'success');
                } else {
                    alert(`Đã thêm người thân ${result.name} thành công.`);
                }
                
                // Reload after brief delay to show toast
                setTimeout(() => location.reload(), 1000);
            } else {
                alert("Lỗi khi thêm người thân: " + result.message);
            }
        } catch (err) {
            alert("Lỗi kết nối khi gửi yêu cầu.");
        }
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeAddModal();
    });
</script>
